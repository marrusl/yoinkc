#!/usr/bin/env python3
"""
yoinkc-build — build a bootc image from yoinkc output with automatic RHEL
entitlement handling.

Usage:
    ./yoinkc-build ./yoinkc-output/ my-bootc-image:latest
    ./yoinkc-build output.tar.gz my-bootc-image:v1.0
    ./yoinkc-build ./yoinkc-output/ my-bootc-image --push registry.example.com/my-bootc-image:v1.0
    ./yoinkc-build ./yoinkc-output/ my-bootc-image --no-cache

No pip dependencies — stdlib only (Python 3.9+).
"""

from __future__ import annotations

import argparse
import os
import shutil
import signal
import subprocess
import sys
import tarfile
import tempfile
from pathlib import Path

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

_SCRIPT_NAME = "yoinkc-build"


# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------

def _log(msg: str) -> None:
    print(f"{_SCRIPT_NAME}: {msg}", flush=True)


def _err(msg: str) -> None:
    print(f"{_SCRIPT_NAME}: error: {msg}", file=sys.stderr, flush=True)


def _warn(msg: str) -> None:
    print(f"{_SCRIPT_NAME}: warning: {msg}", file=sys.stderr, flush=True)


# ---------------------------------------------------------------------------
# Tarball extraction (same pattern as yoinkc-refine)
# ---------------------------------------------------------------------------

def _extract_tarball(tarball_path: Path, dest: Path) -> None:
    """Extract *tarball_path* into *dest*."""
    with tarfile.open(tarball_path, "r:gz") as tf:
        members = []
        for m in tf.getmembers():
            safe_name = "/".join(
                part for part in m.name.replace("\\", "/").split("/")
                if part and part != ".."
            )
            if not safe_name:
                continue
            m.name = safe_name
            members.append(m)
        # filter='data' strips dangerous metadata (Python 3.12+); omit for older.
        try:
            tf.extractall(dest, members=members, filter='data')  # noqa: S202
        except TypeError:
            tf.extractall(dest, members=members)  # noqa: S202


def _flatten_single_subdir(d: Path) -> None:
    """If *d* contains a single subdirectory, move its contents up."""
    if not (d / "Containerfile").exists():
        subdirs = [p for p in d.iterdir() if p.is_dir()]
        if len(subdirs) == 1:
            inner = subdirs[0]
            if (inner / "Containerfile").exists():
                for item in inner.iterdir():
                    shutil.move(str(item), str(d / item.name))
                inner.rmdir()


# ---------------------------------------------------------------------------
# Container runtime
# ---------------------------------------------------------------------------

def _find_runtime() -> str:
    """Return 'podman' or 'docker', or exit with install instructions."""
    for rt in ("podman", "docker"):
        if shutil.which(rt):
            return rt
    _err("neither podman nor docker found.\n"
         "  Install podman: https://podman.io/docs/installation\n"
         "  Install docker: https://docs.docker.com/engine/install/")
    sys.exit(1)


# ---------------------------------------------------------------------------
# RHEL target detection
# ---------------------------------------------------------------------------

def _detect_rhel_target(containerfile: Path) -> bool:
    """Return True if the Containerfile's FROM references registry.redhat.io."""
    try:
        for line in containerfile.read_text().splitlines():
            stripped = line.strip()
            if stripped.upper().startswith("FROM "):
                if "registry.redhat.io" in stripped:
                    return True
                # Keep scanning — a later FROM may also need entitlement
    except OSError:
        pass
    return False


# ---------------------------------------------------------------------------
# Entitlement handling
# ---------------------------------------------------------------------------

def _check_cert_expiry(cert_path: Path) -> str | None:
    """Check cert validity via openssl. Returns expiry date string, or None if expired/missing."""
    if not shutil.which("openssl"):
        return "(openssl not available — cannot verify expiry)"

    # Check if expired
    r = subprocess.run(
        ["openssl", "x509", "-checkend", "0", "-noout", "-in", str(cert_path)],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return None  # expired

    # Check if expiring within 24 hours
    r24 = subprocess.run(
        ["openssl", "x509", "-checkend", "86400", "-noout", "-in", str(cert_path)],
        capture_output=True, text=True,
    )

    # Get the expiry date for display
    r_date = subprocess.run(
        ["openssl", "x509", "-enddate", "-noout", "-in", str(cert_path)],
        capture_output=True, text=True,
    )
    date_str = r_date.stdout.strip().replace("notAfter=", "") if r_date.returncode == 0 else "unknown"

    if r24.returncode != 0:
        _warn(f"entitlement certificate expiring within 24 hours ({date_str})")

    return date_str


def _validate_entitlement_dir(ent_dir: Path, label: str) -> tuple[Path | None, Path | None]:
    """Validate certs in *ent_dir* and return (entitlement_dir, rhsm_dir_or_None)."""
    pems = sorted(ent_dir.glob("*.pem"))
    if not pems:
        return None, None

    # Check the first non-key cert for expiry
    for pem in pems:
        if pem.name.endswith("-key.pem"):
            continue
        expiry = _check_cert_expiry(pem)
        if expiry is None:
            _warn(f"entitlement certificate expired ({label}: {pem.name})")
            _warn("build may fail. Copy fresh certs from the RHEL host:\n"
                  "  scp root@rhel-host:/etc/pki/entitlement/*.pem ./entitlement/")
        else:
            _log(f"using {label} entitlement certs (valid until {expiry})")
        break

    # Look for companion rhsm dir alongside entitlement dir
    rhsm_dir = ent_dir.parent / "rhsm"
    if not rhsm_dir.is_dir():
        rhsm_dir = None

    return ent_dir.resolve(), rhsm_dir.resolve() if rhsm_dir else None


def _find_entitlement(output_dir: Path) -> tuple[Path | None, Path | None]:
    """Find RHEL entitlement certs, checking sources in priority order.

    Returns (entitlement_dir, rhsm_dir) with absolute paths, or (None, None)
    when the host handles entitlement automatically or certs aren't found.
    """
    # 1. RHEL host — podman handles entitlement automatically
    host_ent = Path("/etc/pki/entitlement")
    if host_ent.is_dir() and list(host_ent.glob("*.pem")):
        _log("RHEL host detected — entitlement handled automatically")
        return None, None

    # 2. Bundled in output directory (from run-yoinkc.sh)
    bundled = output_dir / "entitlement"
    if bundled.is_dir():
        result = _validate_entitlement_dir(bundled, "bundled")
        if result[0]:
            return result

    # 3. In current working directory
    cwd_ent = Path.cwd() / "entitlement"
    if cwd_ent.is_dir():
        result = _validate_entitlement_dir(cwd_ent, "cwd")
        if result[0]:
            return result

    # 4. YOINKC_ENTITLEMENT env var
    env_path = os.environ.get("YOINKC_ENTITLEMENT")
    if env_path:
        env_dir = Path(env_path)
        if env_dir.is_dir():
            result = _validate_entitlement_dir(env_dir, "YOINKC_ENTITLEMENT")
            if result[0]:
                return result
        else:
            _warn(f"YOINKC_ENTITLEMENT={env_path} is not a directory")

    # 5. Nothing found
    _warn("RHEL entitlement certificates not found.\n"
          "  If the build fails, options:\n"
          "    1. Build on the RHEL host directly (entitlement is automatic)\n"
          "    2. Copy certs from the RHEL host:\n"
          "         scp root@rhel-host:/etc/pki/entitlement/*.pem ./entitlement/\n"
          "         scp -r root@rhel-host:/etc/rhsm ./rhsm/\n"
          "    3. Re-run run-yoinkc.sh — it bundles certs automatically.")
    return None, None


# ---------------------------------------------------------------------------
# Build
# ---------------------------------------------------------------------------

def _build(
    runtime: str,
    output_dir: Path,
    tag: str,
    entitlement_dir: Path | None,
    rhsm_dir: Path | None,
    no_cache: bool,
) -> bool:
    """Run the container build. Returns True on success."""
    containerfile = output_dir / "Containerfile"
    cmd: list[str] = [runtime, "build", "-f", str(containerfile), "-t", tag]

    if entitlement_dir:
        cmd += ["-v", f"{entitlement_dir}:/etc/pki/entitlement:ro,Z"]
    if rhsm_dir:
        cmd += ["-v", f"{rhsm_dir}:/etc/rhsm:ro,Z"]
    if no_cache:
        cmd.append("--no-cache")

    cmd.append(str(output_dir))

    _log(f"building {tag} …")
    proc = subprocess.Popen(
        cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True,
    )

    captured: list[str] = []
    if proc.stdout is None:
        _err("build process produced no output")
        return False
    for line in proc.stdout:
        print(line, end="", flush=True)
        captured.append(line)
    proc.wait()

    if proc.returncode != 0:
        _err(f"build failed (exit {proc.returncode})")
        if len(captured) > 30:
            print("\n--- last 30 lines of build output ---", file=sys.stderr)
            for line in captured[-30:]:
                print(line, end="", file=sys.stderr)
        return False

    # Report image ID and size
    r = subprocess.run(
        [runtime, "images", "--format", "{{.ID}} {{.Size}}", tag],
        capture_output=True, text=True,
    )
    if r.returncode == 0 and r.stdout.strip():
        parts = r.stdout.strip().split(None, 1)
        img_id = parts[0][:12] if parts else "unknown"
        img_size = parts[1] if len(parts) > 1 else "unknown"
        _log(f"built {tag}  (id: {img_id}, size: {img_size})")
    else:
        _log(f"built {tag}")

    return True


# ---------------------------------------------------------------------------
# Push
# ---------------------------------------------------------------------------

def _push(runtime: str, tag: str, dest: str) -> bool:
    """Tag and push the image to *dest*. Returns True on success."""
    # Parse registry hostname from destination
    registry = dest.split("/")[0]

    # Check auth
    r = subprocess.run(
        [runtime, "login", "--get-login", registry],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        if sys.stdin.isatty():
            _log(f"not logged in to {registry} — logging in now:")
            lr = subprocess.run([runtime, "login", registry])
            if lr.returncode != 0:
                _err(f"login to {registry} failed")
                return False
        else:
            _err(f"not logged in to {registry}.\n"
                 f"  Run: {runtime} login {registry}")
            return False

    # Tag if dest differs from build tag
    if dest != tag:
        _log(f"tagging {tag} → {dest}")
        r = subprocess.run([runtime, "tag", tag, dest], capture_output=True, text=True)
        if r.returncode != 0:
            _err(f"tagging failed: {r.stderr.strip()}")
            return False

    # Push
    _log(f"pushing {dest} …")
    proc = subprocess.Popen(
        [runtime, "push", dest],
        stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True,
    )
    if proc.stdout is None:
        _err("push process produced no output")
        return False
    for line in proc.stdout:
        print(line, end="", flush=True)
    proc.wait()

    if proc.returncode != 0:
        _err(f"push failed (exit {proc.returncode})")
        return False

    _log(f"pushed {dest}")
    return True


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(
        prog=_SCRIPT_NAME,
        description="Build a bootc image from yoinkc output with automatic "
                    "RHEL entitlement handling.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
examples:
  %(prog)s ./yoinkc-output/ my-bootc-image:latest
  %(prog)s output.tar.gz my-bootc-image:v1.0
  %(prog)s ./yoinkc-output/ my-bootc-image --push registry.example.com/my-bootc-image:v1.0
  %(prog)s ./yoinkc-output/ my-bootc-image --no-cache
""",
    )
    parser.add_argument("source", help="output directory or .tar.gz tarball")
    parser.add_argument("name", nargs="?", default=None,
                        help="image name[:tag] (default tag: latest)")
    parser.add_argument("--push", metavar="DEST",
                        help="push image to registry after build")
    parser.add_argument("--no-cache", action="store_true",
                        help="pass --no-cache to the build command")
    args = parser.parse_args()

    # -- Resolve source --
    source = Path(args.source)
    tmpdir: str | None = None

    def _cleanup(*_: object) -> None:
        if tmpdir:
            shutil.rmtree(tmpdir, ignore_errors=True)
        sys.exit(0)

    signal.signal(signal.SIGINT, _cleanup)
    signal.signal(signal.SIGTERM, _cleanup)

    if not source.exists():
        _err(f"not found: {source}")
        sys.exit(1)

    if source.is_file() and (source.name.endswith(".tar.gz") or source.name.endswith(".tgz")):
        if not tarfile.is_tarfile(source):
            _err(f"not a valid tar.gz: {source}")
            sys.exit(1)
        tmpdir = tempfile.mkdtemp(prefix="yoinkc-build-")
        output_dir = Path(tmpdir)
        _log(f"extracting {source.name} …")
        try:
            _extract_tarball(source, output_dir)
        except Exception as exc:
            _err(f"extraction failed: {exc}")
            shutil.rmtree(tmpdir, ignore_errors=True)
            sys.exit(1)
        _flatten_single_subdir(output_dir)
    elif source.is_dir():
        output_dir = source.resolve()
    else:
        _err(f"source must be a directory or .tar.gz: {source}")
        sys.exit(1)

    containerfile = output_dir / "Containerfile"
    if not containerfile.exists():
        _err(f"Containerfile not found in {source}")
        if tmpdir:
            shutil.rmtree(tmpdir, ignore_errors=True)
        sys.exit(1)

    # -- Resolve image name --
    tag = args.name
    if tag is None:
        if sys.stdin.isatty():
            try:
                tag = input(f"{_SCRIPT_NAME}: image name (e.g. my-bootc-image:latest): ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                _cleanup()
            if not tag:
                _err("image name is required")
                sys.exit(1)
        else:
            _err("image name is required (not a TTY — cannot prompt)\n"
                 f"  usage: {_SCRIPT_NAME} <source> <name[:tag]>")
            sys.exit(1)

    if ":" not in tag:
        tag = f"{tag}:latest"

    # -- Find runtime --
    runtime = _find_runtime()
    _log(f"runtime: {runtime}")

    # -- Entitlement --
    entitlement_dir: Path | None = None
    rhsm_dir: Path | None = None
    if _detect_rhel_target(containerfile):
        _log("RHEL base image detected — checking entitlement")
        entitlement_dir, rhsm_dir = _find_entitlement(output_dir)

    # -- Build --
    ok = _build(runtime, output_dir, tag, entitlement_dir, rhsm_dir, args.no_cache)

    if tmpdir:
        shutil.rmtree(tmpdir, ignore_errors=True)

    if not ok:
        sys.exit(1)

    # -- Push --
    if args.push:
        if not _push(runtime, tag, args.push):
            sys.exit(1)


if __name__ == "__main__":
    main()
