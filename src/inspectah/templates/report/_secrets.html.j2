{% from "report/_macros.html.j2" import section, card_toggle with context -%}
{# ── Secrets ──────────────────────────────────────────────────────────────── #}
{% call section("secrets", "Secrets", triageable=true) %}
  {%- if secrets_data %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-secrets", "Secrets") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-secrets"><div class="pf-v6-c-card__body">
  <p><strong>{{ secrets_data|length }} value(s) redacted</strong> across <strong>{{ secrets_file_count }} file(s)</strong>.</p>
  <table class="pf-v6-c-table">
    <thead><tr><th scope="col">File Path</th><th scope="col">Pattern</th><th scope="col">Line</th><th scope="col">Remediation</th></tr></thead>
    <tbody>
    {%- for r in secrets_data %}
    <tr>
      <td><code>{{ r.path or '?' }}</code></td>
      <td>{{ r.pattern or '?' }}</td>
      <td>{{ r.line or '?' }}</td>
      <td class="text-sm">{{ r.remediation or '' }}</td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  </div></div></div>
  {%- else %}
  <p class="text-status-success">No secrets detected.</p>
  {%- endif %}
{% endcall %}

