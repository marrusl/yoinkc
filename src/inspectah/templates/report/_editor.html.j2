{% from "report/_macros.html.j2" import section with context -%}
{# ── Editor tab — refine mode only ───────────────────────────────────────── #}
{% call section("output_files", "Editor") %}
<p>Browse and edit config files, quadlet units, and systemd drop-ins. Click a file to view, then Edit to modify.</p>

<style>
.editor-section-header {
  padding: 8px 10px 4px;
  font-size: 11px; font-weight: 600;
  color: var(--pf-t--global--text--color--subtle);
  text-transform: uppercase; letter-spacing: 0.5px;
}
.editor-variant-group { margin-bottom: 2px; }
.editor-variant-header {
  display: flex; align-items: center; gap: 6px;
  padding: 7px 10px; background: rgba(255,255,255,0.08);
  border-radius: 4px; cursor: pointer; font-size: 12px;
}
.editor-variant-header .chevron { color: #888; font-size: 10px; width: 12px; flex-shrink: 0; }
.editor-variant-header .path-dir { color: #888; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; flex-shrink: 1; }
.editor-variant-header .path-file { color: #ccc; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; flex-shrink: 0.5; }
.editor-variant-header .pf-v6-c-badge { flex-shrink: 0; }
.editor-variant-header .variant-tie-badge { flex-shrink: 0; white-space: nowrap; }
.editor-variant-row {
  display: flex; align-items: center; gap: 6px;
  padding: 6px 10px; margin: 2px 0 2px 20px;
  border-radius: 4px; cursor: pointer; font-size: 12px;
}
.editor-variant-row.selected {
  background: rgba(0, 102, 204, 0.15);
  border-left: 3px solid #0066cc;
}
.editor-variant-row:hover { background: rgba(255,255,255,0.05); }
.editor-variant-row.selected:hover { background: rgba(0, 102, 204, 0.2); }
.editor-variant-row.pf-m-current { outline: 1px solid rgba(0,102,204,0.4); }
.prevalence-bar {
  width: 36px; height: 5px; flex-shrink: 0;
  background: #333; border-radius: 3px; overflow: hidden;
}
.prevalence-bar .fill { height: 100%; border-radius: 3px; }
.prevalence-bar .fill.majority { background: #0066cc; }
.prevalence-bar .fill.minority { background: #cc8800; }
.host-chip {
  background: rgba(100,160,220,0.2); color: #88ccff;
  padding: 1px 5px; border-radius: 3px; font-size: 10px;
  max-width: 80px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  display: inline-block;
}
.editor-variant-row:not(.selected) .host-chip {
  background: rgba(200,170,100,0.15); color: #ccaa66;
}
.host-count { font-size: 11px; color: #ccaa66; }
.selected-badge { margin-left: auto; font-size: 10px; }
.editor-variant-row .switch-btn {
  visibility: hidden; transition: visibility 0.15s;
  white-space: nowrap; flex-shrink: 0;
}
.editor-variant-row:hover .switch-btn,
.editor-variant-row:focus-within .switch-btn {
  visibility: visible;
}
.editor-compare-btn { margin-left: auto; white-space: nowrap; flex-shrink: 0; }
.editor-single-file {
  padding: 7px 10px 7px 24px;
  cursor: pointer; font-size: 12px; color: #ccc;
  border-radius: 4px;
}
.editor-single-file:hover { background: rgba(255,255,255,0.05); }
.editor-single-file.pf-m-current { background: rgba(0,102,204,0.15); }
/* Light-mode contrast fixes for editor tree */
html:not(.pf-v6-theme-dark) .editor-variant-header { background: var(--pf-t--global--background--color--secondary--default, #f0f0f0); }
html:not(.pf-v6-theme-dark) .editor-variant-header .chevron { color: var(--pf-t--global--text--color--subtle, #6a6e73); }
html:not(.pf-v6-theme-dark) .editor-variant-header .path-dir { color: var(--pf-t--global--text--color--subtle, #6a6e73); }
html:not(.pf-v6-theme-dark) .editor-variant-header .path-file { color: var(--pf-t--global--text--color--regular, #151515); }
html:not(.pf-v6-theme-dark) .editor-variant-row:hover { background: rgba(0,0,0,0.04); }
html:not(.pf-v6-theme-dark) .editor-variant-row.selected:hover { background: rgba(0, 102, 204, 0.12); }
html:not(.pf-v6-theme-dark) .host-chip { background: rgba(0, 102, 204, 0.12); color: var(--pf-t--global--text--color--brand--default, #0066cc); }
html:not(.pf-v6-theme-dark) .editor-variant-row:not(.selected) .host-chip { background: rgba(204, 136, 0, 0.12); color: #8a6900; }
html:not(.pf-v6-theme-dark) .host-count { color: #8a6900; }
html:not(.pf-v6-theme-dark) .editor-single-file { color: var(--pf-t--global--text--color--regular, #151515); }
html:not(.pf-v6-theme-dark) .prevalence-bar { background: #e0e0e0; }
/* Tied variant highlighting in editor tree */
.editor-variant-group.variant-tied > .editor-variant-header {
  border-left: 3px solid var(--pf-t--global--color--status--warning--default, #f0ab00);
  background: rgba(240, 171, 0, 0.10);
}
html:not(.pf-v6-theme-dark) .editor-variant-group.variant-tied > .editor-variant-header {
  background: rgba(240, 171, 0, 0.08);
}
</style>

{# --- Re-render error banner (shown by JS on failure, hidden by default) --- #}
<div id="editor-error-banner" class="pf-v6-c-alert pf-m-danger pf-m-inline editor-error-hidden" aria-live="polite">
  <div class="pf-v6-c-alert__icon"><svg aria-hidden="true" fill="currentColor" height="1em" width="1em" viewBox="0 0 512 512"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm0 448c-110.5 0-200-89.5-200-200S145.5 56 256 56s200 89.5 200 200-89.5 200-200 200zm-33.8-217.9V152c0-13.3 10.7-24 24-24h19.6c13.3 0 24 10.7 24 24v86.1c0 13.3-10.7 24-24 24h-19.6c-13.3 0-24-10.7-24-24zM232 336c0-13.3 10.7-24 24-24s24 10.7 24 24-10.7 24-24 24-24-10.7-24-24z"/></svg></div>
  <p class="pf-v6-c-alert__title"><strong>Re-render failed</strong></p>
  <div class="pf-v6-c-alert__description" id="editor-error-message"></div>
  <div class="pf-v6-c-alert__action">
    <button class="pf-v6-c-button pf-m-plain" aria-label="Dismiss" onclick="dismissEditorError()">&times;</button>
  </div>
</div>

<style>
#editor-tab {
  height: calc(100vh - 200px);
  border: 1px solid var(--pf-t--global--border--color--default);
}
#editor-tab .pf-v6-c-drawer__panel {
  border-right: 1px solid var(--pf-t--global--border--color--default);
}
#editor-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}
</style>

<div id="editor-tab"
     class="pf-v6-c-drawer pf-m-expanded pf-m-panel-left pf-m-inline"
     style="--pf-v6-c-drawer__panel--md--FlexBasis: 480px; --pf-v6-c-drawer__panel--md--FlexBasis--min: 480px; --pf-v6-c-drawer__panel--md--FlexBasis--max: 480px;">
  <div class="pf-v6-c-drawer__main">

  {# --- Tree pane (drawer panel) --- #}
  <div class="pf-v6-c-drawer__panel">
    <div class="pf-v6-c-drawer__panel-main">
      <div id="editor-tree" class="editor-tree-layout">
        <div class="editor-tree-header">
          <span class="pf-v6-c-title pf-m-lg">Files</span>
          <button class="pf-v6-c-button pf-m-primary pf-m-small" id="btn-new-file" type="button">+ New File</button>
        </div>
        <div id="editor-tree-list" class="editor-tree-body"></div>
      </div>
    </div>
  </div>

  {# --- Content pane (drawer content) --- #}
  <div class="pf-v6-c-drawer__content">
    <div id="editor-content">
      <div id="editor-toolbar" class="editor-toolbar">
        <div id="editor-file-path" class="editor-file-path"></div>
        <div id="editor-actions"></div>
      </div>
      <div id="editor-view" class="editor-view-pane">
        <pre id="editor-readonly-content" class="editor-readonly-pre"></pre>
        <div id="editor-cm-container" style="display:none; height:100%;"></div>
      </div>
    </div>
  </div>

  </div>{# close pf-v6-c-drawer__main #}
</div>{# close pf-v6-c-drawer #}

{# --- Unsaved changes modal --- #}
<div class="pf-v6-c-backdrop" id="unsaved-changes-modal" style="display:none;">
  <div class="pf-v6-l-bullseye">
    <div class="pf-v6-c-modal-box pf-m-sm" role="dialog" aria-modal="true" aria-label="Unsaved changes">
      <div class="pf-v6-c-modal-box__header">
        <h2 class="pf-v6-c-modal-box__title">Unsaved changes</h2>
      </div>
      <div class="pf-v6-c-modal-box__body">
        <p id="unsaved-changes-message"></p>
      </div>
      <div class="pf-v6-c-modal-box__footer">
        <button class="pf-v6-c-button pf-m-link" id="unsaved-btn-cancel" type="button">Cancel</button>
        <button class="pf-v6-c-button pf-m-secondary" id="unsaved-btn-discard" type="button">Discard</button>
        <button class="pf-v6-c-button pf-m-primary" id="unsaved-btn-save" type="button">Save</button>
      </div>
    </div>
  </div>
</div>

{# --- Delete file confirmation modal --- #}
<div class="pf-v6-c-backdrop" id="delete-file-modal" style="display:none;">
  <div class="pf-v6-l-bullseye">
    <div class="pf-v6-c-modal-box pf-m-sm" role="dialog" aria-modal="true" aria-label="Delete file">
      <div class="pf-v6-c-modal-box__header">
        <h2 class="pf-v6-c-modal-box__title">Delete file</h2>
      </div>
      <div class="pf-v6-c-modal-box__body">
        <p id="delete-file-message"></p>
      </div>
      <div class="pf-v6-c-modal-box__footer">
        <button class="pf-v6-c-button pf-m-secondary" id="delete-btn-cancel" type="button">Cancel</button>
        <button class="pf-v6-c-button pf-m-danger" id="delete-btn-confirm" type="button">Delete</button>
      </div>
    </div>
  </div>
</div>

{% endcall %}
