{% from "report/_macros.html.j2" import section, fleet_cell, card_toggle, card_toolbar with context -%}
{# ── Containers ──────────────────────────────────────────────────────────── #}
{% call section("containers", "Containers", triageable=true) %}
  {%- set ct = snapshot.containers %}
  {%- if ct and (ct.quadlet_units or ct.compose_files or ct.running_containers) %}

  {%- if ct.quadlet_units %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-ct-quadlet-units", "Quadlet Units") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-ct-quadlet-units">
    {%- set quadlet_count = quadlet_variant_groups|length if (fleet_meta and quadlet_variant_groups) else ct.quadlet_units|length %}
    {{ card_toolbar("card-ct-quadlet-items", quadlet_count, "Quadlet units") }}
    <div class="pf-v6-c-card__body" id="card-ct-quadlet-items">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check pf-m-fit-content" scope="col"></th>{% if refine_mode %}<th class="pf-m-fit-content" scope="col"></th>{% endif %}<th scope="col">Unit</th><th scope="col">Image</th><th scope="col">Path</th><th scope="col">Content</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
    {% if fleet_meta and quadlet_variant_groups %}
      {%- for path, variants in quadlet_variant_groups.items() %}
      {%- if variants | length > 1 %}
        {%- set primary = variants[0] %}
        {%- set group_has_selected = variants | selectattr('item.include', 'equalto', true) | list | length > 0 %}
        {%- set is_tied = variants | selectattr('item.tie', 'equalto', true) | list | length > 0 %}
        {%- set tie_winner_variant = variants | selectattr('item.tie_winner', 'equalto', true) | first | default(none) %}
        <tr class="fleet-variant-group{% if not primary.item.include %} excluded{% endif %}{% if is_tied and not tie_winner_variant %} variant-tied{% endif %}"
            data-search-text="{{ path }}"
            data-snap-section="containers" data-snap-list="quadlet_units"
            data-snap-index="{{ primary.snap_index }}"
            {% if is_tied %}data-tie="true"{% endif %}
            {% if tie_winner_variant %}data-tie-winner="true"{% endif %}>
          <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if primary.item.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
          {% if refine_mode %}<td></td>{% endif %}
          <td colspan="3">
            <code>{{ path }}</code>
            <span class="pf-v6-c-label pf-m-compact pf-m-outline fleet-variant-toggle" tabindex="0" role="button" aria-label="Toggle variants"
                  aria-expanded="false">
              <span class="pf-v6-c-label__content">{{ variants | length }} variants</span>
            </span>
            {% if is_tied and not tie_winner_variant %}
            <span class="variant-tie-badge"><span class="tie-icon">&#x26A0;</span> tied &mdash; compare &amp; choose</span>
            {% elif is_tied and tie_winner_variant %}
            <span class="variant-auto-badge">tie winner (hash)</span>
            {% elif group_has_selected %}
            {# Show auto-selected badge when there's a winner (not tied) and multiple variants #}
            <span class="variant-auto-badge">auto-selected</span>
            {% endif %}
          </td>
          <td></td>
          {{ fleet_cell(primary.item) }}
        </tr>
        <tr class="fleet-variant-children">
          <td colspan="{{ 6 + (1 if refine_mode else 0) }}">
            <table class="pf-v6-c-table pf-m-compact fleet-variant-table">
              {%- for v in variants %}
              <tr{% if not v.item.include %} class="excluded"{% endif %}
                  data-snap-section="containers" data-snap-list="quadlet_units"
                  data-snap-index="{{ v.snap_index }}"
                  data-variant-group="{{ path }}"
                  {% if v.item.tie %}data-tie="true"{% endif %}
                  {% if v.item.tie_winner %}data-tie-winner="true"{% endif %}>
                <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if v.item.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
                {% if refine_mode %}<td><button class="pf-v6-c-button pf-m-plain editor-icon" title="{% if v.item.include %}Edit in editor{% else %}View in editor (read-only){% endif %}" data-section="containers" data-list="quadlet_units" data-index="{{ v.snap_index }}" data-path="{{ path }}" onclick="navigateToEditor(this)">✏️</button></td>{% endif %}
                <td>{{ v.item.name }} <span class="variant-index">(variant {{ loop.index }})</span>{% if v.item.tie_winner %} <span class="badge" style="background-color: #e67e22; color: #fff;">(auto-selected: tied)</span>{% endif %}</td>
                {{ fleet_cell(v.item) }}
                <td class="variant-action-cell">
                  {% if v.item.include %}
                    <span class="variant-selected-label">selected</span>
                  {% elif group_has_selected %}
                    <button class="pf-v6-c-button pf-m-link pf-m-small variant-compare-btn">Compare</button>
                  {% else %}
                    <button class="pf-v6-c-button pf-m-link pf-m-small variant-display-btn">Display</button>
                  {% endif %}
                </td>
              </tr>
              {%- endfor %}
            </table>
          </td>
        </tr>
      {%- else %}
        {%- set u = variants[0].item %}
        <tr{% if not u.include %} class="excluded"{% endif %} data-search-text="{{ u.path }}" data-snap-section="containers" data-snap-list="quadlet_units" data-snap-index="{{ variants[0].snap_index }}">
          <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if u.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
          {% if refine_mode %}<td><button class="pf-v6-c-button pf-m-plain editor-icon" title="Edit in editor" data-section="containers" data-list="quadlet_units" data-index="{{ variants[0].snap_index }}" data-path="{{ u.path }}" onclick="navigateToEditor(this)">✏️</button></td>{% endif %}
          <td>{{ u.name }}</td>
          <td>{% if u.image %}<code>{{ u.image }}</code>{% else %}<em>none</em>{% endif %}</td>
          <td><code>{{ u.path }}</code></td>
          <td>{%- if u.content and u.content.strip() %}<details><summary>show</summary><pre class="content-preview">{{ u.content }}</pre></details>{%- endif %}</td>
          {{ fleet_cell(u) }}
        </tr>
      {%- endif %}
      {%- endfor %}
    {% else %}
      {%- for u in ct.quadlet_units %}
      <tr{% if not u.include %} class="excluded"{% endif %} data-search-text="{{ u.path }}" data-snap-section="containers" data-snap-list="quadlet_units" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if u.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
        {% if refine_mode %}<td><button class="pf-v6-c-button pf-m-plain editor-icon" title="Edit in editor" data-section="containers" data-list="quadlet_units" data-index="{{ loop.index0 }}" data-path="{{ u.path }}" onclick="navigateToEditor(this)">✏️</button></td>{% endif %}
        <td>{{ u.name }}</td>
        <td>{% if u.image %}<code>{{ u.image }}</code>{% else %}<em>none</em>{% endif %}</td>
        <td><code>{{ u.path }}</code></td>
        <td>
          {%- if u.content and u.content.strip() %}
          <details><summary>show</summary>
            <pre class="content-preview">{{ u.content }}</pre>
          </details>
          {%- endif %}
        </td>
        {{ fleet_cell(u) }}
      </tr>
      {%- endfor %}
    {% endif %}
    </tbody></table>
    </div></div>
  </div>
  {%- endif %}

  {%- if ct.compose_files %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-ct-compose-files", "Compose Files") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-ct-compose-files">
    {{ card_toolbar("card-ct-compose-items", ct.compose_files|length, "Compose files") }}
    <div class="pf-v6-c-card__body" id="card-ct-compose-items">
    {%- for c in ct.compose_files %}
    <div{% if not c.include %} class="excluded"{% endif %} data-search-text="{{ c.path }}" data-snap-section="containers" data-snap-list="compose_files" data-snap-index="{{ loop.index0 }}">
    <label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if c.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label>
    <span class="text-bold"><code>{{ c.path }}</code></span>
    {% if fleet_meta and c.fleet %}
    <div class="fleet-prevalence fleet-prevalence-inline">
      <div class="fleet-bar"
           data-count="{{ c.fleet.count }}"
           data-total="{{ c.fleet.total }}"
           data-hosts="{{ c.fleet.hosts | join(', ') }}"
           data-host-titles="{% for host in c.fleet.hosts %}{{ host_title_map.get(host, host) }}{% if not loop.last %}, {% endif %}{% endfor %}"
           title="{% for host in c.fleet.hosts %}{{ host_title_map.get(host, host) }}{% if not loop.last %}, {% endif %}{% endfor %}">
        <div class="fleet-bar-track">
          <div class="fleet-bar-fill {{ c.fleet | fleet_color }}"
               style="width: {{ (c.fleet.count * 100 // c.fleet.total) if c.fleet.total > 0 else 100 }}%"></div>
        </div>
        <span class="fleet-bar-label">{{ c.fleet.count }}/{{ c.fleet.total }}</span>
      </div>
    </div>
    {% endif %}
    {%- if c.images %}
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Service</th><th scope="col">Image</th></tr></thead><tbody>
      {%- for img in c.images %}
      <tr><td>{{ img.service }}</td><td><code>{{ img.image }}</code></td></tr>
      {%- endfor %}
    </tbody></table>
    {%- else %}
    <p>No image references found.</p>
    {%- endif %}
    </div>
    {%- endfor %}
    </div></div>
  </div>
  {%- endif %}

  {%- if ct.running_containers %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Running Containers</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Name</th><th scope="col">Image</th><th scope="col">Status</th><th scope="col">Mounts</th><th scope="col">Networks</th></tr></thead><tbody>
      {%- for item in containers_data.running %}
      <tr>
        <td><strong>{{ item.name }}</strong></td>
        <td><code>{{ item.image }}</code></td>
        <td>{{ item.status }}</td>
        <td class="text-sm">{{ item.mount_summary|safe }}</td>
        <td class="text-sm">{{ item.net_summary or '' }}</td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No container workloads.</p>
  {%- endif %}
{% endcall %}

