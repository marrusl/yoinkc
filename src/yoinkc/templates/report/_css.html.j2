<style>
/* ═══════════════════════════════════════════════════════════════════════
   yoinkc report – custom overrides on top of PatternFly 6
   ═══════════════════════════════════════════════════════════════════════ */

/* Theme-aware custom properties */
:root {
  --yoinkc-diff-add-bg: rgba(77, 171, 247, 0.12);
  --yoinkc-diff-remove-bg: rgba(201, 25, 11, 0.12);
  --yoinkc-diff-add-border: #4dabf7;
  --yoinkc-diff-remove-border: #c9190b;
  --yoinkc-content-bottom-padding: 5rem;
  --yoinkc-content-max-height: calc(100vh - 200px);
}

html:not(.pf-v6-theme-dark) {
  --yoinkc-diff-add-bg: rgba(43, 154, 243, 0.08);
  --yoinkc-diff-remove-bg: rgba(201, 25, 11, 0.08);
}

/* Reduced-motion: must come first so it gates ALL animations/transitions below */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}

/* Global table spacing - relaxed density */
.pf-v6-c-table {
  --pf-v6-c-table--cell--PaddingBlockStart: var(--pf-t--global--spacer--sm);
  --pf-v6-c-table--cell--PaddingBlockEnd: var(--pf-t--global--spacer--sm);
  --pf-v6-c-table--cell--PaddingInlineStart: var(--pf-t--global--spacer--md);
  --pf-v6-c-table--cell--PaddingInlineEnd: var(--pf-t--global--spacer--md);
}

/* OS icon theme-aware colours */
.os-icon { vertical-align: middle; margin-right: 6px; }
.os-icon-rhel   { color: #ffffff; }
.os-icon-fedora { color: #79B8FF; }
.os-icon-centos { color: #c678dd; }
.os-icon-rocky  { color: #73BA25; }
.os-icon-alma   { color: #ff4649; }
html:not(.pf-v6-theme-dark) .os-icon-rhel   { color: #EE0000; }
html:not(.pf-v6-theme-dark) .os-icon-fedora { color: #294172; }
html:not(.pf-v6-theme-dark) .os-icon-centos { color: #932279; }
html:not(.pf-v6-theme-dark) .os-icon-rocky  { color: #10B981; }
html:not(.pf-v6-theme-dark) .os-icon-alma   { color: #ff4649; }

/* Page padding – toolbar lives at the bottom (5rem covers fleet slider + preview) */
body { padding-bottom: var(--yoinkc-content-bottom-padding); }
/* Prevent PF6 flex-grow from creating a gap between content and fixed toolbar */
.pf-v6-c-page__main { flex-grow: 0; }

/* Inline alert banners – wrap content in .pf-v6-c-alert__title to land in the
   grid's "title" area; nowrap + overflow-x keeps stats on a single line. */
.os-status-banner { margin-bottom: 1rem; }
.os-status-banner .pf-v6-c-alert__title,
#pkg-selection-banner .pf-v6-c-alert__title { white-space: nowrap; overflow-x: auto; }

/* Section show/hide for nav switching */
.section { display: none; margin-top: var(--pf-t--global--spacer--md, 1rem); }
.section.visible { display: block; opacity: 0; transition: opacity 150ms ease-in-out; }
.section.visible.pf-m-current { opacity: 1; }

/* Sidebar nav */
.pf-v6-c-page__sidebar .pf-v6-c-nav__section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }

/* Sidebar – always visible. PF6 defaults sidebar to opacity:0 / translateX:-100%
   for responsive mobile-first behaviour, but this report has no hamburger toggle,
   so force the sidebar visible at all viewport sizes and motion preferences.
   transform:none is required because any CSS transform creates a new containing
   block that prevents position:sticky from working. */
.pf-v6-c-page__sidebar {
  opacity: 1 !important;
  transform: none !important;
}
@media (min-width: 75rem) {
  .pf-v6-c-page__sidebar {
    position: sticky;
    top: 0;
    max-height: calc(100vh - 3.5rem);
    align-self: start;
  }
}


/* Warning dismiss */
.warning-row.dismissed { display: none; }
.warning-row.dismissing {
  opacity: 0;
  max-height: 0;
  margin: 0;
  padding: 0;
  overflow: hidden;
  transition: opacity 150ms ease-out, max-height 150ms ease-out, margin 150ms ease-out, padding 150ms ease-out;
}
#warnings-list { max-height: 400px; overflow-y: auto; }

/* Summary two-column grid */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--pf-t--global--spacer--lg);
}
@media (max-width: 768px) {
  .summary-grid { grid-template-columns: 1fr; }
}

/* Containerfile code block */
.containerfile-pre { border-radius: 6px; padding: 1rem; overflow: auto; max-height: 70vh; font-size: 0.85rem; line-height: 1.4; white-space: pre; margin: 0; }
.section-heading-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
.section-heading-row h2 { margin: 0; }

/* Repo content preview */
.repo-content-pre { border-radius: 4px; padding: 0.75rem; font-size: 0.8rem; max-height: 300px; overflow: auto; margin: 0.25rem 0 0; white-space: pre; }

/* File browser */
.fb-tree { flex: 0 1 280px; min-width: 200px; max-width: 280px; max-height: 70vh; overflow-y: auto; overflow-x: hidden; }
.fb-tree .pf-v6-c-tree-view__node-text { overflow-wrap: anywhere; word-break: break-all; }
.fb-viewer { flex: 1 1 400px; min-height: 200px; }
.fb-viewer .pf-v6-c-code-block__pre { max-height: 65vh; overflow: auto; }
.file-content-hidden { display: none; }

/* Excluded rows */
tr.excluded td { opacity: 0.6; }
tr.excluded td:first-child { opacity: 1; }
div.excluded { opacity: 0.6; }

/* Include toggle – hidden until yoinkc-refine helper is active */
.pf-v6-c-switch.include-toggle-wrap { display: none; }
/* Vertically center checkbox cells without overriding all table cells globally */
.pf-v6-c-table .pf-v6-c-table__check { vertical-align: middle; }

/* Gap between stacked inner cards inside a card body */
.pf-v6-c-card__body > .pf-v6-c-card + .pf-v6-c-card { margin-top: var(--pf-t--global--spacer--md, 1rem); }


/* Details/summary disclosure styling */
details > summary { cursor: pointer; color: var(--pf-t--global--text--color--link--default); font-size: 0.85em; padding: 0.25rem 0; list-style: none; }
details > summary::-webkit-details-marker { display: none; }
details > summary::before { content: "▸ "; font-size: 0.75em; }
details[open] > summary::before { content: "▾ "; }
details > summary:hover { text-decoration: underline; }
details[open] > summary { margin-bottom: 0.25rem; }

/* Inline semantic labels now use native PF6 variants */

/* Fleet variant styling (migrated from inline styles) */
.fleet-variant-toggle { margin-left: 8px; cursor: pointer; }
.fleet-variant-table { margin: 0; }
.variant-index { color: var(--pf-t--global--text--color--subtle); }
.fleet-banner-hosts { color: var(--pf-t--global--text--color--subtle); }

/* Audit */
.audit-pre { border-radius: 6px; padding: 1rem; overflow: auto; max-height: 50vh; font-size: 0.85rem; margin: 0.5rem 0; }
.audit-table { margin: 0.5rem 0; }
.audit-section { max-height: 70vh; overflow-y: auto; padding: 0 0.25rem; }
details.audit-expand > summary { font-size: 1em; font-weight: 600; color: inherit; padding: 0.6rem 0 0.2rem; }
details.audit-expand { margin-bottom: 0.25rem; }

/* Sticky toolbar */
#exclude-toolbar { position: fixed; bottom: 0; left: 0; right: 0; padding: var(--pf-t--global--spacer--sm) 1.5rem; display: none; align-items: center; gap: 1rem; z-index: 1000; background-color: var(--pf-t--global--background--color--primary--default); border-top: 1px solid var(--pf-t--global--border--color--default); }
#exclude-toolbar.visible, #exclude-toolbar.helper-active { display: flex; }
#exclude-toolbar .toolbar-status { font-weight: 600; flex: 1; }


/* Sidebar triage badges (PF6 badge) */
.triage-badge { margin-left: 0.25rem; }
.triage-badge-reviewed {
  background: var(--pf-t--global--color--status--success--default, #3e8635);
}
.triage-badge-attention {
  background: var(--pf-t--global--color--status--warning--default, #f0ab00);
}

/* ── Extracted inline styles ────────────────────────────────────────────── */

/* Sidebar layout */
.sidebar-body-layout { display: flex; flex-direction: column; overflow: hidden; }
.sidebar-progress-container {
  padding: var(--pf-t--global--spacer--sm) var(--pf-t--global--spacer--md) var(--pf-t--global--spacer--md);
  flex-shrink: 0;
}
.sidebar-nav-container { overflow-y: auto; flex: 1; }

/* Sidebar reviewed check (hidden until JS reveals) */
.reviewed-check {
  display: none;
  color: var(--pf-t--global--color--status--success--default);
}

/* Summary readiness cards — coloured left border */
.readiness-card-success { border-left: 4px solid var(--pf-t--global--color--status--success--default); }
.readiness-card-warning { border-left: 4px solid var(--pf-t--global--color--status--warning--default); }
.readiness-card-danger  { border-left: 4px solid var(--pf-t--global--color--status--danger--default); }
.readiness-card-info    { border-left: 4px solid var(--pf-t--global--color--status--info--default); }

/* Summary readiness counts */
.readiness-count { font-size: 1.3rem; }

/* Summary breakdown + fleet variant lists */
.breakdown-list { list-style: none; padding: 0; margin: 0; }
.breakdown-list-item { display: flex; justify-content: space-between; padding: 0.25rem 0; }
.breakdown-link-btn {
  background: none;
  border: none;
  color: var(--pf-t--global--text--color--link--default);
  cursor: pointer;
  padding: 0;
  text-align: left;
}

/* Banner */
.banner-hostname { opacity: 0.7; }
.fleet-banner-title { font-size: 1.1em; margin-bottom: 4px; }
.fleet-banner-spacing { margin-bottom: var(--pf-t--global--spacer--md); }
.fleet-banner-counts { margin-top: 4px; }

/* Toolbar / action row — right-aligned button container */
.actions-end-row { display: flex; justify-content: flex-end; margin-bottom: var(--pf-t--global--spacer--sm); }

/* Warnings dismiss-all row (slightly different margin than generic) */
.warnings-actions-row { display: flex; justify-content: flex-end; margin-bottom: 0.5rem; }

/* Variant selected label (services, config, containers) */
.variant-selected-label { font-size: 0.75rem; color: var(--pf-t--global--text--color--subtle); }

/* File browser layout */
.file-browser-layout { gap: 1rem; }

/* Non-RPM venv info row */
.venv-info-row { display: flex; align-items: center; gap: var(--pf-t--global--spacer--sm); }

/* Code block with bottom spacing */
.code-block-spaced { margin-bottom: var(--pf-t--global--spacer--md); }

/* Audit manual-intervention list */
.audit-manual-list { margin: 0.25rem 0 0; padding-left: 1.5rem; font-size: 0.9rem; }

/* Subtle text colour */
.text-subtle { color: var(--pf-t--global--text--color--subtle); }

/* Inline warning/conflict icon */
.conflict-icon { margin-left: 0.35em; cursor: help; }

/* New-file modal form layout */
.modal-field-group { margin-bottom: 20px; }
.modal-field-label { display: block; margin-bottom: 6px; }
.modal-radio-group { display: flex; gap: 24px; }
.modal-radio-option { display: flex; align-items: center; gap: 8px; cursor: pointer; }
.modal-hint-text {
  font-size: var(--pf-t--global--font--size--sm);
  color: var(--pf-t--global--text--color--subtle);
  margin-bottom: 6px;
}
.modal-input-full { width: 100%; }
.modal-input-mono { width: 100%; font-family: var(--pf-t--global--font--family--mono); }
.modal-field-error {
  color: var(--pf-t--global--danger--color--200);
  font-size: var(--pf-t--global--font--size--sm);
  margin-top: 4px;
  display: none;
}
.modal-path-preview {
  padding: 10px 14px;
  background: var(--pf-t--global--background--color--secondary--default);
  border: 1px solid var(--pf-t--global--border--color--default);
  border-radius: 4px;
  font-family: var(--pf-t--global--font--family--mono);
  font-size: var(--pf-t--global--font--size--sm);
}

/* Editor tree pane */
.editor-tree-layout {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  background: var(--pf-t--global--background--color--secondary--default);
}
.editor-tree-header {
  padding: 12px 16px;
  border-bottom: 1px solid var(--pf-t--global--border--color--default);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.editor-tree-body { padding: 8px; overflow-y: auto; flex: 1; }

/* Editor error banner (hidden by default, shown by JS) */
.editor-error-hidden { display: none; margin-bottom: 8px; }

/* Editor content pane */
.editor-toolbar {
  padding: 8px 16px;
  border-bottom: 1px solid var(--pf-t--global--border--color--default);
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 48px;
}
.editor-file-path {
  font-family: var(--pf-t--global--font--family--mono);
  font-size: var(--pf-t--global--font--size--heading--sm);
}
.editor-view-pane { flex: 1; overflow: auto; padding: 16px; }
.editor-readonly-pre {
  margin: 0;
  white-space: pre-wrap;
  font-family: var(--pf-t--global--font--family--mono);
  font-size: var(--pf-t--global--font--size--sm);
}

/* Utility classes */
.content-preview { border-radius: 4px; padding: var(--pf-t--global--spacer--sm); font-size: 0.8rem; max-height: 200px; overflow: auto; margin: var(--pf-t--global--spacer--xs) 0; }
.table-group-header { font-weight: var(--pf-t--global--font--weight--body--bold); padding-bottom: var(--pf-t--global--spacer--xs); padding-top: var(--pf-t--global--spacer--md); border-top: 2px solid var(--pf-t--global--border--color--default); background-color: var(--pf-t--global--background--color--secondary--default); }
.text-sm { font-size: var(--pf-t--global--font--size--body--sm); }
.text-bold { font-weight: var(--pf-t--global--font--weight--body--bold); }
.mt-sm { margin-top: var(--pf-t--global--spacer--sm); }
.mt-md { margin-top: var(--pf-t--global--spacer--md); }
.mt-lg { margin-top: var(--pf-t--global--spacer--lg); }
.mb-md { margin-bottom: var(--pf-t--global--spacer--md); }
.table-group-header-first { border-top: none; padding-top: var(--pf-t--global--spacer--sm); }
.deps-list { margin: var(--pf-t--global--spacer--xs) 0; padding-left: 1.5rem; }
.card-actions-layout { display: flex; align-items: center; gap: var(--pf-t--global--spacer--sm); flex-wrap: nowrap; }

/* Toast (PF6 alert group) */
.pf-v6-c-alert-group.pf-m-toast { position: fixed; top: 1rem; right: 1rem; z-index: 2000; display: none; }
.pf-v6-c-alert-group.pf-m-toast.visible { display: block; }

/* PF6 spinner sizing override for inline button usage */
.pf-v6-c-spinner.pf-m-sm { margin-right: 0.5rem; vertical-align: middle; }

/* Form controls in table cells – compact rows with breathing room between columns */
.pf-v6-c-table td .pf-v6-c-form-control {
  margin: 0;
  padding: 0.25rem var(--pf-t--global--spacer--sm);
}

/* Status text/background utility classes — theme-aware via PF6 tokens */
.text-status-success { color: var(--pf-t--global--text--color--status--success--default); }
.text-status-warning { color: var(--pf-t--global--text--color--status--warning--default); }
.text-status-danger  { color: var(--pf-t--global--text--color--status--danger--default); }
.text-status-info    { color: var(--pf-t--global--text--color--status--info--default); }

{% if fleet_meta %}
/* Fleet prevalence badges */
.fleet-prevalence {
  width: 90px;
  min-width: 90px;
}
.fleet-bar {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
}
.fleet-bar-track {
  width: 60px;
  height: 6px;
  background: var(--pf-t--global--background--color--secondary--default, #e0e0e0);
  border-radius: 3px;
  overflow: hidden;
}
.fleet-bar-fill {
  height: 100%;
  border-radius: 3px;
}
.fleet-bar-fill.pf-m-blue {
  background: var(--pf-t--global--color--brand--default, #0066cc);
}
.fleet-bar-fill.pf-m-gold {
  background: var(--pf-t--global--color--status--warning--default, #f0ab00);
}
.fleet-bar-fill.pf-m-red {
  background: var(--pf-t--global--color--status--danger--default, #c9190b);
}
.fleet-bar-label {
  font-size: 11px;
  color: var(--pf-t--global--text--color--subtle, #6a6e73);
  white-space: nowrap;
  cursor: pointer;
  user-select: none;
}
.fleet-banner {
  border-left: 4px solid var(--pf-t--global--color--brand--default, #0066cc);
}
/* Fleet prevalence inline badge (compose-files context) */
.fleet-prevalence-inline { display: inline-block; margin-left: 8px; }
/* Fleet popover (PF6) */
.pf-v6-c-popover.fleet-popover {
  position: absolute;
  z-index: 1000;
  max-width: 300px;
  font-size: 13px;
}
.fleet-popover .pf-v6-c-popover__body ul {
  list-style: none;
  margin: 0;
  padding: 0;
}
.fleet-popover .pf-v6-c-popover__body li {
  padding: 2px 0;
}
/* Fleet popover: header + split copy button */
.fleet-popover-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--pf-t--global--border--color--default, #d2d2d2);
}
.fleet-popover-count {
  font-size: 12px;
  color: var(--pf-t--global--text--color--subtle, #6a6e73);
  white-space: nowrap;
  margin-right: 8px;
}
.fleet-popover-split-btn {
  position: relative;
  display: flex;
  flex-shrink: 0;
}
.fleet-popover-copy-btn,
.fleet-popover-drop-arrow {
  background: var(--pf-t--global--background--color--primary--default, #fff);
  border: 1px solid var(--pf-t--global--border--color--default, #8a8d90);
  color: var(--pf-t--global--text--color--regular, #151515);
  cursor: pointer;
  font-size: 12px;
  line-height: 1;
  padding: 3px 7px;
}
.fleet-popover-copy-btn {
  border-right: none;
  border-radius: 2px 0 0 2px;
}
.fleet-popover-drop-arrow {
  border-radius: 0 2px 2px 0;
  padding: 3px 5px;
}
.fleet-popover-copy-btn:hover,
.fleet-popover-drop-arrow:hover {
  background: var(--pf-t--global--background--color--secondary--default, #f0f0f0);
}
.fleet-popover-copy-btn--copied {
  background: var(--pf-t--global--background--color--secondary--default, #f0f0f0);
}
/* Fleet popover: format dropdown */
.fleet-popover-dropdown {
  position: absolute;
  top: 100%;
  right: 0;
  z-index: 100;
  background: var(--pf-t--global--background--color--primary--default, #fff);
  border: 1px solid var(--pf-t--global--border--color--default, #d2d2d2);
  border-radius: 4px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.12);
  min-width: 140px;
  padding: 4px 0;
  margin-top: 2px;
}
.fleet-popover-fmt-item {
  display: flex;
  align-items: center;
  width: 100%;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 12px;
  padding: 5px 10px;
  text-align: left;
  color: var(--pf-t--global--text--color--regular, #151515);
  white-space: nowrap;
}
.fleet-popover-fmt-item:hover {
  background: var(--pf-t--global--background--color--secondary--default, #f0f0f0);
}
.fleet-popover-fmt-check {
  color: var(--pf-t--global--icon--color--brand--default, #0066cc);
  display: inline-block;
  width: 1.2em;
  font-size: 13px;
  flex-shrink: 0;
}
/* Fleet variant grouping */
.fleet-variant-children {
  display: none;
}
.variant-compare-btn { white-space: nowrap; padding-inline: var(--pf-t--global--spacer--sm, 0.5rem); min-width: max-content; }
/* Fleet variant comparison diff */
.diff-line-same { padding: 0 16px; white-space: pre; color: var(--pf-t--global--text--color--subtle); }
.diff-line-add { padding: 0 16px; white-space: pre; background: var(--yoinkc-diff-add-bg); color: var(--pf-t--global--text--color--regular); }
.diff-line-remove { padding: 0 16px; white-space: pre; background: var(--yoinkc-diff-remove-bg); color: var(--pf-t--global--text--color--regular); }
.diff-legend-selected { color: var(--yoinkc-diff-remove-border); margin-right: 4px; }
.diff-legend-comparison { color: var(--yoinkc-diff-add-border); margin-right: 4px; }
/* Focus indicators for fleet-specific interactive elements */
.fleet-bar:focus-visible,
.fleet-bar-label:focus-visible,
.fleet-variant-toggle:focus-visible {
  outline: 2px solid var(--pf-t--global--icon--color--brand--default, #0066cc);
  outline-offset: 2px;
}
{% endif %}

/* Pencil editor icon column */
.editor-icon {
  font-size: 14px;
  cursor: pointer;
  filter: grayscale(1);
  transition: filter 0.15s;
  background: none;
  border: none;
  padding: 2px;
}
.editor-icon:hover {
  filter: grayscale(0);
}

{% if refine_mode %}
/* CodeMirror gutter: use PF6 variables so dark/light mode is respected */
.cm-gutters {
  background-color: var(--pf-t--global--background--color--secondary--default) !important;
  color: var(--pf-t--global--text--color--subtle) !important;
  border-right: 1px solid var(--pf-t--global--border--color--default) !important;
}
{% endif %}

/* ── Collapsible cards (Part B + D) ──────────────────────────────────────
   These rules override PF6's CSS-variable-driven expandable section.
   toggleCard() drives max-height via JS inline styles (scrollHeight-based),
   so there is no arbitrary ceiling. pf-m-collapsed + pf-m-expanded are both
   toggled in JS. The visibility delay keeps content in the a11y tree while
   the height animation plays, then removes it after 200 ms. */
.pf-v6-c-card.pf-v6-c-expandable-section .pf-v6-c-expandable-section__content {
  overflow: hidden;
  max-height: none; /* JS sets inline max-height during transitions */
  opacity: 1;
  /* visibility 0s 200ms: when collapsing, delay hiding until after the animation
     completes so interactive content stays in the a11y tree while visible. */
  transition: max-height 200ms ease-out, opacity 150ms ease-out, visibility 0s 200ms;
}
.pf-v6-c-card.pf-v6-c-expandable-section.pf-m-collapsed .pf-v6-c-expandable-section__content {
  /* max-height is 0 via JS inline style — not set here to avoid specificity fights */
  opacity: 0;
  visibility: hidden;
  padding-top: 0;
  padding-bottom: 0;
  /* visibility 0s (no delay): become visible immediately on expand */
  transition: max-height 200ms ease-out, opacity 150ms ease-out, visibility 0s;
}
