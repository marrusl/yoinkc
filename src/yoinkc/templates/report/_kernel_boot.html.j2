{% from "report/_macros.html.j2" import section, card_toggle, card_toolbar with context -%}
{# ── Kernel / Boot ────────────────────────────────────────────────────────── #}
{% call section("kernel_boot", "Kernel and boot", triageable=true) %}
  {%- set kb = snapshot.kernel_boot %}
  {%- if kb and (kb.cmdline or kb.sysctl_overrides or kb.non_default_modules or kb.modules_load_d or kb.modprobe_d or kb.dracut_conf or kb.tuned_active or kb.tuned_custom_profiles or kb.locale or kb.timezone or kb.alternatives) %}

  {%- if kb.cmdline or kb.non_default_modules %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-kb-cmdline", "Kernel Command Line") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-kb-cmdline"><div class="pf-v6-c-card__body">
    {%- if kb.cmdline %}
    <div class="pf-v6-c-code-block code-block-spaced"><div class="pf-v6-c-code-block__content"><pre class="pf-v6-c-code-block__pre"><code class="pf-v6-c-code-block__code">{{ kb.cmdline[:300] }}</code></pre></div></div>
    {%- endif %}
    {%- if kb.non_default_modules %}
    <p>{{ kb.non_default_modules|length }} kernel module(s) loaded at inspection time (hardware-specific, not included in the image). See modules-load.d entries below for explicitly configured modules.</p>
    {%- endif %}
    </div></div>
  </div>
  {%- endif %}

  {%- if kb.sysctl_overrides %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-kb-sysctl", "Sysctl Overrides") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-kb-sysctl">
    {{ card_toolbar("card-kb-sysctl-items", kb.sysctl_overrides|length, "Sysctl overrides") }}
    <div class="pf-v6-c-card__body" id="card-kb-sysctl-items">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check pf-m-fit-content" scope="col"></th><th scope="col">Key</th><th class="pf-m-fit-content" scope="col">Runtime</th><th class="pf-m-fit-content" scope="col">Default</th><th scope="col">Source</th></tr></thead><tbody>
      {%- for s in kb.sysctl_overrides %}
      <tr{% if not s.include %} class="excluded"{% endif %} data-search-text="{{ s.key }}" data-snap-section="kernel_boot" data-snap-list="sysctl_overrides" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if s.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
        <td><code>{{ s.key }}</code></td>
        <td class="text-status-warning text-bold">{{ s.runtime }}</td>
        <td>{{ s.default or '—' }}</td>
        <td><code>{{ s.source }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div></div>
  </div>
  {%- endif %}

  {%- if kb.modules_load_d or kb.modprobe_d or kb.dracut_conf %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-kb-modconf", "Module and Dracut Configuration") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-kb-modconf"><div class="pf-v6-c-card__body">
    {%- set modconf_sections =
          ([("modules-load.d", kb.modules_load_d)] if kb.modules_load_d else []) +
          ([("modprobe.d", kb.modprobe_d)] if kb.modprobe_d else []) +
          ([("dracut.conf.d", kb.dracut_conf)] if kb.dracut_conf else [])
    %}
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Path</th><th scope="col">Content</th></tr></thead><tbody>
      {%- for label, items in modconf_sections %}
      <tr><th colspan="2" class="table-group-header{{ ' table-group-header-first' if loop.first else '' }}">{{ label }}</th></tr>
      {%- for cfg in items %}
      <tr>
        <td><code>{{ cfg.path }}</code></td>
        <td>
          {%- if cfg.content and cfg.content.strip() %}
          <details><summary>show</summary>
            <pre class="content-preview">{{ cfg.content }}</pre>
          </details>
          {%- endif %}
        </td>
      </tr>
      {%- endfor %}
      {%- endfor %}
    </tbody></table>
    </div></div>
  </div>
  {%- endif %}

  {%- if kb.tuned_active or kb.tuned_custom_profiles %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-kb-tuned", "Tuned Profile") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-kb-tuned"><div class="pf-v6-c-card__body">
    {%- if kb.tuned_active %}<p>Active profile: <strong>{{ kb.tuned_active }}</strong></p>{%- endif %}
    {%- if kb.tuned_custom_profiles %}
    <p>Custom profiles ({{ kb.tuned_custom_profiles|length }}):</p>
    <ul>
      {%- for tp in kb.tuned_custom_profiles %}
      <li><code>{{ tp.path }}</code></li>
      {%- endfor %}
    </ul>
    {%- endif %}
    </div></div>
  </div>
  {%- endif %}

  {%- if kb.locale or kb.timezone %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-kb-locale", "System Properties") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-kb-locale"><div class="pf-v6-c-card__body">
    <dl class="pf-v6-c-description-list pf-m-horizontal">
      {%- if kb.locale %}
      <div class="pf-v6-c-description-list__group">
        <dt class="pf-v6-c-description-list__term"><span class="pf-v6-c-description-list__text">Locale</span></dt>
        <dd class="pf-v6-c-description-list__description"><div class="pf-v6-c-description-list__text">{{ kb.locale }}</div></dd>
      </div>
      {%- endif %}
      {%- if kb.timezone %}
      <div class="pf-v6-c-description-list__group">
        <dt class="pf-v6-c-description-list__term"><span class="pf-v6-c-description-list__text">Timezone</span></dt>
        <dd class="pf-v6-c-description-list__description"><div class="pf-v6-c-description-list__text">{{ kb.timezone }}</div></dd>
      </div>
      {%- endif %}
    </dl>
    </div></div>
  </div>
  {%- endif %}

  {%- if kb.alternatives %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-kb-alternatives", "Alternatives") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-kb-alternatives"><div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table pf-m-compact" role="grid">
      <thead><tr>
        <th scope="col">Name</th>
        <th scope="col">Path</th>
        <th scope="col">Status</th>
      </tr></thead>
      <tbody>
        {%- for alt in kb.alternatives %}
        <tr>
          <td>{{ alt.name }}</td>
          <td><code>{{ alt.path }}</code></td>
          <td><span class="pf-v6-c-label{{ ' pf-m-blue' if alt.status == 'manual' else '' }}">{{ alt.status }}</span></td>
        </tr>
        {%- endfor %}
      </tbody>
    </table>
    </div></div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No kernel/boot customizations detected.</p>
  {%- endif %}
{% endcall %}

