{% from "report/_macros.html.j2" import fleet_cell, card_toggle with context -%}
{# ── Version-Locked Packages ─────────────────────────────────────────────── #}
{%- if snapshot.rpm and snapshot.rpm.version_locks %}
<div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
  <div class="pf-v6-c-card__header">{{ card_toggle("card-pkg-version-locks", "Version-Locked Packages (" ~ snapshot.rpm.version_locks|length ~ ")") }}</div>
  <div class="pf-v6-c-expandable-section__content" id="card-pkg-version-locks"><div class="pf-v6-c-card__body">
  <table class="pf-v6-c-table" id="pkg-version-locks-table">
    <thead><tr>
      <th scope="col">Package</th>
      <th scope="col">Locked Version</th>
      <th class="pf-m-fit-content" scope="col">Arch</th>
      <th class="pf-v6-c-table__check pf-m-fit-content" scope="col">Include</th>
      {% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}
    </tr></thead>
    <tbody>
    {%- for vl in snapshot.rpm.version_locks %}
    <tr{% if not vl.include %} class="excluded"{% endif %} data-snap-section="rpm" data-snap-list="version_locks" data-snap-index="{{ loop.index0 }}">
      <td>{{ vl.name }}</td>
      <td class="text-sm"><code>{% if vl.epoch != 0 %}{{ vl.epoch }}:{% endif %}{{ vl.version }}-{{ vl.release }}</code></td>
      <td class="text-sm">{{ vl.arch }}</td>
      <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if vl.include else '' }} data-snap-field="include"/><span class="pf-v6-c-switch__toggle"></span></label></td>
      {{ fleet_cell(vl) }}
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  </div></div>
</div>
{%- endif %}
