{% from "report/_macros.html.j2" import section with context -%}
{# ── Summary ────────────────────────────────────────────────────────────── #}
{% call section("summary", "Summary", visible=true) %}
<div class="summary-grid">

  {# ── Left column ──────────────────────────────────────────────────────── #}
  <div>
    {# System Information #}
    <div class="pf-v6-c-card">
      <div class="pf-v6-c-card__header">
        <div class="pf-v6-c-card__title"><h3>System Information</h3></div>
      </div>
      <div class="pf-v6-c-card__body">
        <dl class="pf-v6-c-description-list">
          <div class="pf-v6-c-description-list__group">
            <dt class="pf-v6-c-description-list__term">Hostname</dt>
            <dd class="pf-v6-c-description-list__description">{{ meta.hostname|default('—') }}</dd>
          </div>
          <div class="pf-v6-c-description-list__group">
            <dt class="pf-v6-c-description-list__term">OS</dt>
            <dd class="pf-v6-c-description-list__description">{{ os_desc }}</dd>
          </div>
          <div class="pf-v6-c-description-list__group">
            <dt class="pf-v6-c-description-list__term">Inspection time (UTC)</dt>
            <dd class="pf-v6-c-description-list__description">{{ meta.timestamp|default('—') }}</dd>
          </div>
          {%- if meta.host_root %}
          <div class="pf-v6-c-description-list__group">
            <dt class="pf-v6-c-description-list__term">Host root</dt>
            <dd class="pf-v6-c-description-list__description"><code>{{ meta.host_root }}</code></dd>
          </div>
          {%- endif %}
        </dl>
      </div>
    </div>

    {# Migration Readiness #}
    <h3 class="mt-md mb-md">Migration Readiness</h3>
    {%- if triage.automatic %}
    <div class="pf-v6-c-card mt-md" style="border-left: 4px solid var(--pf-t--global--color--status--success--default)">
      <div class="pf-v6-c-card__body">
        <span class="text-bold" style="font-size:1.3rem; color:var(--pf-t--global--text--color--status--success--default)">{{ triage.automatic }}</span>
        Automatic
      </div>
    </div>
    {%- endif %}
    {%- if triage.fixme %}
    <div class="pf-v6-c-card mt-md" style="border-left: 4px solid var(--pf-t--global--color--status--warning--default)">
      <div class="pf-v6-c-card__body">
        <span class="text-bold" style="font-size:1.3rem; color:var(--pf-t--global--text--color--status--warning--default)">{{ triage.fixme }}</span>
        Needs Review
      </div>
    </div>
    {%- endif %}
    {%- if triage.manual %}
    <div class="pf-v6-c-card mt-md" style="border-left: 4px solid var(--pf-t--global--color--status--danger--default)">
      <div class="pf-v6-c-card__body">
        <span class="text-bold" style="font-size:1.3rem; color:var(--pf-t--global--text--color--status--danger--default)">{{ triage.manual }}</span>
        Manual
      </div>
    </div>
    {%- endif %}
  </div>

  {# ── Right column ─────────────────────────────────────────────────────── #}
  <div>
    {# Breakdown #}
    <div class="pf-v6-c-card">
      <div class="pf-v6-c-card__header">
        <div class="pf-v6-c-card__title"><h3>Breakdown</h3></div>
      </div>
      <div class="pf-v6-c-card__body">
        <ul style="list-style:none; padding:0; margin:0">
          {%- for item in triage_detail %}
          <li style="display:flex; justify-content:space-between; padding:0.25rem 0">
            <button type="button" style="background:none; border:none; color:var(--pf-t--global--text--color--link--default); cursor:pointer; padding:0; text-align:left" onclick="show('{{ item.tab }}');return false">{{ item.label }}</button>
            <span class="text-status-{{ 'success' if item.status == 'automatic' else ('warning' if item.status == 'fixme' else 'danger') }}">{{ item.count }}</span>
          </li>
          {%- endfor %}
        </ul>
      </div>
    </div>

    {# Fleet Overview (fleet mode only) #}
    {%- if fleet_meta %}
    <div class="pf-v6-c-card mt-md" style="border-left: 4px solid var(--pf-t--global--color--status--info--default)">
      <div class="pf-v6-c-card__header">
        <div class="pf-v6-c-card__title"><h3>Fleet Overview</h3></div>
        <span class="text-sm">{{ fleet_meta.total_hosts }} hosts · {{ fleet_meta.min_prevalence }}% threshold</span>
      </div>
      <div class="pf-v6-c-card__body">
        <dl class="pf-v6-c-description-list">
          <div class="pf-v6-c-description-list__group">
            <dt class="pf-v6-c-description-list__term">Included</dt>
            <dd class="pf-v6-c-description-list__description">{{ counts.n_included }}</dd>
          </div>
          <div class="pf-v6-c-description-list__group">
            <dt class="pf-v6-c-description-list__term">Excluded</dt>
            <dd class="pf-v6-c-description-list__description">{{ counts.n_excluded }}</dd>
          </div>
        </dl>
        {%- if variant_summary %}
        <p class="text-bold mt-md">Categories with variants:</p>
        <ul style="list-style:none; padding:0; margin:0">
          {%- for vs in variant_summary %}
          <li style="display:flex; justify-content:space-between; padding:0.25rem 0">
            <button type="button" style="background:none; border:none; color:var(--pf-t--global--text--color--link--default); cursor:pointer; padding:0; text-align:left" onclick="show('{{ vs.tab }}');return false">{{ vs.label }}</button>
            <span class="text-sm">{{ vs.files }} files · {{ vs.variants }} variants</span>
          </li>
          {%- endfor %}
        </ul>
        {%- endif %}
      </div>
    </div>
    {%- endif %}
  </div>

</div>

{# ── Next Steps (full width) ───────────────────────────────────────────── #}
<div class="pf-v6-c-card mt-lg">
  <div class="pf-v6-c-card__header">
    <div class="pf-v6-c-card__title"><h3>Next Steps</h3></div>
  </div>
  <div class="pf-v6-c-card__body">
    <ol>
      <li><strong>Review</strong> — Check the Audit report tab for warnings and review any FIXME comments in the generated Containerfile.</li>
      <li><strong>Refine</strong> (optional) — Use <code>./yoinkc-refine {% if fleet_meta %}fleet-*.tar.gz{% else %}hostname-*.tar.gz{% endif %}</code> to interactively toggle package and config inclusions, then re-render the Containerfile.</li>
      <li><strong>Build</strong> — Build your bootc image: <code>./yoinkc-build {% if fleet_meta %}fleet-*.tar.gz{% else %}hostname-*.tar.gz{% endif %} my-image:latest</code></li>
    </ol>
  </div>
</div>
{% endcall %}
