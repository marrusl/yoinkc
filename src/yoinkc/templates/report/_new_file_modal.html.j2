{% if refine_mode %}
<div class="pf-v6-c-backdrop" id="new-file-modal" style="display:none;" onclick="closeNewFileModal()">
  <div class="pf-v6-l-bullseye">
    <div class="pf-v6-c-modal-box pf-m-md" role="dialog" aria-modal="true" aria-label="Create new file" onclick="event.stopPropagation()">
      <div class="pf-v6-c-modal-box__close">
        <button class="pf-v6-c-button pf-m-plain" onclick="closeNewFileModal()" aria-label="Close">&times;</button>
      </div>
      <div class="pf-v6-c-modal-box__header">
        <h2 class="pf-v6-c-modal-box__title">Create new file</h2>
      </div>

      <div class="pf-v6-c-modal-box__body">
      <div class="modal-field-group">
        <label class="pf-v6-c-form__label modal-field-label"><strong>File type</strong></label>
        <div class="modal-radio-group">
          <label class="modal-radio-option">
            <input type="radio" name="new-file-type" value="config" checked onchange="updateNewFileForm()"> Config file
          </label>
          <label class="modal-radio-option">
            <input type="radio" name="new-file-type" value="quadlet" onchange="updateNewFileForm()"> Quadlet unit
          </label>
          <label class="modal-radio-option">
            <input type="radio" name="new-file-type" value="dropin" onchange="updateNewFileForm()"> Systemd drop-in
          </label>
        </div>
      </div>

      <div id="nf-config-fields">
        <div class="modal-field-group">
          <label class="pf-v6-c-form__label modal-field-label"><strong>File path</strong></label>
          <div class="modal-hint-text">Absolute path on the target system</div>
          <input id="nf-config-path" class="pf-v6-c-form-control modal-input-mono" type="text" placeholder="/etc/myapp/custom.conf" oninput="validateNewFileForm()">
          <div id="nf-config-error" class="modal-field-error"></div>
        </div>
      </div>

      <div id="nf-quadlet-fields" style="display:none;">
        <div class="modal-field-group">
          <label class="pf-v6-c-form__label modal-field-label"><strong>Scope</strong></label>
          <select id="nf-quadlet-scope" class="pf-v6-c-form-control modal-input-full" onchange="updateNewFilePath()">
            <option value="system">System (root)</option>
            {%- for user in (snapshot.users_groups.users or []) if user.get('home') %}
            <option value="{{ user.name }}">User &mdash; {{ user.name }}</option>
            {%- endfor %}
          </select>
        </div>
        <div class="modal-field-group">
          <label class="pf-v6-c-form__label modal-field-label"><strong>Unit name</strong></label>
          <div class="modal-hint-text">e.g. myapp.container</div>
          <input id="nf-quadlet-name" class="pf-v6-c-form-control modal-input-mono" type="text" placeholder="myapp.container" oninput="updateNewFilePath(); validateNewFileForm();">
          <div id="nf-quadlet-error" class="modal-field-error"></div>
        </div>
        <div class="modal-field-group">
          <label class="pf-v6-c-form__label modal-field-label"><strong>Full path</strong></label>
          <div id="nf-quadlet-path-preview" class="modal-path-preview"></div>
        </div>
      </div>

      <div id="nf-dropin-fields" style="display:none;">
        <div class="modal-field-group">
          <label class="pf-v6-c-form__label modal-field-label"><strong>Service</strong></label>
          <div class="modal-hint-text">Select from services discovered on this host</div>
          <select id="nf-dropin-service" class="pf-v6-c-form-control modal-input-full" onchange="updateNewFilePath()">
            {%- if snapshot.services and snapshot.services.state_changes %}
            {%- for sc in snapshot.services.state_changes %}
            <option value="{{ sc.unit }}">{{ sc.unit }}</option>
            {%- endfor %}
            {%- endif %}
          </select>
        </div>
        <div class="modal-field-group">
          <label class="pf-v6-c-form__label modal-field-label"><strong>Override filename</strong></label>
          <input id="nf-dropin-filename" class="pf-v6-c-form-control modal-input-mono" type="text" value="override.conf" oninput="updateNewFilePath(); validateNewFileForm();">
          <div id="nf-dropin-error" class="modal-field-error"></div>
        </div>
        <div class="modal-field-group">
          <label class="pf-v6-c-form__label modal-field-label"><strong>Full path</strong></label>
          <div id="nf-dropin-path-preview" class="modal-path-preview"></div>
        </div>
      </div>
    </div>

      <div class="pf-v6-c-modal-box__footer">
        <button class="pf-v6-c-button pf-m-secondary" onclick="closeNewFileModal()">Cancel</button>
        <button class="pf-v6-c-button pf-m-primary" id="btn-create-file" onclick="createNewFile()" disabled>Create &amp; edit</button>
      </div>
    </div>
  </div>
</div>
{% endif %}
