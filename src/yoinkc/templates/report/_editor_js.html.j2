{% if refine_mode %}
<script>
(function() {
  var editorState = {
    currentFile: null,
    cmView: null,
    editMode: false,
    dirtyFiles: new Map(),
    savedFiles: new Set(),
  };

  function pathParts(p) {
    var i = p.lastIndexOf('/');
    return {dir: p.substring(0, i + 1), name: p.substring(i + 1)};
  }

  function pathHtml(p) {
    var pp = pathParts(p);
    return '<span style="color:var(--pf-t--global--text--color--subtle);">' +
      escapeHtml(pp.dir) + '</span><strong>' + escapeHtml(pp.name) + '</strong>';
  }

  function buildTree() {
    var treeEl = document.getElementById('editor-tree-list');
    if (!treeEl) return;
    treeEl.innerHTML = '';

    var root = document.createElement('ul');
    root.className = 'pf-v6-c-tree-view';

    var sections = [
      {section: 'config', list: 'files', label: 'config'},
      {section: 'services', list: 'drop_ins', label: 'drop-ins'},
      {section: 'containers', list: 'quadlet_units', label: 'quadlet'},
    ];

    sections.forEach(function(sec) {
      var items = snapshot[sec.section] && snapshot[sec.section][sec.list];
      if (!items || items.length === 0) return;

      var catLi = document.createElement('li');
      catLi.className = 'pf-v6-c-tree-view__list-item pf-m-expanded';
      var catDiv = document.createElement('div');
      catDiv.className = 'pf-v6-c-tree-view__content';
      var catBtn = document.createElement('button');
      catBtn.className = 'pf-v6-c-tree-view__node';
      catBtn.textContent = sec.label + '/';
      catDiv.appendChild(catBtn);
      catLi.appendChild(catDiv);

      var catUl = document.createElement('ul');
      catUl.className = 'pf-v6-c-tree-view__list';

      // Group items by path, preserving original indices
      var groups = {};
      var groupOrder = [];
      items.forEach(function(item, idx) {
        if (!groups[item.path]) {
          groups[item.path] = [];
          groupOrder.push(item.path);
        }
        groups[item.path].push({item: item, idx: idx});
      });
      groupOrder.sort();

      groupOrder.forEach(function(path) {
        var entries = groups[path];

        if (entries.length === 1) {
          // Leaf node — single item (or no fleet data)
          var e = entries[0];
          var li = document.createElement('li');
          li.className = 'pf-v6-c-tree-view__list-item';
          var div = document.createElement('div');
          div.className = 'pf-v6-c-tree-view__content';
          var btn = document.createElement('button');
          btn.className = 'pf-v6-c-tree-view__node';
          btn.dataset.section = sec.section;
          btn.dataset.list = sec.list;
          btn.dataset.index = e.idx;
          btn.dataset.path = path;
          btn.innerHTML = pathHtml(path);
          btn.title = path;

          var stateSpan = document.createElement('span');
          stateSpan.className = 'editor-state-label';
          stateSpan.style.marginLeft = '8px';
          btn.appendChild(stateSpan);

          btn.addEventListener('click', function() {
            selectFile(sec.section, sec.list, e.idx, path);
          });
          div.appendChild(btn);
          li.appendChild(div);
          catUl.appendChild(li);
        } else {
          // Multi-variant group — expandable parent with variant children
          entries.sort(function(a, b) {
            var ac = (a.item.fleet && a.item.fleet.count) || 0;
            var bc = (b.item.fleet && b.item.fleet.count) || 0;
            return bc - ac;
          });

          var parentLi = document.createElement('li');
          parentLi.className = 'pf-v6-c-tree-view__list-item pf-m-expanded';
          var parentDiv = document.createElement('div');
          parentDiv.className = 'pf-v6-c-tree-view__content';
          var parentBtn = document.createElement('button');
          parentBtn.className = 'pf-v6-c-tree-view__node';
          parentBtn.innerHTML = pathHtml(path) +
            ' <span class="pf-v6-c-badge pf-m-read">' + entries.length + '</span>';
          parentBtn.title = path;
          parentDiv.appendChild(parentBtn);
          parentLi.appendChild(parentDiv);

          var childUl = document.createElement('ul');
          childUl.className = 'pf-v6-c-tree-view__list';

          entries.forEach(function(e, variantNum) {
            var item = e.item;
            var childLi = document.createElement('li');
            childLi.className = 'pf-v6-c-tree-view__list-item';
            var childDiv = document.createElement('div');
            childDiv.className = 'pf-v6-c-tree-view__content';
            var childBtn = document.createElement('button');
            childBtn.className = 'pf-v6-c-tree-view__node';
            childBtn.dataset.section = sec.section;
            childBtn.dataset.list = sec.list;
            childBtn.dataset.index = e.idx;
            childBtn.dataset.path = path;

            var label = 'variant ' + (variantNum + 1);
            var html = escapeHtml(label);
            if (item.include === true) {
              html += ' <span class="pf-v6-c-label pf-m-compact pf-m-success"><span class="pf-v6-c-label__content">selected</span></span>';
            }
            if (item.fleet) {
              html += ' <span class="pf-v6-c-label pf-m-compact"><span class="pf-v6-c-label__content">' +
                item.fleet.count + '/' + item.fleet.total + ' hosts</span></span>';
            }
            childBtn.innerHTML = html;

            var stateSpan = document.createElement('span');
            stateSpan.className = 'editor-state-label';
            stateSpan.style.marginLeft = '8px';
            childBtn.appendChild(stateSpan);

            childBtn.addEventListener('click', function() {
              selectFile(sec.section, sec.list, e.idx, path);
            });
            childDiv.appendChild(childBtn);
            childLi.appendChild(childDiv);
            childUl.appendChild(childLi);
          });

          parentLi.appendChild(childUl);
          catUl.appendChild(parentLi);
        }
      });

      catLi.appendChild(catUl);
      root.appendChild(catLi);
    });

    treeEl.appendChild(root);
  }

  // Pending navigation target — set when the unsaved-changes modal is shown,
  // consumed by the modal button handlers.
  var pendingNav = null;

  function showUnsavedModal(filename, onSave, onDiscard, onCancel) {
    var modal = document.getElementById('unsaved-changes-modal');
    var msg = document.getElementById('unsaved-changes-message');
    if (!modal) { onDiscard(); return; }
    if (msg) msg.innerHTML = 'You have unsaved changes to <code>' + escapeHtml(filename) + '</code>.';
    modal.style.display = '';

    var saveBtn = document.getElementById('unsaved-btn-save');
    var discardBtn = document.getElementById('unsaved-btn-discard');
    var cancelBtn = document.getElementById('unsaved-btn-cancel');

    function cleanup() {
      modal.style.display = 'none';
      if (saveBtn) saveBtn.replaceWith(saveBtn.cloneNode(true));
      if (discardBtn) discardBtn.replaceWith(discardBtn.cloneNode(true));
      if (cancelBtn) cancelBtn.replaceWith(cancelBtn.cloneNode(true));
    }

    if (saveBtn) saveBtn.addEventListener('click', function() { cleanup(); onSave(); });
    if (discardBtn) discardBtn.addEventListener('click', function() { cleanup(); onDiscard(); });
    if (cancelBtn) cancelBtn.addEventListener('click', function() { cleanup(); onCancel(); });
  }

  function selectFile(section, list, index, path) {
    if (editorState.editMode && editorState.currentFile && editorState.dirtyFiles.has(editorState.currentFile.path)) {
      var dirtyPath = editorState.currentFile.path;
      pendingNav = {section: section, list: list, index: index, path: path};
      showUnsavedModal(
        dirtyPath.split('/').pop(),
        function onSave() {
          editorSave();
          doSelectFile(pendingNav.section, pendingNav.list, pendingNav.index, pendingNav.path);
          pendingNav = null;
        },
        function onDiscard() {
          editorState.dirtyFiles.delete(dirtyPath);
          updateStateLabels();
          doSelectFile(pendingNav.section, pendingNav.list, pendingNav.index, pendingNav.path);
          pendingNav = null;
        },
        function onCancel() {
          pendingNav = null;
        }
      );
      return;
    }
    doSelectFile(section, list, index, path);
  }

  function findSiblingVariants(section, list, path) {
    var items = (snapshot[section] && snapshot[section][list]) || [];
    var siblings = [];
    items.forEach(function(item, idx) {
      if (item.path === path) siblings.push({item: item, idx: idx});
    });
    return siblings;
  }

  function doSelectFile(section, list, index, path) {
    editorState.currentFile = {section: section, list: list, index: index, path: path};
    editorState.editMode = false;

    // Clear previous pf-m-current from all tree-view nodes
    document.querySelectorAll('.pf-v6-c-tree-view__node.pf-m-current').forEach(function(el) {
      el.classList.remove('pf-m-current');
    });
    var sel = 'button.pf-v6-c-tree-view__node[data-section="' + section + '"][data-list="' + list + '"][data-index="' + index + '"]';
    var activeBtn = document.querySelector(sel);
    if (activeBtn) activeBtn.classList.add('pf-m-current');

    var content = snapshot[section][list][index].content || '';
    var readonlyEl = document.getElementById('editor-readonly-content');
    var cmContainer = document.getElementById('editor-cm-container');
    if (readonlyEl) { readonlyEl.textContent = content; readonlyEl.style.display = ''; }
    if (cmContainer) cmContainer.style.display = 'none';

    var pathEl = document.getElementById('editor-file-path');
    if (pathEl) pathEl.innerHTML = pathHtml(path);

    var item = snapshot[section][list][index];
    var actionsEl = document.getElementById('editor-actions');
    if (actionsEl) {
      if (item.include === false && item.fleet) {
        actionsEl.innerHTML = '<button class="pf-v6-c-button pf-m-primary pf-m-small" id="btn-switch-variant">Switch to this variant</button>';
        var switchBtn = document.getElementById('btn-switch-variant');
        if (switchBtn) switchBtn.addEventListener('click', function() {
          var siblings = findSiblingVariants(section, list, path);
          siblings.forEach(function(s) { s.item.include = false; });
          item.include = true;
          buildTree();
          doSelectFile(section, list, index, path);
          if (typeof setDirty === 'function' && typeof isSnapshotClean === 'function') {
            setDirty(!isSnapshotClean());
          }
          if (typeof updateToolbar === 'function') updateToolbar();
        });
      } else {
        actionsEl.innerHTML = '<button class="pf-v6-c-button pf-m-primary pf-m-small" id="btn-edit">Edit</button>';
        var editBtn = document.getElementById('btn-edit');
        if (editBtn) editBtn.addEventListener('click', enterEditMode);
      }
    }

    updateStateLabels();
  }

  function enterEditMode() {
    if (!editorState.currentFile) return;
    editorState.editMode = true;

    var f = editorState.currentFile;
    var content = editorState.dirtyFiles.has(f.path)
      ? editorState.dirtyFiles.get(f.path)
      : (snapshot[f.section][f.list][f.index].content || '');

    var readonlyEl = document.getElementById('editor-readonly-content');
    var cmContainer = document.getElementById('editor-cm-container');
    if (readonlyEl) readonlyEl.style.display = 'none';
    if (cmContainer) { cmContainer.style.display = ''; cmContainer.innerHTML = ''; }

    if (window.CMEditor && cmContainer) {
      editorState.cmView = CMEditor.create(cmContainer, content, function(newContent) {
        if (editorState.currentFile) {
          editorState.dirtyFiles.set(editorState.currentFile.path, newContent);
          updateEditToolbar();
          updateStateLabels();
        }
      });
      if (localStorage.getItem('yoinkc-vim-mode') === 'on') {
        CMEditor.enableVim(editorState.cmView);
      }
    } else if (cmContainer) {
      var ta = document.createElement('textarea');
      ta.value = content;
      ta.style.cssText = 'width:100%; height:100%; font-family:var(--pf-t--global--font--family--mono); font-size:var(--pf-t--global--font--size--sm); border:none; resize:none; padding:8px;';
      ta.id = 'editor-textarea-fallback';
      cmContainer.appendChild(ta);
    }

    updateEditToolbar();
    setupDirtyTracking();
  }

  function setupDirtyTracking() {
    // CM6 dirty tracking is handled via the onChange callback passed to
    // CMEditor.create(). This function only covers the textarea fallback.
    if (!editorState.cmView || !window.CMEditor) {
      var ta = document.getElementById('editor-textarea-fallback');
      if (ta) {
        ta.addEventListener('input', function() {
          if (!editorState.currentFile) return;
          editorState.dirtyFiles.set(editorState.currentFile.path, ta.value);
          updateEditToolbar();
          updateStateLabels();
        });
      }
    }
  }

  function updateEditToolbar() {
    var f = editorState.currentFile;
    if (!f) return;

    var pathEl = document.getElementById('editor-file-path');
    if (pathEl) {
      var label = getStateLabel(f.path);
      pathEl.innerHTML = pathHtml(f.path) + (label ? ' ' + label : '');
    }

    var actionsEl = document.getElementById('editor-actions');
    if (!actionsEl) return;
    var created = isOperatorCreated(f.path);
    var vimLabel = localStorage.getItem('yoinkc-vim-mode') === 'on' ? 'Vim: On' : 'Vim: Off';
    actionsEl.innerHTML =
      (window.CMEditor && window.CMEditor.enableVim ? '<button class="pf-v6-c-button pf-m-plain pf-m-small" id="btn-vim-toggle" style="margin-right:8px;">' + vimLabel + '</button>' : '') +
      (created ? '<button class="pf-v6-c-button pf-m-danger pf-m-small" id="btn-delete" style="margin-right:8px;">Delete</button>' : '') +
      '<button class="pf-v6-c-button pf-m-secondary pf-m-small" id="btn-revert">Revert</button> ' +
      '<button class="pf-v6-c-button pf-m-secondary pf-m-small" id="btn-save-all">Save All</button> ' +
      '<button class="pf-v6-c-button pf-m-primary pf-m-small" id="btn-save">Save</button>';

    var saveBtn = document.getElementById('btn-save');
    if (saveBtn) saveBtn.addEventListener('click', editorSave);
    var saveAllBtn = document.getElementById('btn-save-all');
    if (saveAllBtn) saveAllBtn.addEventListener('click', editorSaveAll);
    var revertBtn = document.getElementById('btn-revert');
    if (revertBtn) revertBtn.addEventListener('click', editorRevert);
    var deleteBtn = document.getElementById('btn-delete');
    if (deleteBtn) deleteBtn.addEventListener('click', editorDeleteFile);
    var vimBtn = document.getElementById('btn-vim-toggle');
    if (vimBtn) vimBtn.addEventListener('click', toggleVim);
  }

  function editorSave() {
    var f = editorState.currentFile;
    if (!f) return;
    var content = getEditorContent();
    snapshot[f.section][f.list][f.index].content = content;
    editorState.dirtyFiles.delete(f.path);
    editorState.savedFiles.add(f.path);
    updateEditToolbar();
    updateStateLabels();
    updateChangedCount();
  }

  function editorRevert() {
    var f = editorState.currentFile;
    if (!f) return;
    var origItems = (originalSnapshot[f.section] && originalSnapshot[f.section][f.list]) || [];
    var origItem = origItems.find(function(item) { return item.path === f.path; });
    var origContent = origItem ? (origItem.content || '') : '';

    // Restore snapshot content from original (undoes any prior save)
    snapshot[f.section][f.list][f.index].content = origContent;
    editorState.dirtyFiles.delete(f.path);
    editorState.savedFiles.delete(f.path);

    // Exit edit mode and re-render read-only view
    doSelectFile(f.section, f.list, f.index, f.path);
    updateChangedCount();
  }

  function editorDeleteFile() {
    var f = editorState.currentFile;
    if (!f) return;

    var modal = document.getElementById('delete-file-modal');
    var msg = document.getElementById('delete-file-message');
    if (!modal) return;
    if (msg) msg.innerHTML = 'Delete <code>' + escapeHtml(f.path) + '</code>? This cannot be undone.';
    modal.style.display = '';

    var confirmBtn = document.getElementById('delete-btn-confirm');
    var cancelBtn = document.getElementById('delete-btn-cancel');

    function cleanup() {
      modal.style.display = 'none';
      if (confirmBtn) confirmBtn.replaceWith(confirmBtn.cloneNode(true));
      if (cancelBtn) cancelBtn.replaceWith(cancelBtn.cloneNode(true));
    }

    if (cancelBtn) cancelBtn.addEventListener('click', function() { cleanup(); });
    if (confirmBtn) confirmBtn.addEventListener('click', function() {
      cleanup();
      snapshot[f.section][f.list].splice(f.index, 1);
      editorState.dirtyFiles.delete(f.path);
      editorState.savedFiles.delete(f.path);
      editorState.currentFile = null;
      editorState.editMode = false;
      buildTree();
      var readonlyEl = document.getElementById('editor-readonly-content');
      var cmContainer = document.getElementById('editor-cm-container');
      if (readonlyEl) { readonlyEl.textContent = ''; readonlyEl.style.display = ''; }
      if (cmContainer) cmContainer.style.display = 'none';
      var pathEl = document.getElementById('editor-file-path');
      if (pathEl) pathEl.innerHTML = '';
      var actionsEl = document.getElementById('editor-actions');
      if (actionsEl) actionsEl.innerHTML = '';
      updateChangedCount();
    });
  }

  function findFileInSnapshot(path) {
    var sections = [
      {section: 'config', list: 'files'},
      {section: 'containers', list: 'quadlet_units'},
      {section: 'services', list: 'drop_ins'},
    ];
    for (var i = 0; i < sections.length; i++) {
      var s = sections[i];
      var items = (snapshot[s.section] && snapshot[s.section][s.list]) || [];
      for (var j = 0; j < items.length; j++) {
        if (items[j].path === path) return {section: s.section, list: s.list, index: j};
      }
    }
    return null;
  }

  function editorSaveAll() {
    if (editorState.currentFile && editorState.editMode) {
      editorState.dirtyFiles.set(editorState.currentFile.path, getEditorContent());
    }
    editorState.dirtyFiles.forEach(function(content, path) {
      var loc = findFileInSnapshot(path);
      if (loc) {
        snapshot[loc.section][loc.list][loc.index].content = content;
        editorState.savedFiles.add(path);
      }
    });
    editorState.dirtyFiles.clear();
    updateEditToolbar();
    updateStateLabels();
    updateChangedCount();
  }

  function escapeHtml(s) {
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function getEditorContent() {
    if (editorState.cmView && window.CMEditor) {
      return CMEditor.getContent(editorState.cmView);
    }
    var ta = document.getElementById('editor-textarea-fallback');
    return ta ? ta.value : '';
  }

  function isOperatorCreated(path) {
    var checks = [
      {section: 'config', list: 'files'},
      {section: 'containers', list: 'quadlet_units'},
      {section: 'services', list: 'drop_ins'},
    ];
    for (var i = 0; i < checks.length; i++) {
      var c = checks[i];
      var origItems = (originalSnapshot[c.section] && originalSnapshot[c.section][c.list]) || [];
      if (origItems.some(function(item) { return item.path === path; })) return false;
    }
    return true;
  }

  function getStateLabel(path) {
    if (editorState.dirtyFiles.has(path)) {
      return '<span class="pf-v6-c-label pf-m-compact pf-m-danger"><span class="pf-v6-c-label__content">unsaved</span></span>';
    }
    if (editorState.savedFiles.has(path)) {
      return '<span class="pf-v6-c-label pf-m-compact pf-m-info"><span class="pf-v6-c-label__content">not rendered</span></span>';
    }
    return '';
  }

  function updateStateLabels() {
    document.querySelectorAll('button.pf-v6-c-tree-view__node[data-path]').forEach(function(btn) {
      var path = btn.dataset.path;
      var labelEl = btn.querySelector('.editor-state-label');
      if (labelEl) labelEl.innerHTML = getStateLabel(path);
    });
  }

  function updateChangedCount() {
    var countEl = document.getElementById('editor-changed-count');
    if (countEl) countEl.textContent = editorState.savedFiles.size;
    var reRenderBtn = document.getElementById('btn-re-render');
    if (reRenderBtn) reRenderBtn.disabled = (editorState.savedFiles.size === 0);
  }

  window.navigateToEditor = function(linkEl) {
    var section = linkEl.dataset.section;
    var list = linkEl.dataset.list;
    var index = parseInt(linkEl.dataset.index, 10);
    var path = linkEl.dataset.path;
    if (typeof show === 'function') show('output_files');
    selectFile(section, list, index, path);
  };

  // --- New File Modal ---
  var newFileBtn = document.getElementById('btn-new-file');
  if (newFileBtn) {
    newFileBtn.addEventListener('click', function() {
      var modal = document.getElementById('new-file-modal');
      if (modal) { modal.style.display = ''; updateNewFileForm(); }
    });
  }

  window.closeNewFileModal = function() {
    var modal = document.getElementById('new-file-modal');
    if (modal) modal.style.display = 'none';
  };

  window.updateNewFileForm = function() {
    var type = (document.querySelector('input[name="new-file-type"]:checked') || {}).value || 'config';
    var cfFields = document.getElementById('nf-config-fields');
    var qFields = document.getElementById('nf-quadlet-fields');
    var dFields = document.getElementById('nf-dropin-fields');
    if (cfFields) cfFields.style.display = type === 'config' ? '' : 'none';
    if (qFields) qFields.style.display = type === 'quadlet' ? '' : 'none';
    if (dFields) dFields.style.display = type === 'dropin' ? '' : 'none';
    updateNewFilePath();
    validateNewFileForm();
  };

  window.updateNewFilePath = function() {
    var type = (document.querySelector('input[name="new-file-type"]:checked') || {}).value || 'config';
    if (type === 'quadlet') {
      var scope = (document.getElementById('nf-quadlet-scope') || {}).value || 'system';
      var name = (document.getElementById('nf-quadlet-name') || {}).value || 'unit.container';
      var base = scope === 'system' ? '/etc/containers/systemd/' : '/home/' + scope + '/.config/containers/systemd/';
      var preview = document.getElementById('nf-quadlet-path-preview');
      if (preview) preview.innerHTML = escapeHtml(base) + '<strong>' + escapeHtml(name) + '</strong>';
    } else if (type === 'dropin') {
      var svc = (document.getElementById('nf-dropin-service') || {}).value || '';
      var fname = (document.getElementById('nf-dropin-filename') || {}).value || 'override.conf';
      var preview = document.getElementById('nf-dropin-path-preview');
      if (preview) preview.innerHTML = '/etc/systemd/system/<strong>' + escapeHtml(svc) + '</strong>.d/<strong>' + escapeHtml(fname) + '</strong>';
    }
  };

  window.validateNewFileForm = function() {
    var type = (document.querySelector('input[name="new-file-type"]:checked') || {}).value || 'config';
    var valid = true;
    var quadletExts = ['.container', '.volume', '.network', '.kube', '.image'];

    if (type === 'config') {
      var path = ((document.getElementById('nf-config-path') || {}).value || '').trim();
      var errEl = document.getElementById('nf-config-error');
      if (!path) { valid = false; if (errEl) errEl.style.display = 'none'; }
      else if (!path.startsWith('/')) { valid = false; if (errEl) { errEl.textContent = 'Path must be absolute (start with /).'; errEl.style.display = ''; } }
      else if (findFileInSnapshot(path)) { valid = false; if (errEl) { errEl.textContent = 'File already exists.'; errEl.style.display = ''; } }
      else { if (errEl) errEl.style.display = 'none'; }
    } else if (type === 'quadlet') {
      var name = ((document.getElementById('nf-quadlet-name') || {}).value || '').trim();
      var errEl = document.getElementById('nf-quadlet-error');
      if (!name) { valid = false; if (errEl) errEl.style.display = 'none'; }
      else if (!quadletExts.some(function(ext) { return name.endsWith(ext); })) {
        valid = false; if (errEl) { errEl.textContent = 'Must end with ' + quadletExts.join(', '); errEl.style.display = ''; }
      } else { if (errEl) errEl.style.display = 'none'; }
    } else if (type === 'dropin') {
      var fname = ((document.getElementById('nf-dropin-filename') || {}).value || '').trim();
      var errEl = document.getElementById('nf-dropin-error');
      if (!fname) { valid = false; if (errEl) errEl.style.display = 'none'; }
      else if (!fname.endsWith('.conf')) { valid = false; if (errEl) { errEl.textContent = 'Must end with .conf'; errEl.style.display = ''; } }
      else { if (errEl) errEl.style.display = 'none'; }
    }

    var createBtn = document.getElementById('btn-create-file');
    if (createBtn) createBtn.disabled = !valid;
    return valid;
  };

  window.createNewFile = function() {
    if (!validateNewFileForm()) return;
    var type = (document.querySelector('input[name="new-file-type"]:checked') || {}).value || 'config';
    var entry, section, list, path;

    if (type === 'config') {
      path = (document.getElementById('nf-config-path').value || '').trim();
      entry = {path: path, kind: 'UNOWNED', content: '', include: true, fleet: null, rpm_va_flags: null, package: null, diff_against_rpm: null};
      section = 'config'; list = 'files';
    } else if (type === 'quadlet') {
      var scope = (document.getElementById('nf-quadlet-scope') || {}).value || 'system';
      var name = (document.getElementById('nf-quadlet-name').value || '').trim();
      var base = scope === 'system' ? '/etc/containers/systemd/' : '/home/' + scope + '/.config/containers/systemd/';
      path = base + name;
      entry = {path: path, name: name, content: '', image: '', include: true, fleet: null};
      section = 'containers'; list = 'quadlet_units';
    } else if (type === 'dropin') {
      var svc = (document.getElementById('nf-dropin-service') || {}).value || '';
      var fname = (document.getElementById('nf-dropin-filename').value || '').trim();
      path = 'etc/systemd/system/' + svc + '.d/' + fname;
      entry = {path: path, unit: svc, content: '', include: true, fleet: null};
      section = 'services'; list = 'drop_ins';
    }

    if (!snapshot[section]) snapshot[section] = {};
    if (!snapshot[section][list]) snapshot[section][list] = [];
    snapshot[section][list].push(entry);

    closeNewFileModal();
    buildTree();
    var index = snapshot[section][list].length - 1;
    selectFile(section, list, index, path);
    enterEditMode();
  };

  // --- Re-render from editor ---
  var reRenderBtn = document.getElementById('btn-re-render');
  if (reRenderBtn) {
    reRenderBtn.addEventListener('click', function() {
      editorSaveAll();
      reRenderBtn.textContent = 'Re-rendering\u2026';
      reRenderBtn.disabled = true;
      var sliderEl = document.getElementById('prevalence-slider');
      if (snapshot.meta && snapshot.meta.fleet && sliderEl) {
        snapshot.meta.fleet.min_prevalence = parseInt(sliderEl.value, 10);
      }
      fetch(window.location.origin + '/api/re-render', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({snapshot: snapshot, original: originalSnapshot}),
      }).then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.text();
      }).then(function(html) {
        document.open();
        document.write(html);
        document.close();
      }).catch(function(err) {
        reRenderBtn.innerHTML = 'Re-render (<span id="editor-changed-count">' + editorState.savedFiles.size + '</span> files changed)';
        reRenderBtn.disabled = false;
        showEditorError(err.message);
      });
    });
  }

  function toggleVim() {
    if (!editorState.cmView || !window.CMEditor || !window.CMEditor.enableVim) return;
    var isOn = localStorage.getItem('yoinkc-vim-mode') === 'on';
    if (isOn) {
      CMEditor.disableVim(editorState.cmView);
      localStorage.setItem('yoinkc-vim-mode', 'off');
    } else {
      CMEditor.enableVim(editorState.cmView);
      localStorage.setItem('yoinkc-vim-mode', 'on');
    }
    updateEditToolbar();
  }

  function showEditorError(message) {
    var banner = document.getElementById('editor-error-banner');
    var msgEl = document.getElementById('editor-error-message');
    if (banner) { banner.style.display = ''; }
    if (msgEl) { msgEl.textContent = message; }
  }

  window.dismissEditorError = function() {
    var banner = document.getElementById('editor-error-banner');
    if (banner) banner.style.display = 'none';
  };

  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 's' && editorState.editMode) {
      e.preventDefault();
      editorSave();
    }
  });

  if (typeof refineMode !== 'undefined' && refineMode) {
    buildTree();
  }
})();
</script>
{% endif %}
