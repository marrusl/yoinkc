{% from "report/_macros.html.j2" import section, fleet_cell, card_toggle, card_toolbar with context -%}
{# ── Config ──────────────────────────────────────────────────────────────── #}
{% call section("config", "Configuration files", triageable=true) %}
  {%- if snapshot.config and snapshot.config.files %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-config-files", "Configuration Files") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-config-files">
    {%- set config_count = config_variant_groups|length if (fleet_meta and config_variant_groups) else config_files_rendered|length %}
    {{ card_toolbar("card-config-items", config_count, "Config files") }}
    <div class="pf-v6-c-card__body" id="card-config-items">
  <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check pf-m-fit-content" scope="col"></th>{% if refine_mode %}<th class="pf-m-fit-content" scope="col"></th>{% endif %}<th scope="col">Path</th><th class="pf-m-fit-content" scope="col">Kind</th><th class="pf-m-fit-content" scope="col">Category</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
  {% if fleet_meta and config_variant_groups %}
    {%- for path, variants in config_variant_groups.items() %}
    {%- if variants | length > 1 %}
      {%- set primary = variants[0] %}
      {%- set group_has_selected = variants | selectattr('item.include', 'equalto', true) | list | length > 0 %}
      {%- set sorted_variants = variants | sort(attribute='item.fleet.count', reverse=true) if variants[0].item.fleet else variants %}
      {%- set is_tied = (not group_has_selected) and (variants | length >= 2) and sorted_variants[0].item.fleet and sorted_variants[1].item.fleet and (sorted_variants[0].item.fleet.count == sorted_variants[1].item.fleet.count) %}
      <tr class="fleet-variant-group{% if not primary.item.include %} excluded{% endif %}{% if is_tied %} variant-tied{% endif %}"
          data-search-text="{{ path }}"
          data-snap-section="config" data-snap-list="files"
          data-snap-index="{{ primary.item.snap_index }}">
        <td class="pf-v6-c-table__check">
          <label class="pf-v6-c-switch include-toggle-wrap">
            <input type="checkbox" class="pf-v6-c-switch__input include-toggle"
                   {{ 'checked' if primary.item.include else '' }}/>
            <span class="pf-v6-c-switch__toggle"></span>
          </label>
        </td>
        {% if refine_mode %}<td></td>{% endif %}
        <td>
          <code>{{ path }}</code>
          <span class="pf-v6-c-label pf-m-compact pf-m-outline fleet-variant-toggle"
                tabindex="0" role="button" aria-label="Toggle variants"
                aria-expanded="false">
            <span class="pf-v6-c-label__content">{{ variants | length }} variants</span>
          </span>
          {% if is_tied %}
          <span class="variant-tie-badge"><span class="tie-icon">&#x26A0;</span> tied &mdash; compare &amp; choose</span>
          {% elif group_has_selected %}
          {# Show auto-selected badge when there's a winner (not tied) and multiple variants #}
          <span class="variant-auto-badge">auto-selected</span>
          {% endif %}
        </td>
        <td></td><td></td>
        {{ fleet_cell(primary.item) }}
      </tr>
      <tr class="fleet-variant-children">
        <td colspan="{{ 5 + (1 if refine_mode else 0) }}">
          <table class="pf-v6-c-table pf-m-compact fleet-variant-table">
            {%- for v in variants %}
            <tr{% if not v.item.include %} class="excluded"{% endif %}
                data-snap-section="config" data-snap-list="files"
                data-snap-index="{{ v.item.snap_index }}"
                data-variant-group="{{ path }}">
              <td class="pf-v6-c-table__check">
                <label class="pf-v6-c-switch include-toggle-wrap">
                  <input type="checkbox" class="pf-v6-c-switch__input include-toggle"
                         {{ 'checked' if v.item.include else '' }}/>
                  <span class="pf-v6-c-switch__toggle"></span>
                </label>
              </td>
              {% if refine_mode %}<td><button class="pf-v6-c-button pf-m-plain editor-icon" title="{% if v.item.include %}Edit in editor{% else %}View in editor (read-only){% endif %}" data-section="config" data-list="files" data-index="{{ v.item.snap_index }}" data-path="{{ path }}" onclick="navigateToEditor(this)">✏️</button></td>{% endif %}
              <td><code>{{ path }}</code> <span class="variant-index">(variant {{ loop.index }})</span></td>
              <td>{{ v.item.kind }}{% if v.item.flags and ('M' in v.item.flags or 'U' in v.item.flags or 'G' in v.item.flags) %} <span class="pf-v6-c-label pf-m-compact pf-m-gold"><span class="pf-v6-c-label__content">permissions</span></span>{% endif %}</td>
              <td>{{ v.item.category | replace('_', ' ') | title }}</td>
              {{ fleet_cell(v.item) }}
              <td class="variant-action-cell">
                {% if v.item.include %}
                  <span class="variant-selected-label">selected</span>
                {% elif group_has_selected %}
                  <button class="pf-v6-c-button pf-m-link pf-m-small variant-compare-btn">Compare</button>
                {% else %}
                  <button class="pf-v6-c-button pf-m-link pf-m-small variant-display-btn">Display</button>
                {% endif %}
              </td>
            </tr>
            {%- endfor %}
          </table>
        </td>
      </tr>
    {%- else %}
      {%- set f = variants[0].item %}
      <tr{% if not f.include %} class="excluded"{% endif %} data-search-text="{{ f.path }}" data-snap-section="config" data-snap-list="files" data-snap-index="{{ f.snap_index }}">
        <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if f.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
        {% if refine_mode %}<td><button class="pf-v6-c-button pf-m-plain editor-icon" title="Edit in editor" data-section="config" data-list="files" data-index="{{ f.snap_index }}" data-path="{{ f.path }}" onclick="navigateToEditor(this)">✏️</button></td>{% endif %}
        <td><code>{{ f.path }}</code></td>
        <td>{{ f.kind }}{% if f.flags and ('M' in f.flags or 'U' in f.flags or 'G' in f.flags) %} <span class="pf-v6-c-label pf-m-compact pf-m-gold"><span class="pf-v6-c-label__content">permissions</span></span>{% endif %}</td>
        <td>{{ f.category | replace('_', ' ') | title }}</td>
        {{ fleet_cell(f) }}
      </tr>
    {%- endif %}
    {%- endfor %}
  {% else %}
    {%- for item in config_files_rendered %}
    <tr{% if not item.include %} class="excluded"{% endif %} data-search-text="{{ item.path }}" data-snap-section="config" data-snap-list="files" data-snap-index="{{ item.snap_index }}">
      <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if item.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
      {% if refine_mode %}<td><button class="pf-v6-c-button pf-m-plain editor-icon" title="Edit in editor" data-section="config" data-list="files" data-index="{{ item.snap_index }}" data-path="{{ item.path }}" onclick="navigateToEditor(this)">✏️</button></td>{% endif %}
      <td><code>{{ item.path }}</code></td>
      <td>{{ item.kind }}{% if item.flags and ('M' in item.flags or 'U' in item.flags or 'G' in item.flags) %} <span class="pf-v6-c-label pf-m-compact pf-m-gold"><span class="pf-v6-c-label__content">permissions</span></span>{% endif %}</td>
      <td>{{ item.category | replace('_', ' ') | title }}</td>
      {{ fleet_cell(item) }}
    </tr>
    {%- endfor %}
  {% endif %}
  </tbody></table>
  </div></div></div>
  {%- else %}
  <p>No config files.</p>
  {%- endif %}
{% endcall %}

