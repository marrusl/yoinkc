{% from "report/_macros.html.j2" import section, fleet_cell with context -%}
{# ── Config ──────────────────────────────────────────────────────────────── #}
{% call section("config", "Configuration files") %}
  {%- if snapshot.config and snapshot.config.files %}
  <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Path</th><th scope="col">Kind</th><th scope="col">rpm -Va flags</th><th scope="col">Diff</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
  {% if fleet_meta and config_variant_groups %}
    {%- for path, variants in config_variant_groups.items() %}
    {%- if variants | length > 1 %}
      {%- set primary = variants[0] %}
      <tr class="fleet-variant-group{% if not primary.item.include %} excluded{% endif %}"
          data-snap-section="config" data-snap-list="files"
          data-snap-index="{{ primary.item.snap_index }}">
        <td class="pf-v6-c-table__check">
          <span class="pf-v6-c-check pf-m-standalone include-cb-wrap">
            <input type="checkbox" class="pf-v6-c-check__input include-cb"
                   {{ 'checked' if primary.item.include else '' }}/>
          </span>
        </td>
        <td>
          <code>{{ path }}</code>
          <span class="pf-v6-c-label pf-m-compact pf-m-outline fleet-variant-toggle"
                style="margin-left: 8px; cursor: pointer;">
            <span class="pf-v6-c-label__content">{{ variants | length }} variants</span>
          </span>
        </td>
        <td></td><td></td><td></td>
        {{ fleet_cell(primary.item) }}
      </tr>
      <tr class="fleet-variant-children">
        <td colspan="10">
          <table class="pf-v6-c-table pf-m-compact" style="margin: 0;">
            {%- for v in variants %}
            <tr{% if not v.item.include %} class="excluded"{% endif %}
                data-snap-section="config" data-snap-list="files"
                data-snap-index="{{ v.item.snap_index }}">
              <td class="pf-v6-c-table__check">
                <span class="pf-v6-c-check pf-m-standalone include-cb-wrap">
                  <input type="checkbox" class="pf-v6-c-check__input include-cb"
                         {{ 'checked' if v.item.include else '' }}/>
                </span>
              </td>
              <td><code>{{ path }}</code> <span style="color: var(--pf-v6-global--Color--200);">(variant {{ loop.index }})</span></td>
              {{ fleet_cell(v.item) }}
              <td>
                {% if v.item is mapping and v.item.diff_html %}
                  {{ v.item.diff_html|safe }}
                {% endif %}
              </td>
            </tr>
            {%- endfor %}
          </table>
        </td>
      </tr>
    {%- else %}
      {%- set f = variants[0].item %}
      <tr{% if not f.include %} class="excluded"{% endif %} data-snap-section="config" data-snap-list="files" data-snap-index="{{ f.snap_index }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if f.include else '' }}/></span></td>
        <td><code>{{ f.path }}</code>{% if refine_mode %} <a href="#" class="edit-in-editor-link" data-section="config" data-list="files" data-index="{{ f.snap_index }}" data-path="{{ f.path }}" onclick="navigateToEditor(this); return false;" style="margin-left:8px;">View &amp; edit in editor &rarr;</a>{% endif %}</td>
        <td>{{ f.kind }}</td>
        <td>{% if f.flags %}<code>{{ f.flags }}</code>{% endif %}</td>
        <td>{{ f.diff_html|safe }}</td>
        {{ fleet_cell(f) }}
      </tr>
    {%- endif %}
    {%- endfor %}
  {% else %}
    {%- for item in config_files_rendered %}
    <tr{% if not item.include %} class="excluded"{% endif %} data-snap-section="config" data-snap-list="files" data-snap-index="{{ item.snap_index }}">
      <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if item.include else '' }}/></span></td>
      <td><code>{{ item.path }}</code>{% if refine_mode %} <a href="#" class="edit-in-editor-link" data-section="config" data-list="files" data-index="{{ item.snap_index }}" data-path="{{ item.path }}" onclick="navigateToEditor(this); return false;" style="margin-left:8px;">View &amp; edit in editor &rarr;</a>{% endif %}</td>
      <td>{{ item.kind }}</td>
      <td>{% if item.flags %}<code>{{ item.flags }}</code>{% endif %}</td>
      <td>{{ item.diff_html|safe }}</td>
      {{ fleet_cell(item) }}
    </tr>
    {%- endfor %}
  {% endif %}
  </tbody></table>
  {%- else %}
  <p>No config files.</p>
  {%- endif %}
{% endcall %}

