{# ── Section wrapper macro ─────────────────────────────────────────────── #}
{% macro section(id, title, visible=false, triageable=false) -%}
<div id="section-{{ id }}" class="section{% if visible %} visible{% endif %}">
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header">
      <div class="pf-v6-c-card__title"><h2>{{ title }}</h2></div>
    </div>
    <div class="pf-v6-c-card__body">
    {%- if triageable %}
    <div class="actions-end-row">
      <button class="pf-v6-c-button pf-m-secondary pf-m-small" onclick="toggleReviewed('{{ id }}', this)" data-tab-id="{{ id }}">Mark as reviewed</button>
    </div>
    {%- endif %}
    {{- caller() }}
    </div>
  </div>
</div>
{%- endmacro %}

{# ── Fleet prevalence cell macro ─────────────────────────────────────── #}
{% macro fleet_cell(item) %}
{% if fleet_meta %}
<td class="fleet-prevalence">
  {% if item.fleet %}
  <div class="fleet-bar" tabindex="0" role="button"
       aria-label="{{ item.fleet.count }} of {{ item.fleet.total }} hosts"
       data-count="{{ item.fleet.count }}"
       data-total="{{ item.fleet.total }}"
       data-hosts="{{ item.fleet.hosts | join(', ') }}"
       data-host-titles="{% for host in item.fleet.hosts %}{{ host_title_map.get(host, host) }}{% if not loop.last %}, {% endif %}{% endfor %}"
       title="{% for host in item.fleet.hosts %}{{ host_title_map.get(host, host) }}{% if not loop.last %}, {% endif %}{% endfor %}">
    <div class="fleet-bar-track">
      <div class="fleet-bar-fill {{ item.fleet | fleet_color }}"
           style="width: {{ (item.fleet.count * 100 // item.fleet.total) if item.fleet.total > 0 else 100 }}%"></div>
    </div>
    <span class="fleet-bar-label">{{ item.fleet.count }}/{{ item.fleet.total }}</span>
  </div>
  {% endif %}
</td>
{% endif %}
{% endmacro %}

{# ── Expandable card toggle button ──────────────────────────────────────── #}
{% macro card_toggle(content_id, title) -%}
<button class="pf-v6-c-expandable-section__toggle" aria-expanded="true" aria-controls="{{ content_id }}" onclick="toggleCard(this)">
  <span class="pf-v6-c-expandable-section__toggle-icon"><svg aria-hidden="true" fill="currentColor" viewBox="0 0 256 512" height="1em" width="1em"><path d="M224.3 273l-136 136c-9.4 9.4-24.6 9.4-33.9 0l-22.6-22.6c-9.4-9.4-9.4-24.6 0-33.9l96.4-96.4-96.4-96.4c-9.4-9.4-9.4-24.6 0-33.9L54.3 103c9.4-9.4 24.6-9.4 33.9 0l136 136c9.5 9.4 9.5 24.6.1 34z"/></svg></span>
  <span class="pf-v6-c-expandable-section__toggle-text">{{ title }}</span>
</button>
{%- endmacro %}

{# ── Simple data table macro ────────────────────────────────────────────── #}
{% macro data_table(headers) %}
<table class="pf-v6-c-table"><thead><tr>
  {%- for h in headers %}<th scope="col">{{ h }}</th>{% endfor -%}
</tr></thead><tbody>
{{ caller() }}
</tbody></table>
{% endmacro %}
