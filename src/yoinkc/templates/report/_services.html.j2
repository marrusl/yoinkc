{% from "report/_macros.html.j2" import section, fleet_cell with context -%}
{# ── Services ────────────────────────────────────────────────────────────── #}
{% call section("services", "Services") %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Service State Changes</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- if snapshot.services and snapshot.services.state_changes | selectattr('action', 'ne', 'unchanged') | list %}
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check pf-m-fit-content" scope="col"></th><th scope="col">Unit</th><th class="pf-m-fit-content" scope="col">Current</th><th class="pf-m-fit-content" scope="col">Default</th><th class="pf-m-fit-content" scope="col">Action</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
      {%- for s in snapshot.services.state_changes %}
      {%- if s.action != 'unchanged' %}
      <tr{% if not s.include %} class="excluded"{% endif %} data-snap-section="services" data-snap-list="state_changes" data-snap-index="{{ loop.index0 }}"><td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if s.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td><td>{{ s.unit }}</td><td>{{ s.current_state }}</td><td>{{ s.default_state }}</td><td>{{ s.action }}</td>{{ fleet_cell(s) }}</tr>
      {%- endif %}
      {%- endfor %}
    </tbody></table>
    {%- else %}
    <p>No service changes.</p>
    {%- endif %}
    </div>
  </div>

  {%- if snapshot.services and snapshot.services.drop_ins %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Drop-in Overrides ({{ snapshot.services.drop_ins|length }})</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check pf-m-fit-content" scope="col"></th><th scope="col">Parent unit</th><th scope="col">Drop-in path</th><th scope="col">Content</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
    {% if fleet_meta and dropin_variant_groups %}
      {%- for path, variants in dropin_variant_groups.items() %}
      {%- if variants | length > 1 %}
        {%- set primary = variants[0] %}
        <tr class="fleet-variant-group{% if not primary.item.include %} excluded{% endif %}"
            data-snap-section="services" data-snap-list="drop_ins"
            data-snap-index="{{ primary.snap_index }}">
          <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if primary.item.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
          <td colspan="2">
            <code>{{ path }}</code>
            <span class="pf-v6-c-label pf-m-compact pf-m-outline fleet-variant-toggle" style="margin-left: 8px; cursor: pointer;">
              <span class="pf-v6-c-label__content">{{ variants | length }} variants</span>
            </span>
          </td>
          <td></td>
          {{ fleet_cell(primary.item) }}
        </tr>
        <tr class="fleet-variant-children">
          <td colspan="10">
            <table class="pf-v6-c-table pf-m-compact" style="margin: 0;">
              {%- for v in variants %}
              <tr{% if not v.item.include %} class="excluded"{% endif %}
                  data-snap-section="services" data-snap-list="drop_ins"
                  data-snap-index="{{ v.snap_index }}"
                  data-variant-group="{{ path }}">
                <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if v.item.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
                <td><code>{{ path }}</code> <span style="color: var(--pf-v6-global--Color--200);">(variant {{ loop.index }})</span></td>
                {{ fleet_cell(v.item) }}
                <td class="variant-action-cell">
                  {% if v.item.include %}
                    <span style="font-size:0.75rem;color:var(--pf-t--global--text--color--subtle);">selected</span>
                  {% else %}
                    <button class="pf-v6-c-button pf-m-link pf-m-small variant-compare-btn">Compare</button>
                  {% endif %}
                </td>
              </tr>
              {%- endfor %}
            </table>
          </td>
        </tr>
      {%- else %}
        {%- set d = variants[0].item %}
        <tr{% if not d.include %} class="excluded"{% endif %} data-snap-section="services" data-snap-list="drop_ins" data-snap-index="{{ variants[0].snap_index }}">
          <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if d.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
          <td>{{ d.unit }}</td>
          <td><code>{{ d.path }}</code></td>
          <td>{%- if d.content.strip() %}{% if refine_mode %}<a href="#" class="edit-in-editor-link" data-section="services" data-list="drop_ins" data-index="{{ variants[0].snap_index }}" data-path="{{ d.path }}" onclick="navigateToEditor(this); return false;">View &amp; edit in editor &rarr;</a>{% else %}<details><summary>show</summary><pre class="content-preview">{{ d.content }}</pre></details>{% endif %}{%- endif %}</td>
          {{ fleet_cell(d) }}
        </tr>
      {%- endif %}
      {%- endfor %}
    {% else %}
      {%- for d in snapshot.services.drop_ins %}
      <tr{% if not d.include %} class="excluded"{% endif %} data-snap-section="services" data-snap-list="drop_ins" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if d.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
        <td>{{ d.unit }}</td>
        <td><code>{{ d.path }}</code></td>
        <td>
          {%- if d.content.strip() %}
          {% if refine_mode %}
          <a href="#" class="edit-in-editor-link" data-section="services" data-list="drop_ins" data-index="{{ loop.index0 }}" data-path="{{ d.path }}" onclick="navigateToEditor(this); return false;">View &amp; edit in editor &rarr;</a>
          {% else %}
          <details><summary>show</summary>
            <pre class="content-preview">{{ d.content }}</pre>
          </details>
          {% endif %}
          {%- endif %}
        </td>
        {{ fleet_cell(d) }}
      </tr>
      {%- endfor %}
    {% endif %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}
{% endcall %}

