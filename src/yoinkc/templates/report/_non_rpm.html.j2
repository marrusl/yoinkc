{% from "report/_macros.html.j2" import section, fleet_cell, card_toggle, card_toolbar with context -%}
{# ── Non-RPM software ────────────────────────────────────────────────────── #}
{% call section("non_rpm", "Non-RPM software", triageable=true) %}
  {%- set nr = snapshot.non_rpm_software %}
  {%- if nr and nr.items %}
  {%- set nd = non_rpm_data %}

  {%- if nd.elf %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-nr-elf", "Compiled Binaries") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-nr-elf">
    {{ card_toolbar("card-nr-elf-items", nd.elf|length, "Binaries") }}
    <div class="pf-v6-c-card__body" id="card-nr-elf-items">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check pf-m-fit-content" scope="col"></th><th scope="col">Path</th><th class="pf-m-fit-content" scope="col">Language</th><th class="pf-m-fit-content" scope="col">Linking</th><th scope="col">Shared Libraries</th></tr></thead><tbody>
      {%- for i in nd.elf %}
      {%- set lang = i.lang %}
      {%- set lang_lbl = {'go': 'pf-m-teal', 'rust': 'pf-m-orange', 'c/c++': 'pf-m-purple'} %}
      {%- set linking = 'static' if i.static else 'dynamic' %}
      {%- set nr_idx = namespace(val=-1) %}
      {%- for item in nr.items %}{% if item.path == i.path %}{% set nr_idx.val = loop.index0 %}{% endif %}{%- endfor %}
      <tr{% if not i.include %} class="excluded"{% endif %} data-search-text="{{ i.path }}" data-snap-section="non_rpm_software" data-snap-list="items" data-snap-index="{{ nr_idx.val }}">
        <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if i.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
        <td><code>{{ i.path }}</code></td>
        <td><span class="pf-v6-c-label pf-m-filled {{ lang_lbl.get(lang, 'pf-m-grey') }}">{{ lang }}</span></td>
        <td><span class="pf-v6-c-label pf-m-filled {{ 'pf-m-green' if i.static else 'pf-m-orange' }}">{{ linking }}</span></td>
        <td class="text-sm">{{ i.shared_libs[:5]|join(', ') or '' }}</td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div></div>
  </div>
  {%- endif %}

  {%- if nd.venv %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-nr-venv", "Python Virtual Environments") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-nr-venv"><div class="pf-v6-c-card__body">
    {%- for v in nd.venv %}
    {%- set ssp = v.system_site_packages %}
    <div class="mt-md venv-info-row">
      <code>{{ v.path }}</code>
      {%- if ssp %} <span class="pf-v6-c-label pf-m-filled pf-m-red">system-site-packages</span>
      {%- else %} <span class="pf-v6-c-label pf-m-filled pf-m-green">isolated</span>
      {%- endif %}
    </div>
    {%- set pkgs = v.packages %}
    {%- if pkgs %}
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Package</th><th scope="col">Version</th></tr></thead><tbody>
      {%- for p in pkgs[:20] %}
      <tr><td>{{ p.name }}</td><td>{{ p.version }}</td></tr>
      {%- endfor %}
      {%- if pkgs|length > 20 %}
      <tr><td colspan="2"><em>+{{ pkgs|length - 20 }} more</em></td></tr>
      {%- endif %}
    </tbody></table>
    {%- else %}
    <p>No packages found.</p>
    {%- endif %}
    {%- endfor %}
    </div></div>
  </div>
  {%- endif %}

  {%- if nd.git %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-nr-git", "Git Repositories") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-nr-git"><div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Path</th><th scope="col">Remote</th><th scope="col">Branch</th><th scope="col">Commit</th></tr></thead><tbody>
      {%- for i in nd.git %}
      <tr>
        <td><code>{{ i.path }}</code></td>
        <td><code>{{ i.git_remote }}</code></td>
        <td>{{ i.git_branch }}</td>
        <td><code>{{ i.git_commit[:12] }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div></div>
  </div>
  {%- endif %}

  {%- if nd.pip %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-nr-pip", "System Pip Packages") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-nr-pip">
    {{ card_toolbar("card-nr-pip-items", nd.pip|length, "Pip packages") }}
    <div class="pf-v6-c-card__body" id="card-nr-pip-items">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check pf-m-fit-content" scope="col"></th><th scope="col">Package</th><th class="pf-m-fit-content" scope="col">Version</th><th scope="col">Path</th></tr></thead><tbody>
      {%- for i in nd.pip[:20] %}
      {%- set nr_idx = namespace(val=-1) %}
      {%- for item in nr.items %}{% if item.path == i.path and item.name == i.name %}{% set nr_idx.val = loop.index0 %}{% endif %}{%- endfor %}
      <tr{% if not i.include %} class="excluded"{% endif %} data-search-text="{{ i.name }}" data-snap-section="non_rpm_software" data-snap-list="items" data-snap-index="{{ nr_idx.val }}">
        <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if i.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
        <td>{{ i.name }}</td>
        <td>{{ i.version }}</td>
        <td><code>{{ i.path }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div></div>
  </div>
  {%- endif %}

  {%- if nd.other %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-nr-other", "Other Items") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-nr-other"><div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Path</th><th scope="col">Confidence</th><th scope="col">Method</th></tr></thead><tbody>
      {%- for i in nd.other[:20] %}
      <tr>
        <td><code>{{ i.path or i.name }}</code></td>
        <td>{{ i.confidence }}</td>
        <td>{{ i.method }}</td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div></div>
  </div>
  {%- endif %}

  {%- if nr and nr.env_files %}
  <div class="pf-v6-c-card pf-v6-c-expandable-section pf-m-expanded">
    <div class="pf-v6-c-card__header">{{ card_toggle("card-nr-env-files", "Dotenv / Secret Files") }}</div>
    <div class="pf-v6-c-expandable-section__content" id="card-nr-env-files"><div class="pf-v6-c-card__body">
    <p>These files may contain API keys or passwords. Secrets have been redacted; inject them at deploy time via a secret store or systemd credentials.</p>
    {%- set env_count = env_variant_groups|length if (fleet_meta and env_variant_groups) else nr.env_files|length %}
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check pf-m-fit-content" scope="col"></th><th scope="col">Path</th><th scope="col">Status</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
    {% if fleet_meta and env_variant_groups %}
      {%- for path, variants in env_variant_groups.items() %}
      {%- if variants | length > 1 %}
        {%- set primary = variants[0] %}
        {%- set group_has_selected = variants | selectattr('item.include', 'equalto', true) | list | length > 0 %}
        {%- set is_tied = variants | selectattr('item.tie', 'equalto', true) | list | length > 0 %}
        {%- set tie_winner_variant = variants | selectattr('item.tie_winner', 'equalto', true) | first | default(none) %}
        <tr class="fleet-variant-group{% if not primary.item.include %} excluded{% endif %}{% if is_tied and not tie_winner_variant %} variant-tied{% endif %}"
            data-search-text="{{ path }}"
            data-snap-section="non_rpm_software" data-snap-list="env_files"
            data-snap-index="{{ primary.snap_index }}"
            {% if is_tied %}data-tie="true"{% endif %}
            {% if tie_winner_variant %}data-tie-winner="true"{% endif %}>
          <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if primary.item.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
          <td>
            <code>{{ path }}</code>
            <span class="pf-v6-c-label pf-m-compact pf-m-outline fleet-variant-toggle" tabindex="0" role="button" aria-label="Toggle variants"
                  aria-expanded="false">
              <span class="pf-v6-c-label__content">{{ variants | length }} variants</span>
            </span>
            {% if is_tied and not tie_winner_variant %}
            <span class="variant-tie-badge"><span class="tie-icon">&#x26A0;</span> tied &mdash; compare &amp; choose</span>
            {% elif is_tied and tie_winner_variant %}
            <span class="variant-auto-badge">tie winner ({{ tie_winner_variant.content_hash_short or 'hash' }})</span>
            {% elif group_has_selected %}
            <span class="variant-auto-badge">auto-selected</span>
            {% endif %}
          </td>
          <td>captured &amp; redacted</td>
          {{ fleet_cell(primary.item) }}
        </tr>
        <tr class="fleet-variant-children">
          <td colspan="{{ 4 if fleet_meta else 3 }}">
            <table class="pf-v6-c-table pf-m-compact fleet-variant-table">
              {%- for v in variants %}
              <tr{% if not v.item.include %} class="excluded"{% endif %}
                  data-snap-section="non_rpm_software" data-snap-list="env_files"
                  data-snap-index="{{ v.snap_index }}"
                  data-variant-group="{{ path }}"
                  {% if v.item.tie %}data-tie="true"{% endif %}
                  {% if v.item.tie_winner %}data-tie-winner="true"{% endif %}
                  {% if v.content_hash_short %}data-content-hash="{{ v.content_hash_short }}"{% endif %}>
                <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if v.item.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
                <td><code>{{ v.item.path }}</code> <span class="variant-index">(variant {{ loop.index }})</span>{% if v.item.tie_winner %} <span class="badge" style="background-color: #e67e22; color: #fff;">(auto-selected: tied)</span>{% endif %}</td>
                {{ fleet_cell(v.item) }}
                <td class="variant-action-cell">
                  {% if v.item.include %}
                    <span class="variant-selected-label">selected</span>
                  {% elif group_has_selected %}
                    <button class="pf-v6-c-button pf-m-link pf-m-small variant-compare-btn">Compare</button>
                  {% else %}
                    <button class="pf-v6-c-button pf-m-link pf-m-small variant-display-btn">Display</button>
                  {% endif %}
                </td>
              </tr>
              {%- endfor %}
            </table>
          </td>
        </tr>
      {%- else %}
        {%- set ef = variants[0].item %}
        <tr{% if not ef.include %} class="excluded"{% endif %} data-search-text="{{ ef.path }}" data-snap-section="non_rpm_software" data-snap-list="env_files" data-snap-index="{{ variants[0].snap_index }}">
          <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if ef.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
          <td><code>{{ ef.path }}</code></td>
          <td>captured &amp; redacted</td>
          {{ fleet_cell(ef) }}
        </tr>
      {%- endif %}
      {%- endfor %}
    {% else %}
      {%- for ef in nr.env_files %}
      <tr data-search-text="{{ ef.path }}" data-snap-section="non_rpm_software" data-snap-list="env_files" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><label class="pf-v6-c-switch include-toggle-wrap"><input type="checkbox" class="pf-v6-c-switch__input include-toggle" {{ 'checked' if ef.include else '' }}/><span class="pf-v6-c-switch__toggle"></span></label></td>
        <td><code>{{ ef.path }}</code></td>
        <td>captured &amp; redacted</td>
      </tr>
      {%- endfor %}
    {% endif %}
    </tbody></table>
    </div></div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No non-RPM software.</p>
  {%- endif %}
{% endcall %}

