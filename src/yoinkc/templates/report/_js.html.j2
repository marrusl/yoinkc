<script>
// Apply saved theme immediately so re-rendered pages don't flash
(function(){ var t = localStorage.getItem('yoinkc-theme'); if (t === 'light') document.documentElement.classList.remove('pf-v6-theme-dark'); })();
var snapshot = {{ snapshot_json|safe }};
var originalSnapshot = {{ original_snapshot_json|safe }};
var refineMode = {{ 'true' if refine_mode else 'false' }};

var FOCUSABLE_SELECTOR = 'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

function activateOnKeydown(e) {
  if (e.key === 'Enter' || e.key === ' ') {
    e.preventDefault();
    e.currentTarget.click();
  }
}

function trapFocus(modalElement, closeHandler) {
  var previousFocus = document.activeElement;
  var focusable = modalElement.querySelectorAll(FOCUSABLE_SELECTOR);
  if (focusable.length) focusable[0].focus();

  function onKeydown(e) {
    if (e.key === 'Escape') {
      e.preventDefault();
      if (closeHandler) closeHandler();
      return;
    }
    if (e.key !== 'Tab') return;
    var updated = modalElement.querySelectorAll(FOCUSABLE_SELECTOR);
    if (!updated.length) return;
    var first = updated[0];
    var last = updated[updated.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }
  modalElement.addEventListener('keydown', onKeydown);

  return function releaseTrap() {
    modalElement.removeEventListener('keydown', onKeydown);
    if (previousFocus && previousFocus.focus) previousFocus.focus();
  };
}

(function(){
  var sections = document.querySelectorAll('.section');
  var navLinks = document.querySelectorAll('.pf-v6-c-nav__link[data-tab]');
  var fromPopstate = false;
  var initialLoad = true;
  function show(id) {
    if (!id) return;
    sections.forEach(function(s){ s.classList.remove('visible', 'pf-m-current'); });
    var el = document.getElementById('section-' + id);
    if (el) {
      el.classList.add('visible');
      requestAnimationFrame(function() { el.classList.add('pf-m-current'); });
    }
    navLinks.forEach(function(link){
      var isActive = link.getAttribute('data-tab') === id;
      link.classList.toggle('pf-m-current', isActive);
      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
    if (!fromPopstate) {
      history.pushState({tab: id}, '', '#' + id);
    }
    if (!initialLoad) {
      var reviewBtn = el ? el.querySelector('[data-tab-id="' + id + '"]') : null;
      var focusTarget = reviewBtn || document.getElementById('main-content');
      if (focusTarget) focusTarget.focus();
    }
  }
  window.show = show;
  navLinks.forEach(function(link){
    link.addEventListener('click', function(e){ e.preventDefault(); show(link.getAttribute('data-tab')); });
  });
  window.addEventListener('popstate', function(e) {
    if (e.state && e.state.tab) {
      fromPopstate = true;
      show(e.state.tab);
      fromPopstate = false;
    }
  });
  // On page load: honour a hash URL (bookmarks/shared links), then seed history with replaceState
  (function() {
    var hash = location.hash ? location.hash.slice(1) : '';
    var initialTab = (hash && document.getElementById('section-' + hash)) ? hash : 'summary';
    fromPopstate = true;
    show(initialTab);
    fromPopstate = false;
    history.replaceState({tab: initialTab}, '', '#' + initialTab);
  })();
  initialLoad = false;

  // --- Warning dismiss + badge ---
  var bannerCount = document.getElementById('banner-warning-count');
  var warningBadge = document.getElementById('nav-warning-badge');

  function updateWarningBadge() {
    var total = document.querySelectorAll('#warnings-list .warning-row:not(.dismissed)').length;
    if (bannerCount) bannerCount.textContent = total;
    if (warningBadge) {
      warningBadge.textContent = total;
      warningBadge.classList.toggle('pf-m-unread', total > 0);
      warningBadge.classList.toggle('pf-m-read', total === 0);
    }
  }

  document.querySelectorAll('#warnings-list .warning-row-dismiss').forEach(function(btn){
    btn.addEventListener('click', function(){
      this.closest('.warning-row').classList.add('dismissed');
      updateWarningBadge();
    });
  });
  var dismissAll = document.getElementById('warning-dismiss-all');
  if (dismissAll) {
    dismissAll.addEventListener('click', function(){
      document.querySelectorAll('#warnings-list .warning-row').forEach(function(row){
        row.classList.add('dismissed');
      });
      updateWarningBadge();
    });
  }
  updateWarningBadge();

  var search = document.getElementById('warn-search');
  if (search) {
    search.addEventListener('input', function(){
      var q = (this.value || '').toLowerCase();
      document.querySelectorAll('#warnings-list .warning-row').forEach(function(row){
        var isDismissed = row.classList.contains('dismissed');
        var matches = q === '' || (row.textContent || '').toLowerCase().indexOf(q) >= 0;
        row.style.display = (!isDismissed && matches) ? '' : 'none';
      });
    });
  }
  document.querySelectorAll('.pf-v6-c-tree-view__node:not(.file-entry)').forEach(function(btn){
    btn.addEventListener('click', function(){
      var li = this.closest('.pf-v6-c-tree-view__list-item');
      if (!li) return;
      var expanded = li.classList.toggle('pf-m-expanded');
      li.setAttribute('aria-expanded', expanded);
    });
  });
  document.querySelectorAll('.file-entry').forEach(function(btn){
    btn.addEventListener('click', function(){
      var id = this.getAttribute('data-content-id');
      var path = this.getAttribute('data-path');
      var pathEl = document.getElementById('file-viewer-path');
      var contentEl = document.getElementById('file-viewer-content');
      var src = id ? document.getElementById(id) : null;
      if (pathEl) pathEl.textContent = path || 'Click a file';
      if (contentEl) contentEl.innerHTML = src ? src.innerHTML : '';
      document.querySelectorAll('.file-entry.pf-m-current').forEach(function(n){ n.classList.remove('pf-m-current'); });
      this.classList.add('pf-m-current');
    });
  });

  // --- Interactive item exclusion ---
  var toolbar = document.getElementById('exclude-toolbar');
  var statusTextEl = document.getElementById('toolbar-status-text');
  var toast = document.getElementById('toast');
  var rerenderBtn = document.getElementById('btn-rerender');
  var tarballBtn = document.getElementById('btn-tarball');
  var downloadSnapshotBtn = document.getElementById('btn-download-snapshot');
  var resetBtn = document.getElementById('btn-reset');
  var helperAvailable = false;
  var reRenderEnabled = false;
  var dirty = false;

  var includeBaseline = {};
  var strategyBaseline = {};
  function buildBaseline() {
    includeBaseline = {};
    strategyBaseline = {};
    document.querySelectorAll('.include-toggle').forEach(function(cb) {
      var tr = cb.closest('tr[data-snap-section]') || cb.closest('[data-snap-section]');
      if (!tr) return;
      var section = tr.getAttribute('data-snap-section');
      var list = tr.getAttribute('data-snap-list');
      var idx = tr.getAttribute('data-snap-index');
      if (section && list && idx !== null) {
        includeBaseline[section + '/' + list + '/' + idx] = cb.checked;
      }
    });
    document.querySelectorAll('.strategy-select').forEach(function(sel) {
      var tr = sel.closest('tr[data-snap-section]');
      if (!tr) return;
      var key = tr.getAttribute('data-snap-section') + '/' + tr.getAttribute('data-snap-list') + '/' + tr.getAttribute('data-snap-index');
      strategyBaseline[key] = sel.value;
    });
  }
  function isSnapshotClean() {
    var clean = true;
    document.querySelectorAll('.include-toggle').forEach(function(cb) {
      var tr = cb.closest('tr[data-snap-section]') || cb.closest('[data-snap-section]');
      if (!tr) return;
      var section = tr.getAttribute('data-snap-section');
      var list = tr.getAttribute('data-snap-list');
      var idx = tr.getAttribute('data-snap-index');
      if (section && list && idx !== null) {
        if (cb.checked !== includeBaseline[section + '/' + list + '/' + idx]) {
          clean = false;
        }
      }
    });
    document.querySelectorAll('.strategy-select').forEach(function(sel) {
      var tr = sel.closest('tr[data-snap-section]');
      if (!tr) return;
      var key = tr.getAttribute('data-snap-section') + '/' + tr.getAttribute('data-snap-list') + '/' + tr.getAttribute('data-snap-index');
      if (sel.value !== strategyBaseline[key]) clean = false;
    });
    return clean;
  }
  buildBaseline();

  function setDirty(isDirty) {
    dirty = isDirty;
    if (tarballBtn) tarballBtn.disabled = isDirty;
    // Re-render buttons respect both dirty state AND re-render availability
    var canReRender = isDirty && reRenderEnabled;
    if (rerenderBtn) rerenderBtn.disabled = !canReRender;
    var editorReRenderBtn = document.getElementById('btn-re-render');
    if (editorReRenderBtn) editorReRenderBtn.disabled = !canReRender;
  }

  function showToast(msg, ms) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('visible');
    setTimeout(function(){ toast.classList.remove('visible'); }, ms || 4000);
  }

  function countToggleChanges() {
    var includes = 0;
    var seenIncludeKeys = new Set();
    document.querySelectorAll('.include-toggle').forEach(function(cb) {
      var tr = cb.closest('tr[data-snap-section]') || cb.closest('[data-snap-section]');
      if (!tr) return;
      // Skip fleet variant parent rows — they mirror the first child and share the same snap-index
      if (tr.classList.contains('fleet-variant-group')) return;
      var key = tr.getAttribute('data-snap-section') + '/' + tr.getAttribute('data-snap-list') + '/' + tr.getAttribute('data-snap-index');
      if (seenIncludeKeys.has(key)) return;
      seenIncludeKeys.add(key);
      if (cb.checked !== includeBaseline[key]) includes++;
    });
    var strategies = 0;
    document.querySelectorAll('.strategy-select').forEach(function(sel) {
      var tr = sel.closest('tr[data-snap-section]');
      if (!tr) return;
      var key = tr.getAttribute('data-snap-section') + '/' + tr.getAttribute('data-snap-list') + '/' + tr.getAttribute('data-snap-index');
      if (sel.value !== strategyBaseline[key]) strategies++;
    });
    return { includes: includes, strategies: strategies, total: includes + strategies };
  }
  window.countToggleChanges = countToggleChanges;

  function updateToolbar() {
    var counts = countToggleChanges();
    var n = counts.includes;
    var strategyChanges = counts.strategies;
    var changed = !isSnapshotClean();
    var isHelper = toolbar && toolbar.classList.contains('helper-active');

    if (changed) {
      var parts = [];
      if (n > 0) parts.push(n + ' toggle change' + (n > 1 ? 's' : ''));
      if (strategyChanges > 0) parts.push(strategyChanges + ' strategy change(s)');
      if (parts.length === 0) parts.push('Snapshot modified');
      if (statusTextEl) { statusTextEl.textContent = parts.join(', '); statusTextEl.style.color = ''; }
      if (rerenderBtn) rerenderBtn.disabled = !reRenderEnabled;
      if (downloadSnapshotBtn) downloadSnapshotBtn.disabled = false;
    } else if (isHelper) {
      if (statusTextEl) { statusTextEl.textContent = 'No pending changes'; statusTextEl.style.color = 'var(--pf-t--global--text--color--subtle)'; }
      if (rerenderBtn) rerenderBtn.disabled = true;
      if (downloadSnapshotBtn) downloadSnapshotBtn.disabled = true;
    } else {
      if (statusTextEl) { statusTextEl.textContent = ''; statusTextEl.style.color = ''; }
    }
    if (resetBtn) resetBtn.disabled = !changed;

    if (toolbar && !isHelper) {
      toolbar.classList.toggle('visible', n > 0 || changed);
    }
    // Update the editor re-render button label with combined change counts
    if (typeof updateChangedCount === 'function') updateChangedCount();
  }

  function resolveSnapshotRef(section, list) {
    if (!snapshot) return null;
    var sec = snapshot[section];
    if (!sec) return null;
    return sec[list] || null;
  }

  document.querySelectorAll('.include-toggle').forEach(function(cb){
    cb.addEventListener('change', function(){
      var tr = this.closest('tr[data-snap-section]') || this.closest('[data-snap-section]');
      if (!tr) return;
      var section = tr.getAttribute('data-snap-section');
      var list = tr.getAttribute('data-snap-list');
      var idx = parseInt(tr.getAttribute('data-snap-index'), 10);
      if (section && list && !isNaN(idx) && idx >= 0) {
        var arr = resolveSnapshotRef(section, list);
        if (arr && arr[idx] !== undefined) {
          arr[idx].include = this.checked;
        }
      }
      // Variant radio-group: deselect siblings when enabling one variant.
      // Parent fleet rows do not carry data-variant-group because they point at
      // the same snapshot item as the first child row.
      var variantGroup = tr.getAttribute('data-variant-group');
      var compareGroup = variantGroup;
      if (!compareGroup && tr.classList.contains('fleet-variant-group')) {
        var childVariants = tr.nextElementSibling;
        if (childVariants && childVariants.classList.contains('fleet-variant-children')) {
          var firstVariantRow = childVariants.querySelector('[data-variant-group]');
          if (firstVariantRow) compareGroup = firstVariantRow.getAttribute('data-variant-group');
        }
      }
      if (variantGroup && this.checked) {
        document.querySelectorAll('[data-variant-group="' + variantGroup + '"]').forEach(function(sibling) {
          if (sibling === tr) return;
          var sibSection = sibling.getAttribute('data-snap-section');
          var sibList = sibling.getAttribute('data-snap-list');
          var sibIdx = parseInt(sibling.getAttribute('data-snap-index'), 10);
          if (!sibSection || !sibList || isNaN(sibIdx)) return;
          var sibArr = resolveSnapshotRef(sibSection, sibList);
          if (sibArr && sibArr[sibIdx] !== undefined) {
            sibArr[sibIdx].include = false;
          }
          var sibCb = sibling.querySelector('.include-toggle');
          if (sibCb) sibCb.checked = false;
          sibling.classList.add('excluded');
        });
      }
      tr.classList.toggle('excluded', !this.checked);
      if (compareGroup && typeof updateCompareButtons === 'function') {
        updateCompareButtons(compareGroup);
      }
      updateToolbar();
      setDirty(!isSnapshotClean());
      recalcTriageCounts();
    });
  });

  // --- Strategy select handler ---
  document.querySelectorAll('.strategy-select').forEach(function(sel){
    sel.addEventListener('change', function(){
      var tr = this.closest('tr[data-snap-section]');
      if (!tr) return;
      var section = tr.getAttribute('data-snap-section');
      var list = tr.getAttribute('data-snap-list');
      var idx = parseInt(tr.getAttribute('data-snap-index'), 10);
      if (section && list && !isNaN(idx) && idx >= 0) {
        var arr = resolveSnapshotRef(section, list);
        if (arr && arr[idx] !== undefined) {
          arr[idx].strategy = this.value;
        }
      }
      setDirty(!isSnapshotClean());
      updateToolbar();
    });
  });

  // --- Apply strategy to all users/groups ---
  function applyStrategyToAll(btnId, selectId, listName) {
    var btn = document.getElementById(btnId);
    var sel = document.getElementById(selectId);
    if (!btn || !sel) return;
    btn.addEventListener('click', function() {
      var val = sel.value;
      var arr = resolveSnapshotRef('users_groups', listName);
      if (!arr) return;
      document.querySelectorAll('tr[data-snap-section="users_groups"][data-snap-list="' + listName + '"] .strategy-select').forEach(function(s) {
        s.value = val;
        var idx = parseInt(s.closest('tr').getAttribute('data-snap-index'), 10);
        if (!isNaN(idx) && arr[idx] !== undefined) arr[idx].strategy = val;
      });
      setDirty(!isSnapshotClean());
      updateToolbar();
    });
  }
  applyStrategyToAll('btn-strategy-apply-all', 'strategy-apply-all', 'users');
  applyStrategyToAll('btn-strategy-apply-all-groups', 'strategy-apply-all-groups', 'groups');

  // --- Package leaf/auto-dep cascade ---
  var pkgDepTree = (snapshot.rpm && snapshot.rpm.leaf_dep_tree) || {};
  var pkgAutoNames = new Set((snapshot.rpm && snapshot.rpm.auto_packages) || []);

  function getPkgIdx(name) {
    var pkgs = (snapshot.rpm && snapshot.rpm.packages_added) || [];
    for (var i = 0; i < pkgs.length; i++) {
      if (pkgs[i] && pkgs[i].name === name) return i;
    }
    return -1;
  }

  function recomputeAutoDeps() {
    var covered = new Set();
    document.querySelectorAll('.pkg-dep-tree-group tr[data-leaf], #pkg-dep-tree tr[data-leaf]').forEach(function(row) {
      var cb = row.querySelector('.leaf-cb');
      if (cb && cb.checked) {
        (pkgDepTree[row.getAttribute('data-leaf')] || []).forEach(function(d) { covered.add(d); });
      }
    });
    pkgAutoNames.forEach(function(dep) {
      var i = getPkgIdx(dep);
      if (i >= 0 && snapshot.rpm && snapshot.rpm.packages_added[i]) {
        snapshot.rpm.packages_added[i].include = covered.has(dep);
      }
    });
  }

  function updatePkgBanner() {
    var bannerText = document.getElementById('pkg-selection-text');
    if (!bannerText) return;
    var leafRows = document.querySelectorAll('.pkg-dep-tree-group tr[data-leaf], #pkg-dep-tree tr[data-leaf]');
    if (!leafRows.length) return;
    var total = leafRows.length;
    var selected = 0;
    var covered = new Set();
    leafRows.forEach(function(row) {
      var cb = row.querySelector('.leaf-cb');
      if (cb && cb.checked) {
        selected++;
        (pkgDepTree[row.getAttribute('data-leaf')] || []).forEach(function(d) { covered.add(d); });
      }
    });
    bannerText.innerHTML = '<strong>' + selected + ' of ' + total + ' leaf package' + (total !== 1 ? 's' : '') + ' selected</strong>'
      + ', pulling in <strong>' + covered.size + ' dependenc' + (covered.size !== 1 ? 'ies' : 'y') + '</strong>'
      + ' \u2014 only leaf packages appear in the Containerfile\u2019s <code>dnf\u00a0install</code> line.';
  }

  document.querySelectorAll('.pkg-dep-tree-group .leaf-cb, #pkg-dep-tree .leaf-cb').forEach(function(cb) {
    cb.addEventListener('change', function() {
      recomputeAutoDeps();
      updatePkgBanner();
    });
  });

  updatePkgBanner();

  document.querySelectorAll('.repo-collapse-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', String(!expanded));
      var icon = this.querySelector('.pf-v6-c-button__icon');
      if (icon) icon.textContent = expanded ? '\u25B6' : '\u25BC';

      var row = this.closest('tr[data-repo-group]');
      if (!row) return;

      var next = row.nextElementSibling;
      while (next && !next.hasAttribute('data-repo-group')) {
        next.style.display = expanded ? 'none' : '';
        next = next.nextElementSibling;
      }
    });
  });

  function syncRepoHeaderCheckboxes(repoCb) {
    var tr = repoCb.closest('tr[data-snap-index]');
    if (!tr) return;
    var idx = tr.getAttribute('data-snap-index');
    if (idx === null) return;

    document.querySelectorAll(
      'tr[data-snap-section="rpm"][data-snap-list="repo_files"][data-snap-index="' + idx + '"]'
    ).forEach(function(peerRow) {
      var peerCb = peerRow.querySelector('.repo-cb');
      if (!peerCb) return;
      peerCb.checked = repoCb.checked;
      peerRow.classList.toggle('excluded', !repoCb.checked);
    });
  }

  function repoGroupNamesForCheckbox(repoCb) {
    var tr = repoCb.closest('tr[data-repo-group]');
    if (!tr) return new Set();
    var repoNames = new Set();
    var idx = tr.getAttribute('data-snap-index');

    if (idx !== null) {
      document.querySelectorAll(
        'tr[data-snap-section="rpm"][data-snap-list="repo_files"][data-snap-index="' + idx + '"][data-repo-group]'
      ).forEach(function(peerRow) {
        var peerName = peerRow.getAttribute('data-repo-group');
        if (peerName) repoNames.add(peerName);
      });
    }

    if (!repoNames.size) {
      var repoName = tr.getAttribute('data-repo-group');
      if (repoName) repoNames.add(repoName);
    }

    return repoNames;
  }

  function syncRepoLeafInteractivity(repoCb) {
    var repoNames = repoGroupNamesForCheckbox(repoCb);
    if (!repoNames.size) return;
    var checked = repoCb.checked;

    document.querySelectorAll('.pkg-dep-tree-group tr[data-leaf], #pkg-dep-tree tr[data-leaf]').forEach(function(row) {
      var pkgIdx = parseInt(row.getAttribute('data-snap-index'), 10);
      if (pkgIdx < 0) return;
      var pkg = snapshot.rpm.packages_added[pkgIdx];
      if (!pkg || !repoNames.has(pkg.source_repo)) return;

      var leafCb = row.querySelector('.leaf-cb');
      if (!leafCb) return;
      leafCb.disabled = !checked;
    });
  }

  // --- Repo cascade: a repo header toggles all dep-tree leaf rows backed by its repo file ---
  function applyRepoCascade(repoCb) {
    var repoNames = repoGroupNamesForCheckbox(repoCb);
    if (!repoNames.size) return;
    var checked = repoCb.checked;

    syncRepoHeaderCheckboxes(repoCb);

    document.querySelectorAll('.pkg-dep-tree-group tr[data-leaf], #pkg-dep-tree tr[data-leaf]').forEach(function(row) {
      var pkgIdx = parseInt(row.getAttribute('data-snap-index'), 10);
      if (pkgIdx < 0) return;
      var pkg = snapshot.rpm.packages_added[pkgIdx];
      if (!pkg || !repoNames.has(pkg.source_repo)) return;

      var leafCb = row.querySelector('.leaf-cb');
      if (!leafCb) return;

      if (!checked) {
        leafCb.checked = false;
        pkg.include = false;
        row.classList.add('excluded');
      } else {
        leafCb.checked = true;
        pkg.include = true;
        row.classList.remove('excluded');
      }
    });
    syncRepoLeafInteractivity(repoCb);
    recomputeAutoDeps();
    updatePkgBanner();
  }

  function resetToOriginal() {
    document.querySelectorAll('[data-snap-section]').forEach(function(el) {
      var section = el.getAttribute('data-snap-section');
      var list = el.getAttribute('data-snap-list');
      var idx = parseInt(el.getAttribute('data-snap-index'), 10);
      if (!section || !list || isNaN(idx) || idx < 0) return;

      var origSection = originalSnapshot[section];
      if (!origSection) return;
      var origList = origSection[list];
      if (!origList || !origList[idx]) return;
      var origItem = origList[idx];

      var liveSection = snapshot[section];
      if (liveSection && liveSection[list] && liveSection[list][idx] !== undefined) {
        if (origItem.include !== undefined) {
          liveSection[list][idx].include = origItem.include;
        }
        if (origItem.strategy !== undefined) {
          liveSection[list][idx].strategy = origItem.strategy;
        }
      }

      var cb = el.querySelector('.include-toggle');
      if (cb) {
        var shouldCheck = origItem.include !== undefined ? origItem.include : true;
        cb.checked = shouldCheck;
        if (cb.classList.contains('leaf-cb')) {
          cb.disabled = false;
        }
      }

      var sel = el.querySelector('.strategy-select');
      if (sel && origItem.strategy !== undefined) {
        sel.value = origItem.strategy;
      }

      var shouldExclude = origItem.include !== undefined ? !origItem.include : false;
      el.classList.toggle('excluded', shouldExclude);
    });

    document.querySelectorAll('.repo-cb').forEach(function(cb) {
      syncRepoHeaderCheckboxes(cb);
      syncRepoLeafInteractivity(cb);
    });

    recomputeAutoDeps();
    updatePkgBanner();
    updateToolbar();
    setDirty(false);

    // Reset prevalence slider to original value
    var slider = document.getElementById('summary-prevalence-slider');
    if (slider && originalSnapshot.meta && originalSnapshot.meta.fleet) {
      var origThreshold = originalSnapshot.meta.fleet.min_prevalence;
      slider.value = origThreshold;
      slider.setAttribute('data-current-threshold', origThreshold);
      var valueLabel = document.getElementById('summary-prevalence-value');
      if (valueLabel) valueLabel.textContent = origThreshold + '%';
      var countsLabel = document.getElementById('summary-prevalence-counts');
      if (countsLabel) {
        var counts = countAtThreshold(origThreshold);
        countsLabel.textContent = counts.included + ' included \u00b7 ' + counts.excluded + ' below threshold';
      }
    }

    recalcTriageCounts();
    if (typeof updateCompareButtons === 'function') {
      var seen = {};
      document.querySelectorAll('[data-variant-group]').forEach(function(el) {
        seen[el.getAttribute('data-variant-group')] = true;
      });
      Object.keys(seen).forEach(function(g) { updateCompareButtons(g); });
    }
    resetReviewState();
    showToast('Selections reset to initial state');
  }

  document.querySelectorAll('.repo-cb').forEach(function(cb) {
    cb.addEventListener('change', function() {
      applyRepoCascade(this);
      recalcTriageCounts();
      updateToolbar();
      setDirty(!isSnapshotClean());
    });
  });

  if (resetBtn) {
    resetBtn.addEventListener('click', function() {
      if (confirm('Reset all selections to their initial state? This cannot be undone.')) {
        resetToOriginal();
      }
    });
  }

  // --- Download modified snapshot ---
  downloadSnapshotBtn.addEventListener('click', function(){
    if (!dirty) return;
    var json = JSON.stringify(snapshot, null, 2);
    var blob = new Blob([json], {type: 'application/json'});
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'modified-snapshot.json';
    a.click();
    URL.revokeObjectURL(a.href);
  });

  // --- Re-render ---
  if (rerenderBtn) {
    rerenderBtn.addEventListener('click', function(){
      if (!helperAvailable) return;
      if (!dirty) return;
      var origText = rerenderBtn.innerHTML;
      rerenderBtn.innerHTML = '<span class="spinner"></span>Re-rendering...';
      rerenderBtn.disabled = true;
      var sliderEl = document.getElementById('summary-prevalence-slider');
      if (snapshot.meta && snapshot.meta.fleet && sliderEl) {
        var newThreshold = parseInt(sliderEl.value, 10);
        if (typeof window.applyPrevalenceThreshold === 'function') {
          window.applyPrevalenceThreshold(newThreshold);
        }
        snapshot.meta.fleet.min_prevalence = newThreshold;
      }
      fetch(window.location.origin + '/api/re-render', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({snapshot: snapshot, original: originalSnapshot}),
      }).then(function(r){
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.text();
      }).then(function(html){
        setDirty(false);
        document.open();
        document.write(html);
        document.close();
      }).catch(function(err){
        showToast('Re-render failed: ' + err.message, 5000);
        rerenderBtn.innerHTML = origText;
        rerenderBtn.disabled = false;
      });
    });
  }

  // --- Download tarball ---
  tarballBtn.addEventListener('click', function(){
    if (!helperAvailable) return;
    window.location.href = window.location.origin + '/api/tarball';
  });

  // --- Helper script detection with retry ---
  function enableHelperButtons(reRenderAvailable) {
    helperAvailable = true;
    document.querySelectorAll('.include-toggle-wrap').forEach(function(el){ el.style.display = 'inline-grid'; });
    if (toolbar) {
      toolbar.style.display = '';
      toolbar.classList.remove('visible');
      toolbar.classList.add('helper-active');
    }
    reRenderEnabled = (reRenderAvailable !== false);
    if (rerenderBtn) {
      if (reRenderEnabled) {
        rerenderBtn.disabled = false;
        rerenderBtn.title = 'Re-render with excluded items removed';
      } else {
        rerenderBtn.title = 'Re-render requires podman or docker — not found on this system';
      }
    }
    tarballBtn.disabled = false;
    tarballBtn.title = 'Download current output as tar.gz';
    updateToolbar();
  }

  function checkHelperAvailable(attempt) {
    fetch(window.location.origin + '/api/health')
      .then(function(r) { return r.ok ? r.json() : Promise.reject(new Error('not ok')); })
      .then(function(d) {
        if (d && d.status === 'ok') {
          enableHelperButtons(d.re_render !== false);
        } else {
          retryOrGiveUp(attempt);
        }
      })
      .catch(function() { retryOrGiveUp(attempt); });
  }

  function retryOrGiveUp(attempt) {
    if (attempt < 3) {
      setTimeout(function() { checkHelperAvailable(attempt + 1); }, 2000);
    } else {
      console.log('yoinkc-refine not detected');
    }
  }

  checkHelperAvailable(0);
  updateToolbar();

  // --- Sidebar triage count recalculation ---
  function recalcTriageCounts() {
    var sectionLists = {
      'rpm':              ['packages_added', 'module_streams', 'version_locks'],
      'config':           ['files'],
      'services':         ['state_changes', 'drop_ins'],
      'network':          ['firewall_zones'],
      'selinux':          ['port_labels'],
      'non_rpm_software': ['items'],
      'containers':       ['quadlet_units', 'compose_files'],
      'scheduled_tasks':  ['generated_timer_units', 'cron_jobs'],
    };
    Object.keys(sectionLists).forEach(function(sectionName) {
      var sec = snapshot[sectionName];
      if (!sec) return;
      var count = 0;
      sectionLists[sectionName].forEach(function(listName) {
        var items = sec[listName];
        if (!items) return;
        if (sectionName === 'services' && listName === 'state_changes') {
          items.forEach(function(item) {
            if (item.include !== false && item.action !== 'unchanged') count++;
          });
        } else {
          items.forEach(function(item) {
            if (item.include !== false) count++;
          });
        }
      });
      var el = document.querySelector('.triage-count[data-triage-section="' + sectionName + '"]');
      if (el) {
        var oldText = el.textContent;
        el.textContent = String(count);
        if (el.textContent !== oldText) {
          el.classList.remove('sidebar-badge-updated');
          void el.offsetWidth; // force reflow to restart animation if already running
          el.classList.add('sidebar-badge-updated');
          el.addEventListener('animationend', function() {
            el.classList.remove('sidebar-badge-updated');
          }, { once: true });
        }
      }
    });
  }

  // --- Theme toggle ---
  (function() {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    function applyTheme(theme) {
      if (theme === 'dark') {
        document.documentElement.classList.add('pf-v6-theme-dark');
      } else {
        document.documentElement.classList.remove('pf-v6-theme-dark');
      }
      btn.textContent = theme === 'light' ? '\u263D' : '\u2600';
      btn.title = theme === 'light' ? 'Switch to dark theme' : 'Switch to light theme';
      localStorage.setItem('yoinkc-theme', theme);
    }
    applyTheme(localStorage.getItem('yoinkc-theme') || 'dark');
    btn.addEventListener('click', function() {
      var isDark = document.documentElement.classList.contains('pf-v6-theme-dark');
      applyTheme(isDark ? 'light' : 'dark');
    });
  })();

  // --- Copy Containerfile to clipboard ---
  (function() {
    var btn = document.getElementById('btn-copy-cf');
    if (!btn) return;
    var pre = document.getElementById('containerfile-pre');
    function flash() {
      btn.textContent = 'Copied!';
      btn.classList.remove('pf-m-secondary');
      btn.classList.add('pf-m-primary');
      setTimeout(function() {
        btn.textContent = 'Copy';
        btn.classList.remove('pf-m-primary');
        btn.classList.add('pf-m-secondary');
      }, 1500);
    }
    function fallback(text) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0';
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      var ok = false;
      try { ok = document.execCommand('copy'); } catch(e) {}
      document.body.removeChild(ta);
      if (ok) { flash(); } else { showToast('Clipboard not available in this context', 3000); }
    }
    btn.addEventListener('click', function() {
      var text = pre ? pre.textContent : '';
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(flash).catch(function() { fallback(text); });
      } else {
        fallback(text);
      }
    });
  })();

  // --- Triage progress tracking ---
  var reviewedSections = {};
  // Build triageable tab list from the DOM so fleet reports (which omit Storage)
  // automatically get the correct count without any hardcoded assumptions.
  var TRIAGEABLE_TABS = (function() {
    var tabs = [];
    document.querySelectorAll('[data-tab-id]').forEach(function(btn) {
      tabs.push(btn.getAttribute('data-tab-id'));
    });
    return tabs;
  }());

  function updateReviewProgress() {
    var count = Object.keys(reviewedSections).length;
    var total = TRIAGEABLE_TABS.length;
    var pct = total > 0 ? Math.round(count * 100 / total) : 0;
    var label = document.getElementById('review-progress-label');
    var indicator = document.getElementById('review-progress-indicator');
    var container = document.getElementById('review-progress');
    var bar = container ? container.querySelector('.pf-v6-c-progress__bar') : null;
    if (label) {
      label.textContent = count === total ? 'All sections reviewed' : count + ' of ' + total + ' reviewed';
    }
    if (indicator) {
      indicator.style.width = pct + '%';
    }
    if (bar) {
      bar.setAttribute('aria-valuemax', String(total));
      bar.setAttribute('aria-valuenow', String(count));
    }
    if (container) {
      container.classList.toggle('pf-m-success', total > 0 && count === total);
    }
  }

  // Initialise the label/aria-valuemax with the correct DOM-derived total.
  updateReviewProgress();

  function toggleReviewed(tabId, btn) {
    if (reviewedSections[tabId]) {
      delete reviewedSections[tabId];
      btn.className = 'pf-v6-c-button pf-m-secondary pf-m-small';
      btn.textContent = 'Mark as reviewed';
    } else {
      reviewedSections[tabId] = true;
      btn.className = 'pf-v6-c-button pf-m-plain pf-m-small';
      btn.innerHTML = '<span style="color: var(--pf-t--global--color--status--success--default);">✓ Reviewed</span>';
    }
    var check = document.getElementById('check-' + tabId);
    if (check) {
      check.style.display = reviewedSections[tabId] ? '' : 'none';
      if (reviewedSections[tabId]) {
        check.classList.remove('reviewed-checkmark');
        void check.offsetWidth;
        check.classList.add('reviewed-checkmark');
      }
    }
    updateReviewProgress();
  }

  function resetReviewState() {
    reviewedSections = {};
    TRIAGEABLE_TABS.forEach(function(tabId) {
      var check = document.getElementById('check-' + tabId);
      if (check) {
        check.style.display = 'none';
        check.classList.remove('reviewed-checkmark');
      }
      var btn = document.querySelector('[data-tab-id="' + tabId + '"]');
      if (btn) {
        btn.className = 'pf-v6-c-button pf-m-secondary pf-m-small';
        btn.textContent = 'Mark as reviewed';
      }
    });
    updateReviewProgress();
  }

  // Expose helpers needed by the fleet refine IIFE (outside this closure)
  window.updateToolbar = updateToolbar;
  window.setDirty = setDirty;
  window.isSnapshotClean = isSnapshotClean;
  window.isReRenderEnabled = function() { return reRenderEnabled; };
  window.resolveSnapshotRef = resolveSnapshotRef;
  window.recalcTriageCounts = recalcTriageCounts;
  window.toggleReviewed = toggleReviewed;
})();


function toggleCard(btn) {
  var section = btn.closest('.pf-v6-c-expandable-section');
  var expanded = btn.getAttribute('aria-expanded') === 'true';
  btn.setAttribute('aria-expanded', String(!expanded));
  if (!section) return;

  // Keep pf-m-expanded in sync so PF6's icon-rotation CSS variable stays correct
  section.classList.toggle('pf-m-expanded', !expanded);

  var contentId = btn.getAttribute('aria-controls');
  var content = contentId ? document.getElementById(contentId) : null;

  if (expanded) {
    // Collapsing: give the transition a concrete start value, then animate to 0.
    // Setting scrollHeight inline then forcing a reflow commits that value as the
    // "from" point before we drive it to 0px.
    if (content) {
      content.style.maxHeight = content.scrollHeight + 'px';
      void content.offsetHeight; // force reflow to commit start value
      content.style.maxHeight = '0px';
    }
    section.classList.add('pf-m-collapsed');
  } else {
    // Expanding: remove collapsed, animate from 0 to scrollHeight, then clear
    // the inline cap so the content can grow freely in future.
    section.classList.remove('pf-m-collapsed');
    if (content) {
      content.style.maxHeight = content.scrollHeight + 'px';
      content.addEventListener('transitionend', function onExpand(e) {
        if (e.propertyName !== 'max-height') return;
        // Guard against a fast re-collapse cancelling this listener late
        if (!section.classList.contains('pf-m-collapsed')) {
          content.style.maxHeight = '';
        }
        content.removeEventListener('transitionend', onExpand);
      });
    }
  }
}

{% if fleet_meta %}
function lineDiff(oldText, newText) {
  var oldLines = (oldText || '').split('\n');
  var newLines = (newText || '').split('\n');
  var m = oldLines.length, n = newLines.length;

  if (m > 5000 || n > 5000) return null;

  // LCS table
  var dp = [];
  for (var i = 0; i <= m; i++) {
    dp[i] = [];
    for (var j = 0; j <= n; j++) {
      if (i === 0 || j === 0) dp[i][j] = 0;
      else if (oldLines[i - 1] === newLines[j - 1]) dp[i][j] = dp[i - 1][j - 1] + 1;
      else dp[i][j] = Math.max(dp[i - 1][j], dp[i][j - 1]);
    }
  }

  var result = [];
  var i = m, j = n;
  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && oldLines[i - 1] === newLines[j - 1]) {
      result.push({ type: 'same', text: oldLines[i - 1] });
      i--; j--;
    } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {
      result.push({ type: 'add', text: newLines[j - 1] });
      j--;
    } else {
      result.push({ type: 'remove', text: oldLines[i - 1] });
      i--;
    }
  }
  result.reverse();
  return result;
}

function escapeHtml(str) {
  var div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

var compareCloseTimer = null;
var compareReleaseTrap = null;

function closeCompareModal() {
  var modal = document.getElementById('variant-compare-modal');
  if (!modal) return;
  if (compareReleaseTrap) { compareReleaseTrap(); compareReleaseTrap = null; }
  modal.classList.remove('pf-m-open');
  compareCloseTimer = setTimeout(function() {
    compareCloseTimer = null;
    modal.style.display = 'none';
    var body = document.getElementById('compare-modal-body');
    var footer = document.getElementById('compare-modal-footer');
    if (body) body.innerHTML = '';
    if (footer) footer.innerHTML = '';
  }, 160);
}

function showCompareModal(path, selectedItem, comparisonItem, peerMode) {
  var modal = document.getElementById('variant-compare-modal');
  if (!modal) return;
  peerMode = !!peerMode;

  var hasContent = !!(selectedItem.content || comparisonItem.content);
  var diff = hasContent ? lineDiff(selectedItem.content || '', comparisonItem.content || '') : null;

  // Title
  var titleEl = document.getElementById('compare-modal-title');
  titleEl.textContent = 'Compare variants';

  // Subtitle with host info and legend
  var selHosts = selectedItem.fleet ? selectedItem.fleet.hosts.join(', ') : '';
  var selCount = selectedItem.fleet ? selectedItem.fleet.count + '/' + selectedItem.fleet.total : '';
  var cmpHosts = comparisonItem.fleet ? comparisonItem.fleet.hosts.join(', ') : '';
  var cmpCount = comparisonItem.fleet ? comparisonItem.fleet.count + '/' + comparisonItem.fleet.total : '';
  var selectedLabel = peerMode ? 'Variant A' : 'Selected';
  var comparisonLabel = peerMode ? 'Variant B' : 'This variant';
  var bodyHtml = '<div style="padding:8px 20px;font-size:0.8rem;color:var(--pf-t--global--text--color--subtle);border-bottom:1px solid var(--pf-t--global--border--color--default);">'
    + '<code style="font-size:0.8rem;">' + escapeHtml(path) + '</code><br>'
    + '<span class="diff-legend-selected">&#9632;</span> ' + selectedLabel + ' (' + selCount + ' hosts: ' + escapeHtml(selHosts) + ')<br>'
    + '<span class="diff-legend-comparison">&#9632;</span> ' + comparisonLabel + ' (' + cmpCount + ' hosts: ' + escapeHtml(cmpHosts) + ')'
    + '</div>';

  // Diff body
  if (!hasContent) {
    bodyHtml += '<div style="padding:20px;text-align:center;color:var(--pf-t--global--text--color--subtle);">No content available for comparison.</div>';
  } else if (diff === null) {
    bodyHtml += '<div style="padding:20px;text-align:center;color:var(--pf-t--global--text--color--subtle);">File too large to diff (over 5000 lines)</div>';
  } else {
    bodyHtml += '<div style="padding:0;overflow-y:auto;font-family:monospace;font-size:0.75rem;line-height:1.6;">';
    diff.forEach(function(line) {
      var cls = line.type === 'add' ? 'diff-line-add' : line.type === 'remove' ? 'diff-line-remove' : 'diff-line-same';
      var prefix = line.type === 'add' ? '+' : line.type === 'remove' ? '-' : ' ';
      bodyHtml += '<div class="' + cls + '">' + prefix + ' ' + escapeHtml(line.text) + '</div>';
    });
    bodyHtml += '</div>';
  }

  document.getElementById('compare-modal-body').innerHTML = bodyHtml;

  // Footer
  var footerEl = document.getElementById('compare-modal-footer');
  if (peerMode) {
    footerEl.innerHTML = '<button class="pf-v6-c-button pf-m-secondary" data-action="close">Close</button>'
      + '<button class="pf-v6-c-button pf-m-secondary" data-action="use-a">Use Variant A</button>'
      + '<button class="pf-v6-c-button pf-m-primary" data-action="use-b">Use Variant B</button>';
  } else {
    footerEl.innerHTML = '<button class="pf-v6-c-button pf-m-secondary" data-action="close">Close</button>'
      + '<button class="pf-v6-c-button pf-m-primary" data-action="switch">Switch to this variant</button>';
  }

  footerEl.querySelector('[data-action="close"]').addEventListener('click', closeCompareModal);

  modal._comparisonContext = {
    path: path,
    selectedItem: selectedItem,
    comparisonItem: comparisonItem,
    peerMode: peerMode
  };

  if (peerMode) {
    footerEl.querySelector('[data-action="use-a"]').addEventListener('click', function() {
      applyVariantSelection(path, selectedItem);
      closeCompareModal();
    });
    footerEl.querySelector('[data-action="use-b"]').addEventListener('click', function() {
      applyVariantSelection(path, comparisonItem);
      closeCompareModal();
    });
  } else {
    footerEl.querySelector('[data-action="switch"]').addEventListener('click', function() {
      switchVariant(modal._comparisonContext);
      closeCompareModal();
    });
  }

  if (compareCloseTimer) { clearTimeout(compareCloseTimer); compareCloseTimer = null; }
  modal.style.display = '';
  requestAnimationFrame(function() {
    modal.classList.add('pf-m-open');
    var dialog = modal.querySelector('.pf-v6-c-modal-box');
    if (dialog) compareReleaseTrap = trapFocus(dialog, closeCompareModal);
  });
}

function syncParentGroupRows(group) {
  document.querySelectorAll('.fleet-variant-group').forEach(function(parentRow) {
    var parentIdx = parseInt(parentRow.getAttribute('data-snap-index'), 10);
    var section = parentRow.getAttribute('data-snap-section');
    var list = parentRow.getAttribute('data-snap-list');
    if (!section || !list || isNaN(parentIdx)) return;
    var arr = resolveSnapshotRef(section, list);
    if (!arr || !arr[parentIdx]) return;

    var childRows = document.querySelectorAll('[data-variant-group="' + group + '"]');
    var matchesGroup = false;
    childRows.forEach(function(child) {
      if (child.getAttribute('data-snap-section') === section
          && child.getAttribute('data-snap-list') === list
          && parseInt(child.getAttribute('data-snap-index'), 10) === parentIdx) {
        matchesGroup = true;
      }
    });
    if (!matchesGroup) return;

    var parentCb = parentRow.querySelector('.include-toggle');
    if (parentCb) parentCb.checked = arr[parentIdx].include;
    parentRow.classList.toggle('excluded', !arr[parentIdx].include);
  });
}

function applyVariantSelection(group, targetItem) {
  var rows = document.querySelectorAll('[data-variant-group="' + group + '"]');
  rows.forEach(function(row) {
    var section = row.getAttribute('data-snap-section');
    var list = row.getAttribute('data-snap-list');
    var idx = parseInt(row.getAttribute('data-snap-index'), 10);
    if (!section || !list || isNaN(idx)) return;
    var arr = resolveSnapshotRef(section, list);
    if (!arr || !arr[idx]) return;

    var isTarget = (arr[idx] === targetItem);
    arr[idx].include = isTarget;

    var cb = row.querySelector('.include-toggle');
    if (cb) cb.checked = isTarget;
    row.classList.toggle('excluded', !isTarget);

    var actionCell = row.querySelector('.variant-action-cell');
    if (actionCell) {
      if (isTarget) {
        actionCell.innerHTML = '<span style="font-size:0.75rem;color:var(--pf-t--global--text--color--subtle);">selected</span>';
      } else {
        actionCell.innerHTML = '<button class="pf-v6-c-button pf-m-link pf-m-small variant-compare-btn">Compare</button>';
      }
    }
  });

  syncParentGroupRows(group);

  updateToolbar();
  setDirty(!isSnapshotClean());
  if (typeof recalcTriageCounts === 'function') recalcTriageCounts();
  if (typeof updateCompareButtons === 'function') updateCompareButtons(group);
  if (typeof editorRefreshTree === 'function') editorRefreshTree();
}

function switchVariant(ctx) {
  applyVariantSelection(ctx.path, ctx.comparisonItem);
}

function updateCompareButtons(group) {
  var rows = document.querySelectorAll('[data-variant-group="' + group + '"]');
  var canPeerCompare = rows.length === 2;
  var hasSelected = false;
  rows.forEach(function(row) {
    var section = row.getAttribute('data-snap-section');
    var list = row.getAttribute('data-snap-list');
    var idx = parseInt(row.getAttribute('data-snap-index'), 10);
    var arr = resolveSnapshotRef(section, list);
    if (arr && arr[idx] && arr[idx].include) hasSelected = true;
  });
  rows.forEach(function(row) {
    var btn = row.querySelector('.variant-compare-btn');
    if (!btn) return;
    if (hasSelected || canPeerCompare) {
      btn.removeAttribute('disabled');
      btn.classList.remove('pf-m-disabled');
    } else {
      btn.setAttribute('disabled', '');
      btn.classList.add('pf-m-disabled');
    }
  });
}

/* Fleet: Compare button click delegation */
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.variant-compare-btn');
  if (!btn) return;

  var row = btn.closest('[data-variant-group]');
  if (!row) return;

  var group = row.getAttribute('data-variant-group');
  var section = row.getAttribute('data-snap-section');
  var list = row.getAttribute('data-snap-list');
  var idx = parseInt(row.getAttribute('data-snap-index'), 10);
  if (!section || !list || isNaN(idx)) return;

  var arr = resolveSnapshotRef(section, list);
  if (!arr || !arr[idx]) return;
  var comparisonItem = arr[idx];
  var rows = Array.prototype.slice.call(document.querySelectorAll('[data-variant-group="' + group + '"]'));

  var selectedItem = null;
  rows.forEach(function(sibling) {
    var sibIdx = parseInt(sibling.getAttribute('data-snap-index'), 10);
    var sibArr = resolveSnapshotRef(sibling.getAttribute('data-snap-section'), sibling.getAttribute('data-snap-list'));
    if (sibArr && sibArr[sibIdx] && sibArr[sibIdx].include) {
      selectedItem = sibArr[sibIdx];
    }
  });

  if (!selectedItem) {
    if (rows.length !== 2) return;
    var otherItem = null;
    rows.forEach(function(sibling) {
      if (sibling === row) return;
      var sibIdx = parseInt(sibling.getAttribute('data-snap-index'), 10);
      var sibArr = resolveSnapshotRef(sibling.getAttribute('data-snap-section'), sibling.getAttribute('data-snap-list'));
      if (sibArr && sibArr[sibIdx]) {
        otherItem = sibArr[sibIdx];
      }
    });
    if (!otherItem) return;
    showCompareModal(group, otherItem, comparisonItem, true);
    return;
  }

  showCompareModal(group, selectedItem, comparisonItem);
});

var initialCompareGroups = {};
document.querySelectorAll('[data-variant-group]').forEach(function(el) {
  initialCompareGroups[el.getAttribute('data-variant-group')] = true;
});
Object.keys(initialCompareGroups).forEach(function(g) { updateCompareButtons(g); });

/* Fleet: keyboard activation for fleet bars */
document.querySelectorAll('.fleet-bar').forEach(function(bar) {
  bar.addEventListener('keydown', activateOnKeydown);
});

/* Fleet: toggle fraction/percentage on prevalence labels */
document.querySelectorAll('.fleet-bar-label').forEach(function(label) {
  label.setAttribute('tabindex', '0');
  label.setAttribute('role', 'button');
  label.setAttribute('aria-label', 'Toggle percentage display');
  label.addEventListener('click', function(e) {
    e.stopPropagation();
    var bar = this.closest('.fleet-bar');
    if (!bar) return;
    var count = parseInt(bar.getAttribute('data-count'), 10);
    var total = parseInt(bar.getAttribute('data-total'), 10);
    var showing = this.getAttribute('data-showing') || 'fraction';
    if (showing === 'fraction') {
      var pct = total > 0 ? Math.round(count * 100 / total) : 100;
      this.textContent = pct + '%';
      this.setAttribute('data-showing', 'percent');
    } else {
      this.textContent = count + '/' + total;
      this.setAttribute('data-showing', 'fraction');
    }
  });
  label.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      e.stopPropagation();
      this.click();
    }
  });
});

/* Fleet: host list popover on bar click */
var activePopover = null;
var copyFormat = 'newline';

function fleetHostTitle(host) {
  var fleetMeta = snapshot.meta && snapshot.meta.fleet;
  var titleMap = fleetMeta && fleetMeta.host_title_map;
  return (titleMap && titleMap[host]) || host;
}

function fleetCopyHosts(hostList, btnEl) {
  var sep = copyFormat === 'comma' ? ',' : (copyFormat === 'space' ? ' ' : '\n');
  var text = hostList.join(sep);
  function flash() {
    btnEl.textContent = 'Copied!';
    btnEl.classList.add('fleet-popover-copy-btn--copied');
    setTimeout(function() {
      btnEl.textContent = 'Copy';
      btnEl.classList.remove('fleet-popover-copy-btn--copied');
    }, 1500);
  }
  function fallback(t) {
    var ta = document.createElement('textarea');
    ta.value = t;
    ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    var ok = false;
    try { ok = document.execCommand('copy'); } catch(ex) {}
    document.body.removeChild(ta);
    if (ok) { flash(); } else { showToast('Clipboard not available in this context', 3000); }
  }
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(flash).catch(function() { fallback(text); });
  } else {
    fallback(text);
  }
}

document.querySelectorAll('.fleet-bar').forEach(function(bar) {
  bar.addEventListener('click', function(e) {
    if (activePopover) {
      if (activePopover._releaseTrap) activePopover._releaseTrap();
      activePopover.remove();
      activePopover = null;
    }
    var hostsAttr = this.getAttribute('data-hosts');
    var hostTitlesAttr = this.getAttribute('data-host-titles');
    var count = parseInt(this.getAttribute('data-count'), 10) || 0;
    var total = parseInt(this.getAttribute('data-total'), 10) || 0;
    var popover = document.createElement('div');
    popover.className = 'fleet-popover';
    /* Stop clicks inside popover from bubbling to the bar handler.
       Also close the dropdown if the click was outside it. */
    popover.addEventListener('click', function(ev) {
      ev.stopPropagation();
      if (!ev.target.closest('.fleet-popover-dropdown') && !ev.target.closest('.fleet-popover-drop-arrow')) {
        var dd = popover.querySelector('.fleet-popover-dropdown');
        if (dd) dd.style.display = 'none';
      }
    });

    if (!hostsAttr) {
      popover.textContent = 'Host list not available';
    } else {
      var hostList = hostsAttr.split(', ').map(function(h) { return h.trim(); }).filter(Boolean);
      var hostTitles = hostTitlesAttr
        ? hostTitlesAttr.split(', ').map(function(h) { return h.trim(); })
        : hostList.map(fleetHostTitle);
      if (hostList.length === 0) {
        popover.textContent = 'Host list not available';
      } else {
        var header = document.createElement('div');
        header.className = 'fleet-popover-header';

        var countLabel = document.createElement('span');
        countLabel.className = 'fleet-popover-count';
        countLabel.textContent = count + ' of ' + total + ' hosts';
        header.appendChild(countLabel);

        var splitBtn = document.createElement('div');
        splitBtn.className = 'fleet-popover-split-btn';

        var copyBtn = document.createElement('button');
        copyBtn.className = 'fleet-popover-copy-btn';
        copyBtn.type = 'button';
        copyBtn.textContent = 'Copy';
        copyBtn.addEventListener('click', function(ev) {
          ev.stopPropagation();
          fleetCopyHosts(hostList, copyBtn);
        });

        var dropdown = document.createElement('div');
        dropdown.className = 'fleet-popover-dropdown';
        dropdown.style.display = 'none';

        var dropArrow = document.createElement('button');
        dropArrow.className = 'fleet-popover-drop-arrow';
        dropArrow.type = 'button';
        dropArrow.setAttribute('aria-label', 'Choose copy format');
        dropArrow.textContent = '▾';
        dropArrow.addEventListener('click', function(ev) {
          ev.stopPropagation();
          dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
        });

        var fmtDefs = [
          { key: 'newline', label: 'One per line' },
          { key: 'comma',   label: 'Comma-separated' },
          { key: 'space',   label: 'Space-separated' }
        ];
        fmtDefs.forEach(function(fmt) {
          var item = document.createElement('button');
          item.className = 'fleet-popover-fmt-item';
          item.type = 'button';
          item.setAttribute('data-fmt', fmt.key);

          var check = document.createElement('span');
          check.className = 'fleet-popover-fmt-check';
          check.textContent = copyFormat === fmt.key ? '✓' : '';

          var lbl = document.createElement('span');
          lbl.textContent = fmt.label;

          item.appendChild(check);
          item.appendChild(lbl);
          item.addEventListener('click', function(ev) {
            ev.stopPropagation();
            copyFormat = fmt.key;
            fleetCopyHosts(hostList, copyBtn);
            dropdown.querySelectorAll('.fleet-popover-fmt-check').forEach(function(c) {
              var row = c.closest('[data-fmt]');
              c.textContent = row && row.getAttribute('data-fmt') === copyFormat ? '✓' : '';
            });
            dropdown.style.display = 'none';
          });
          dropdown.appendChild(item);
        });

        splitBtn.appendChild(copyBtn);
        splitBtn.appendChild(dropArrow);
        splitBtn.appendChild(dropdown);
        header.appendChild(splitBtn);
        popover.appendChild(header);

        var ul = document.createElement('ul');
        hostList.forEach(function(h, idx) {
          var li = document.createElement('li');
          li.textContent = h;
          li.title = hostTitles[idx] || fleetHostTitle(h);
          ul.appendChild(li);
        });
        popover.appendChild(ul);
      }
    }

    this.style.position = 'relative';
    this.appendChild(popover);
    activePopover = popover;
    activePopover._releaseTrap = trapFocus(popover, function() {
      if (activePopover) {
        if (activePopover._releaseTrap) activePopover._releaseTrap();
        activePopover.remove();
        activePopover = null;
      }
    });
  });
});

/* Close popover on click outside */
document.addEventListener('click', function(e) {
  if (activePopover && !e.target.closest('.fleet-bar')) {
    if (activePopover._releaseTrap) activePopover._releaseTrap();
    activePopover.remove();
    activePopover = null;
  }
});

/* Fleet: variant group expand/collapse */
document.querySelectorAll('.fleet-variant-toggle').forEach(function(badge) {
  badge.addEventListener('keydown', activateOnKeydown);
  badge.addEventListener('click', function() {
    var childRow = this.closest('tr').nextElementSibling;
    if (childRow && childRow.classList.contains('fleet-variant-children')) {
      if (childRow.style.display === 'table-row') {
        childRow.style.display = '';
      } else {
        childRow.style.display = 'table-row';
      }
    }
  });
});
{% endif %}

{% if fleet_meta %}
// Hoisted prevalence helpers — used by summary slider and toolbar slider
function prevalenceInclude(count, total, minPrev) {
  return (count * 100) >= (minPrev * total);
}

function countAtThreshold(threshold) {
  var included = 0, excluded = 0;
  var sections = ['rpm', 'config', 'services', 'network',
                  'containers', 'scheduled_tasks', 'users_groups'];
  sections.forEach(function(secName) {
    var sec = snapshot[secName];
    if (!sec) return;
    Object.keys(sec).forEach(function(listName) {
      var items = sec[listName];
      if (!Array.isArray(items)) return;
      items.forEach(function(item) {
        if (!item.fleet) return;
        if (prevalenceInclude(item.fleet.count, item.fleet.total, threshold)) {
          included++;
        } else {
          excluded++;
        }
      });
    });
  });
  return { included: included, excluded: excluded };
}

// Summary tab prevalence — live card updates (all fleet reports)
(function() {
  var summarySlider = document.getElementById('summary-prevalence-slider');
  if (!summarySlider) return;

  var valueEl = document.getElementById('summary-prevalence-value');
  var countsEl = document.getElementById('summary-prevalence-counts');
  var scopeTotalEl = document.getElementById('summary-scope-total');
  var scopeAutoEl = document.getElementById('summary-scope-auto');
  var attentionEl = document.getElementById('summary-attention-count');
  var reviewEl = document.getElementById('summary-review-count');
  var manualEl = document.getElementById('summary-manual-count');

  var staticFixme = {{ triage.fixme }};
  var staticManual = {{ triage.manual }};

  function animateCounter(el, newValue) {
    if (!el) return;
    var newText = String(newValue);
    if (el.textContent === newText) return;
    el.classList.add('updating');
    setTimeout(function() {
      el.textContent = newText;
      el.classList.remove('updating');
    }, 100);
  }

  function updateSummaryCards(threshold) {
    var result = countAtThreshold(threshold);
    if (valueEl) valueEl.textContent = threshold + '%';
    if (countsEl) countsEl.textContent = result.included + ' included \u00b7 ' + result.excluded + ' below threshold';

    var approxTotal = result.included + staticFixme + staticManual;
    var approxAuto = result.included;
    var attentionCount = staticFixme + staticManual;

    animateCounter(scopeTotalEl, approxTotal);
    if (scopeAutoEl) animateCounter(scopeAutoEl, approxAuto);
    animateCounter(attentionEl, attentionCount);
    if (reviewEl) animateCounter(reviewEl, staticFixme);
    if (manualEl) animateCounter(manualEl, staticManual);
  }

  summarySlider.addEventListener('input', function() {
    updateSummaryCards(parseInt(this.value, 10));
  });

  updateSummaryCards(parseInt(summarySlider.value, 10));

  // Sync prevalence badge values across section headers
  summarySlider.addEventListener('input', function() {
    var val = parseInt(this.value, 10);
    document.querySelectorAll('.prevalence-badge-value').forEach(function(el) {
      el.textContent = val + '%';
    });
  });
})();

// Prevalence badge click → navigate to summary tab
(function() {
  document.querySelectorAll('.prevalence-badge').forEach(function(badge) {
    badge.addEventListener('click', function(e) {
      e.stopPropagation();
      if (typeof show === 'function') show('summary');
    });
  });
})();

// Section priority list — sort by priority and click-to-navigate
(function() {
  var container = document.getElementById('summary-priority-rows');
  if (!container) return;

  var rows = Array.prototype.slice.call(container.children);
  var bucket = { manual: 0, fixme: 1, review: 1, auto: 2 };
  rows.sort(function(a, b) {
    var aStatus = a.querySelector('[class*="status-"]');
    var bStatus = b.querySelector('[class*="status-"]');
    var aMatch = aStatus && aStatus.className.match(/status-(\w+)/);
    var bMatch = bStatus && bStatus.className.match(/status-(\w+)/);
    var aBucket = aMatch ? (bucket[aMatch[1]] || 2) : 2;
    var bBucket = bMatch ? (bucket[bMatch[1]] || 2) : 2;
    if (aBucket !== bBucket) return aBucket - bBucket;
    var aCount = parseInt((aStatus && aStatus.textContent.match(/(\d+)/)) ? RegExp.$1 : '0', 10);
    var bCount = parseInt((bStatus && bStatus.textContent.match(/(\d+)/)) ? RegExp.$1 : '0', 10);
    return bCount - aCount;
  });
  rows.forEach(function(row) { container.appendChild(row); });

  container.addEventListener('click', function(e) {
    var row = e.target.closest('.summary-priority-row');
    if (!row) return;
    var tabId = row.getAttribute('data-nav-tab');
    if (tabId && typeof show === 'function') {
      show(tabId);
    }
  });
})();
