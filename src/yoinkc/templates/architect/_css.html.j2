<style>
/* ═══════════════════════════════════════════════════════════════════════
   yoinkc architect – custom overrides on top of PatternFly 6
   ═══════════════════════════════════════════════════════════════════════ */

/* Reduced-motion */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}

/* ── Page chrome ──────────────────────────────────────────────────────── */
html, body { margin: 0; padding: 0; height: 100%; }
body { display: flex; flex-direction: column; }

.pf-v6-c-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.pf-v6-c-masthead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--pf-t--global--spacer--lg, 1.5rem);
  height: 3.5rem;
  flex-shrink: 0;
}
.pf-v6-c-masthead__brand {
  font-size: 1.125rem;
  font-weight: 700;
  letter-spacing: 0.03em;
}

/* ── Three-column layout ─────────────────────────────────────────────── */
.architect-layout {
  display: grid;
  grid-template-columns: 200px minmax(0, 3fr) minmax(0, 2fr);
  flex: 1;
  overflow: hidden;
  min-height: 0;
}

@media (max-width: 960px) {
  .architect-layout {
    grid-template-columns: 180px minmax(0, 1fr) minmax(0, 1fr);
  }
}

/* ── Sidebar (fleets) ────────────────────────────────────────────────── */
.architect-sidebar {
  /* Override PF6 sidebar defaults that break CSS grid child behavior */
  opacity: 1 !important;
  transform: none !important;
  position: static !important;
  display: block !important;
  width: auto !important;
  max-width: none !important;
  overflow-y: auto;
  border-right: 1px solid var(--pf-t--global--border--color--default, #444);
}
.architect-sidebar .pf-v6-c-nav__section-title {
  text-transform: uppercase;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: var(--pf-t--global--spacer--sm, 0.5rem) var(--pf-t--global--spacer--md, 1rem);
  color: var(--pf-t--global--text--color--subtle, #aaa);
}

.fleet-card {
  display: block;
  padding: var(--pf-t--global--spacer--sm, 0.5rem) var(--pf-t--global--spacer--md, 1rem);
  border-left: 3px solid transparent;
  cursor: pointer;
  transition: background 0.15s;
  text-decoration: none;
  color: inherit;
}
.fleet-card:hover {
  background: var(--pf-t--global--background--color--secondary--hover, rgba(255,255,255,0.06));
}
.fleet-card.fleet-active {
  background: var(--pf-t--global--background--color--secondary--default, rgba(255,255,255,0.04));
}
.fleet-card-name {
  font-weight: 600;
  font-size: 0.875rem;
  margin-bottom: 0.125rem;
}
.fleet-card-meta {
  font-size: 0.75rem;
  color: var(--pf-t--global--text--color--subtle, #aaa);
}

/* Fleet color accents */
.fleet-color-0 { border-left-color: var(--pf-t--global--color--status--danger--default, #c9190b); }
.fleet-color-1 { border-left-color: var(--pf-t--global--color--status--warning--default, #f0ab00); }
.fleet-color-2 { border-left-color: var(--pf-t--global--color--status--info--default, #2b9af3); }
.fleet-color-3 { border-left-color: var(--pf-t--global--color--status--success--default, #3e8635); }
.fleet-color-4 { border-left-color: #a18fff; }
.fleet-color-5 { border-left-color: #ec7a08; }

/* ── Center: Layer topology tree ─────────────────────────────────────── */
.architect-layout > .pf-v6-c-page__main {
  overflow-y: auto;
  overflow-x: hidden;
  padding: var(--pf-t--global--spacer--lg, 1.5rem);
  min-width: 0;  /* prevent grid blowout from long content */
}

.layer-tree-title {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--pf-t--global--text--color--subtle, #aaa);
  margin-bottom: var(--pf-t--global--spacer--md, 1rem);
}

.layer-card {
  border: 1px solid var(--pf-t--global--border--color--default, #444);
  border-left: 3px solid var(--pf-t--global--color--status--danger--default, #c9190b);
  border-radius: var(--pf-t--global--border--radius--small, 3px);
  padding: var(--pf-t--global--spacer--md, 1rem);
  margin-bottom: var(--pf-t--global--spacer--sm, 0.5rem);
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
  position: relative;
}
.layer-card:hover {
  background: var(--pf-t--global--background--color--secondary--hover, rgba(255,255,255,0.06));
}
.layer-card.layer-selected {
  background: var(--pf-t--global--background--color--primary--default, rgba(0,102,204,0.12));
  border-color: var(--pf-t--global--color--brand--default, #0066cc);
  border-left-width: 3px;
}
.layer-card.layer-derived {
  margin-left: 2.5rem;
  border-left-color: var(--pf-t--global--color--status--info--default, #2b9af3);
}
.layer-card.layer-derived.layer-selected {
  border-color: var(--pf-t--global--color--brand--default, #0066cc);
}

/* Derived layer group: vertical connector from base to children */
.derived-group {
  position: relative;
  margin-left: 1rem;
  padding-left: 1.5rem;
}
.derived-group::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0.5rem;
  border-left: 1px solid var(--pf-t--global--border--color--default, #444);
}

/* Horizontal connector tick for each derived layer */
.derived-connector {
  position: relative;
}
.derived-connector::before {
  content: '';
  position: absolute;
  left: -1.5rem;
  top: 50%;
  width: 1.25rem;
  border-top: 1px solid var(--pf-t--global--border--color--default, #444);
}
.derived-connector:last-child::after {
  /* Hide the vertical line below the last child */
  content: '';
  position: absolute;
  left: -1.5rem;
  top: 50%;
  bottom: -0.5rem;
  width: 2px;
  background: var(--pf-t--global--background--color--primary--default, #1b1d21);
}

.layer-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  margin-bottom: 0.375rem;
}
.layer-card-name {
  font-weight: 700;
  font-size: 1rem;
  flex-shrink: 0;
}
.layer-card-badges {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  flex-shrink: 0;
}

.layer-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.6875rem;
  font-weight: 600;
  padding: 0.125rem 0.5rem;
  border-radius: 99px;
  white-space: nowrap;
  overflow: visible;
  min-width: max-content;
}
.layer-badge-pkg {
  background: var(--pf-t--global--background--color--secondary--default, rgba(255,255,255,0.08));
  color: var(--pf-t--global--text--color--regular, #eee);
}
.layer-badge-fanout {
  background: rgba(240, 171, 0, 0.15);
  color: var(--pf-t--global--color--status--warning--default, #f0ab00);
}
.layer-badge-turbulence {
  background: rgba(43, 154, 243, 0.15);
  color: var(--pf-t--global--color--status--info--default, #2b9af3);
}

.layer-card-detail {
  font-size: 0.75rem;
  color: var(--pf-t--global--text--color--subtle, #aaa);
}

/* Tree connector lines (legacy, kept for backward compat) */
.tree-connector {
  position: relative;
  margin-left: 1rem;
  padding-left: 1rem;
}
.tree-connector::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 50%;
  border-left: 1px solid var(--pf-t--global--border--color--default, #444);
  border-bottom: 1px solid var(--pf-t--global--border--color--default, #444);
  width: 0.75rem;
}
.tree-connector:last-child::before {
  bottom: 50%;
}

/* ── Right: Package drawer ───────────────────────────────────────────── */
.architect-drawer {
  border-left: 1px solid var(--pf-t--global--border--color--default, #444);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.drawer-header {
  padding: var(--pf-t--global--spacer--md, 1rem);
  border-bottom: 1px solid var(--pf-t--global--border--color--default, #444);
  flex-shrink: 0;
}
.drawer-header-title {
  font-weight: 700;
  font-size: 0.9375rem;
  margin-bottom: 0.125rem;
}
.drawer-header-meta {
  font-size: 0.75rem;
  color: var(--pf-t--global--text--color--subtle, #aaa);
}

.drawer-body {
  overflow-y: auto;
  flex: 1;
  padding: 0;
}

.drawer-section-label {
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--pf-t--global--text--color--subtle, #aaa);
  padding: var(--pf-t--global--spacer--sm, 0.5rem) var(--pf-t--global--spacer--md, 1rem);
  background: var(--pf-t--global--background--color--secondary--default, rgba(255,255,255,0.04));
  border-bottom: 1px solid var(--pf-t--global--border--color--default, #444);
}

.pkg-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.375rem var(--pf-t--global--spacer--md, 1rem);
  border-bottom: 1px solid var(--pf-t--global--border--color--default, rgba(255,255,255,0.06));
  font-size: 0.8125rem;
  transition: background 0.1s;
}
.pkg-row:hover {
  background: var(--pf-t--global--background--color--secondary--hover, rgba(255,255,255,0.06));
}

.pkg-name {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.pkg-icon { font-size: 0.875rem; flex-shrink: 0; }

.config-row {
  display: flex;
  align-items: center;
  padding: 0.375rem var(--pf-t--global--spacer--md, 1rem);
  border-bottom: 1px solid var(--pf-t--global--border--color--default, rgba(255,255,255,0.06));
  font-size: 0.8125rem;
  color: var(--pf-t--global--text--color--subtle, #aaa);
}
.config-row .pkg-icon { opacity: 0.7; }

/* Move dropdown */
.move-dropdown {
  position: relative;
  flex-shrink: 0;
}
.move-btn {
  font-size: 0.6875rem;
  padding: 0.125rem 0.5rem;
  border: 1px solid var(--pf-t--global--border--color--default, #555);
  border-radius: var(--pf-t--global--border--radius--small, 3px);
  background: transparent;
  color: var(--pf-t--global--text--color--link--default, #2b9af3);
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.1s;
}
.move-btn:hover {
  background: var(--pf-t--global--background--color--secondary--hover, rgba(255,255,255,0.08));
}

.move-menu {
  position: absolute;
  right: 0;
  top: 100%;
  z-index: 100;
  min-width: 160px;
  background: var(--pf-t--global--background--color--primary--default, #1b1d21);
  border: 1px solid var(--pf-t--global--border--color--default, #444);
  border-radius: var(--pf-t--global--border--radius--small, 3px);
  box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  display: none;
  padding: 0.25rem 0;
}
.move-menu.open { display: block; }

.move-menu-item {
  display: block;
  width: 100%;
  padding: 0.375rem 0.75rem;
  text-align: left;
  font-size: 0.75rem;
  border: none;
  background: none;
  color: var(--pf-t--global--text--color--regular, #eee);
  cursor: pointer;
  transition: background 0.1s;
}
.move-menu-item:hover {
  background: var(--pf-t--global--background--color--secondary--hover, rgba(255,255,255,0.08));
}

.move-impact {
  font-size: 0.625rem;
  color: var(--pf-t--global--text--color--subtle, #888);
  padding: 0.25rem 0.75rem 0.375rem;
  line-height: 1.4;
  border-top: 1px solid var(--pf-t--global--border--color--default, rgba(255,255,255,0.08));
  margin-top: 0.125rem;
}

/* ── Bottom toolbar ──────────────────────────────────────────────────── */
.architect-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.5rem var(--pf-t--global--spacer--lg, 1.5rem);
  border-top: 1px solid var(--pf-t--global--border--color--default, #444);
  flex-shrink: 0;
  background: var(--pf-t--global--background--color--secondary--default, rgba(255,255,255,0.02));
}
.toolbar-summary {
  font-size: 0.8125rem;
  color: var(--pf-t--global--text--color--subtle, #aaa);
}

/* ── Toast ────────────────────────────────────────────────────────────── */
.architect-toast {
  position: fixed;
  bottom: 4rem;
  right: 1.5rem;
  padding: 0.75rem 1.25rem;
  border-radius: var(--pf-t--global--border--radius--small, 3px);
  font-size: 0.8125rem;
  opacity: 0;
  transform: translateY(0.5rem);
  transition: opacity 0.3s, transform 0.3s;
  pointer-events: none;
  z-index: 200;
}
.architect-toast.visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

/* ── Scrollbar styling (dark) ────────────────────────────────────────── */
.architect-sidebar::-webkit-scrollbar,
.drawer-body::-webkit-scrollbar,
.pf-v6-c-page__main::-webkit-scrollbar {
  width: 6px;
}
.architect-sidebar::-webkit-scrollbar-thumb,
.drawer-body::-webkit-scrollbar-thumb,
.pf-v6-c-page__main::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.15);
  border-radius: 3px;
}
.architect-sidebar::-webkit-scrollbar-track,
.drawer-body::-webkit-scrollbar-track,
.pf-v6-c-page__main::-webkit-scrollbar-track {
  background: transparent;
}

/* ── Empty state ─────────────────────────────────────────────────────── */
.drawer-empty {
  padding: 2rem var(--pf-t--global--spacer--md, 1rem);
  text-align: center;
  color: var(--pf-t--global--text--color--subtle, #aaa);
  font-size: 0.8125rem;
}

/* ── Light theme adjustments ─────────────────────────────────────────── */
html:not(.pf-v6-theme-dark) .move-menu {
  background: #fff;
  box-shadow: 0 4px 16px rgba(0,0,0,0.15);
}
html:not(.pf-v6-theme-dark) .architect-sidebar::-webkit-scrollbar-thumb,
html:not(.pf-v6-theme-dark) .drawer-body::-webkit-scrollbar-thumb {
  background: rgba(0,0,0,0.2);
}
</style>
