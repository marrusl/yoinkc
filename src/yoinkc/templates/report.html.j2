{#
  report.html.j2 — yoinkc self-contained inspection report.
  Rendered by renderers/html_report.py via _build_context().
  Context keys:
    snapshot, counts, triage, os_desc, meta,
    warnings, warnings_panel, warnings_overflow,
    containerfile_html (Markup), containerfile_lines,
    tree_html (Markup), file_content_snippets_html (Markup),
    audit_html (Markup),
    config_files_rendered (list of dicts),
    non_rpm_data (dict of categorized items),
    containers_data (dict),
    network_data (dict),
    triage_detail (list of dicts),
#}

{# ── Section wrapper macro ─────────────────────────────────────────────── #}
{% macro section(id, title, visible=false) -%}
<div id="section-{{ id }}" class="section{% if visible %} visible{% endif %}">
  <h2>{{ title }}</h2>
  {{- caller() }}
</div>
{%- endmacro %}

{# ── Simple data table macro ────────────────────────────────────────────── #}
{% macro data_table(headers) %}
<table class="data-table"><thead><tr>
  {%- for h in headers %}<th>{{ h }}</th>{% endfor -%}
</tr></thead><tbody>
{{ caller() }}
</tbody></table>
{% endmacro %}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>yoinkc Report</title>
<style>
:root { --bg: #0f1419; --card: #1a2332; --text: #e6edf3; --muted: #8b949e; --accent: #58a6ff; --warn: #d29922; --error: #f85149; --ok: #3fb950; --code-bg: #0d1117; --border: #30363d; --warn-bg: #2d1f1f; }
[data-theme="light"] { --bg: #f6f8fa; --card: #ffffff; --text: #1f2328; --muted: #57606a; --accent: #0969da; --warn: #9a6700; --error: #cf222e; --ok: #1a7f37; --code-bg: #eaeef2; --border: #d0d7de; --warn-bg: #fff8c5; }
* { box-sizing: border-box; }
body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 1rem; padding-bottom: 70px; line-height: 1.5; }
.container { max-width: 1400px; margin: 0 auto; padding: 0 2rem; }
h1, h2, h3 { margin-top: 0; }
a { color: var(--accent); }
.banner { background: var(--card); border-radius: 8px; padding: 1rem 1.5rem; margin-bottom: 1rem; border-left: 4px solid var(--accent); }
.warning-panel { background: var(--warn-bg); border: 1px solid var(--warn); border-radius: 8px; padding: 1rem; margin-bottom: 1rem; }
.warning-panel.collapsed { display: none; }
.warning-panel-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 0.5rem; }
.warning-panel h3 { color: var(--warn); margin: 0; flex: 1; }
.warning-panel-dismiss { background: var(--card); border: 1px solid var(--warn); color: var(--warn); border-radius: 6px; padding: 0.35rem 0.75rem; cursor: pointer; font-size: 0.9rem; font-weight: 500; white-space: nowrap; }
.warning-panel-dismiss:hover { background: var(--warn); color: var(--bg); border-color: var(--warn); }
.warning-row { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.4rem 0; border-bottom: 1px solid rgba(210,153,34,0.15); }
.warning-row.dismissed { display: none; }
.warning-row:last-child { border-bottom: none; }
.warning-row .warning-msg { flex: 1; font-size: 0.9rem; }
.warning-row-dismiss { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 1.1rem; line-height: 1; padding: 0.15rem 0.35rem; border-radius: 4px; flex-shrink: 0; }
.warning-row-dismiss:hover { color: var(--warn); background: rgba(210,153,34,0.15); }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.section { display: none; background: var(--card); border-radius: 8px; padding: 1.5rem; margin-top: 1rem; max-width: 1200px; }
.section.visible { display: block; animation: fadeIn .15s ease; }
table { width: auto; border-collapse: collapse; }
th, td { text-align: left; padding: .5rem .75rem; border-bottom: 1px solid var(--border); }
th { color: var(--muted); font-weight: 500; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; }
.tabs { display: flex; flex-direction: column; gap: 0; margin-bottom: 1rem; }
.tab-row { display: flex; gap: 0; border-bottom: 1px solid var(--border); flex-wrap: wrap; }
.tabs button { background: transparent; border: none; border-bottom: 2px solid transparent; border-radius: 0; padding: 0.5rem 0.75rem; color: var(--muted); cursor: pointer; transition: color .15s, border-color .15s; }
.tabs button:hover { color: var(--text); }
.tabs button.active { border-bottom-color: var(--accent); color: var(--text); }
tbody tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
tbody tr:hover td { background: rgba(88,166,255,0.06); }
[data-theme="light"] tbody tr:nth-child(even) td { background: rgba(0,0,0,0.02); }
[data-theme="light"] tbody tr:hover td { background: rgba(9,105,218,0.06); }
button:focus-visible, .card:focus-visible, input:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
#warnings-list { max-height: 400px; overflow-y: auto; }
.search { margin-bottom: 1rem; }
.search input { width: 100%; max-width: 400px; padding: .5rem; border-radius: 6px; border: 1px solid var(--border); background: var(--bg); color: var(--text); }
.badge { display: inline-block; padding: .15rem .5rem; border-radius: 4px; font-size: .75rem; }
.badge.ok { background: #238636; color: #fff; }
.badge.warn { background: #9e6a03; color: #fff; }
.badge.error { background: #da3633; color: #fff; }
.badge.info { background: #1f6feb; color: #fff; }
.containerfile-pre { background: var(--code-bg); border: 1px solid var(--border); border-radius: 6px; padding: 1rem; overflow: auto; max-height: 70vh; font-size: 0.85rem; line-height: 1.4; white-space: pre; margin: 0; }
.section-heading-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
.section-heading-row h2 { margin: 0; }
.btn-copy-cf { background: var(--card); border: 1px solid var(--border); color: var(--muted); border-radius: 6px; padding: 0.3rem 0.7rem; cursor: pointer; font-size: 0.78rem; font-family: inherit; transition: color .1s, border-color .1s, background .1s; }
.btn-copy-cf:hover { color: var(--text); border-color: var(--accent); }
.btn-copy-cf.copied { background: var(--ok); border-color: var(--ok); color: #fff; }
[data-theme="light"] .btn-copy-cf.copied { background: #2da44e; border-color: #2da44e; opacity: 0.85; }
.file-browser-layout { display: flex; gap: 1rem; margin-top: 1rem; flex-wrap: wrap; }
.file-tree-panel { flex: 0 1 280px; min-width: 200px; max-height: 70vh; overflow-y: auto; background: var(--code-bg); border: 1px solid var(--border); border-radius: 6px; padding: 0.75rem; }
.file-tree-root { padding: 0; }
.file-tree-root > details { margin-bottom: 0.25rem; }
.file-tree-panel ul { list-style: none; padding-left: 1rem; margin: 0.25rem 0; }
.file-tree-panel .tree-dir summary { cursor: pointer; padding: 0.2rem 0; }
.file-tree-panel .file-entry { background: none; border: none; color: var(--accent); cursor: pointer; padding: 0.2rem 0; text-align: left; font-size: 0.9rem; }
.file-tree-panel .file-entry:hover { text-decoration: underline; }
.file-viewer-panel { flex: 1 1 400px; min-height: 200px; background: var(--code-bg); border: 1px solid var(--border); border-radius: 6px; padding: 1rem; overflow: auto; }
.file-viewer-panel .file-path { color: var(--muted); font-size: 0.85rem; margin-bottom: 0.5rem; }
.file-viewer-panel .file-content-pre { max-height: 65vh; margin: 0; }
.file-content-hidden { display: none; }
.diff-view { max-height: 300px; overflow: auto; font-size: 0.85em; line-height: 1.5; background: var(--code-bg); padding: 0.5rem; border-radius: 4px; }
.diff-add { color: #3fb950; background: rgba(46,160,67,0.08); display: block; border-left: 3px solid #3fb950; padding-left: 0.5rem; }
.diff-del { color: #f85149; background: rgba(248,81,73,0.08); display: block; border-left: 3px solid #f85149; padding-left: 0.5rem; }
.diff-hdr { color: #8b949e; display: block; font-weight: bold; }
.diff-hunk { color: #79c0ff; display: block; }
.summary-hero { font-size: 1.1rem; margin-bottom: 1.5rem; color: var(--muted); }
.summary-meta { display: grid; gap: 0.5rem; margin-bottom: 1.5rem; padding: 1rem; background: var(--code-bg); border-radius: 8px; border: 1px solid var(--border); }
.summary-meta dt { color: var(--muted); font-size: 0.85rem; margin-top: 0.5rem; }
.summary-meta dt:first-child { margin-top: 0; }
.summary-meta dd { margin: 0.15rem 0 0 0; }
.readiness-panel { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
.readiness-col { background: var(--code-bg); border: 1px solid var(--border); border-radius: 8px; padding: 1rem; }
.readiness-col.readiness-auto { border-left: 4px solid var(--ok); }
.readiness-col.readiness-fixme { border-left: 4px solid var(--warn); }
.readiness-col.readiness-manual { border-left: 4px solid var(--error); }
.readiness-header { font-weight: 600; margin-bottom: 0.5rem; }
.readiness-count { font-size: 1.3rem; margin-right: 0.25rem; }
.readiness-col.readiness-auto .readiness-count { color: var(--ok); }
.readiness-col.readiness-fixme .readiness-count { color: var(--warn); }
.readiness-col.readiness-manual .readiness-count { color: var(--error); }
.readiness-col ul { list-style: none; padding: 0; margin: 0; }
.readiness-col li { padding: 0.2rem 0; }
.readiness-link { background: none; border: none; color: var(--accent); cursor: pointer; padding: 0; font-size: 0.9rem; text-align: left; }
.readiness-link:hover { text-decoration: underline; }
::-webkit-scrollbar { width: 8px; height: 8px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--muted); }
.summary-next { margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border); }
.audit-pre { background: var(--code-bg); border: 1px solid var(--border); border-radius: 6px; padding: 1rem; overflow: auto; max-height: 50vh; font-size: 0.85rem; margin: 0.5rem 0; }
.audit-table { margin: 0.5rem 0; }
.audit-section { max-height: 70vh; overflow-y: auto; }
tr.excluded td { text-decoration: line-through; opacity: 0.45; }
tr.excluded td:first-child { text-decoration: none; opacity: 1; }
.include-cb { width: 18px; height: 18px; cursor: pointer; accent-color: #4a9eff; border: 1px solid #8b949e; display: none; }
.repo-badge { display: inline-block; font-size: 0.75rem; padding: 0.15rem 0.5rem; border-radius: 4px; font-weight: 600; }
.repo-badge.epel { background: #1f6feb33; color: #58a6ff; }
.repo-badge.copr { background: #da363333; color: #f85149; }
.repo-badge.rpmfusion { background: #f0883e33; color: #f0883e; }
.repo-badge.base { background: var(--border); color: #8b949e; }
.repo-content-pre { background: var(--code-bg); border: 1px solid var(--border); border-radius: 4px; padding: 0.75rem; font-size: 0.8rem; max-height: 300px; overflow: auto; margin: 0.25rem 0 0; white-space: pre; }
#exclude-toolbar { position: fixed; bottom: 0; left: 0; right: 0; background: var(--card); border-top: 2px solid var(--accent); padding: 0.6rem 1.5rem; display: none; align-items: center; gap: 1rem; z-index: 1000; }
#exclude-toolbar.visible, #exclude-toolbar.helper-active { display: flex; }
#exclude-toolbar .toolbar-status { font-weight: 600; color: var(--warn); flex: 1; }
#exclude-toolbar button { padding: 0.5rem 1rem; border-radius: 6px; border: 1px solid var(--border); cursor: pointer; font-size: 0.9rem; font-weight: 500; }
#btn-download-snapshot { background: var(--card); color: var(--text); }
#btn-rerender { background: var(--card); color: var(--text); }
#btn-tarball { background: var(--card); color: var(--text); }
#exclude-toolbar button.btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
#btn-rerender.disabled { opacity: 0.4; cursor: not-allowed; }
#btn-tarball.disabled { opacity: 0.4; cursor: not-allowed; }
.toast { position: fixed; top: 1rem; right: 1rem; background: #da3633; color: #fff; padding: 0.75rem 1.5rem; border-radius: 8px; z-index: 2000; display: none; }
.toast.visible { display: block; }
.spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid #fff; border-top-color: transparent; border-radius: 50%; animation: spin 0.6s linear infinite; margin-right: 0.5rem; vertical-align: middle; }
@keyframes spin { to { transform: rotate(360deg); } }
#theme-toggle { background: var(--card); border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 0.5rem 1rem; cursor: pointer; font-size: 0.9rem; font-weight: 500; font-family: inherit; white-space: nowrap; transition: background .15s, border-color .15s, color .15s; }
#theme-toggle:hover { background: var(--accent); border-color: var(--accent); color: #fff; }
.page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
.page-header h1 { margin: 0; }
</style>
</head>
<body>
<div class="container">

<div class="page-header">
  <h1>yoinkc Inspection Report</h1>
  <button id="theme-toggle" title="Switch to light theme" aria-label="Toggle theme">&#9728;</button>
</div>

{# ── Banner ─────────────────────────────────────────────────────────────── #}
<div class="banner">
  <strong>Host:</strong> {{ os_desc }} &nbsp;|&nbsp;
  <span style="color:#3fb950">&#10003; {{ triage.automatic }} automatic</span> &nbsp;|&nbsp;
  <span style="color:#d29922">&#9888; {{ triage.fixme }} FIXME</span> &nbsp;|&nbsp;
  <span style="color:#f85149">&#9679; {{ triage.manual }} manual</span> &nbsp;|&nbsp;
  <strong>Warnings:</strong> <span id="banner-warning-count">{{ warnings|length }}</span>
</div>

{# ── Warning panel ──────────────────────────────────────────────────────── #}
{% if warnings %}
<div id="warning-banner" class="warning-panel" data-overflow-count="{{ warnings_overflow }}">
  <div class="warning-panel-header">
    <h3>Warnings &amp; items to review (<span id="warning-banner-count">{{ warnings|length }}</span>)</h3>
    <button type="button" class="warning-panel-dismiss" id="warning-dismiss-all" aria-label="Dismiss All">Dismiss All</button>
  </div>
  <div id="warning-rows">
    {%- for w in warnings_panel %}
    <div class="warning-row" data-warning-idx="{{ loop.index0 }}">
      <span class="badge {{ w.severity|default('warning') }}">{{ w.severity|default('warning') }}</span>
      <span class="warning-msg">{{ (w.message or w.detail or '—') }}</span>
      <button type="button" class="warning-row-dismiss" aria-label="Dismiss">&times;</button>
    </div>
    {%- endfor %}
    {%- if warnings_overflow > 0 %}
    <div class="warning-row" style="color:var(--muted);font-size:0.85rem;justify-content:center;">… and {{ warnings_overflow }} more in the Warnings tab</div>
    {%- endif %}
  </div>
</div>
{% endif %}

{# ── Tab navigation ─────────────────────────────────────────────────────── #}
<div class="tabs">
  <div class="tab-row">
    <button class="active" data-tab="summary">Summary</button>
    <button data-tab="audit">Audit report</button>
    <button data-tab="warnings">Warnings</button>
    <button data-tab="output_files">File browser</button>
    <button data-tab="containerfile">Containerfile</button>
  </div>
  <div class="tab-row">
    <button data-tab="packages">Packages</button>
    <button data-tab="config">Config</button>
    <button data-tab="services">Services</button>
    <button data-tab="users_groups">Users/Groups</button>
    <button data-tab="containers">Containers</button>
    <button data-tab="non_rpm">Non-RPM</button>
  </div>
  <div class="tab-row">
    <button data-tab="scheduled_tasks">Scheduled</button>
    <button data-tab="kernel_boot">Kernel/Boot</button>
    <button data-tab="selinux">SELinux</button>
    <button data-tab="network">Network</button>
    <button data-tab="storage">Storage</button>
    <button data-tab="secrets">Secrets</button>
  </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   Sections
   ══════════════════════════════════════════════════════════════════════════ #}

{# ── Summary ────────────────────────────────────────────────────────────── #}
{% call section("summary", "Summary", visible=true) %}
<p class="summary-hero">Inspection overview and run metadata. Use the cards or tabs above to drill into any category.</p>
<p class="summary-portable" style="font-size:0.9rem;color:var(--muted);">This report is self-contained and portable: all content (Containerfile, audit, config/ and quadlet/ file browser) is embedded. You can copy or share <code>report.html</code> alone.</p>
<dl class="summary-meta">
  <dt>Host root</dt><dd><code>{{ meta.host_root|default('') }}</code></dd>
  <dt>Hostname</dt><dd>{{ meta.hostname|default('—') }}</dd>
  <dt>Inspection time (UTC)</dt><dd>{{ meta.timestamp|default('—') }}</dd>
  <dt>OS</dt><dd>{{ os_desc }}</dd>
</dl>
<h3>Migration readiness</h3>
<div class="readiness-panel">
  {%- set auto_items = triage_detail|selectattr('status', 'equalto', 'automatic')|list %}
  {%- set fixme_items = triage_detail|selectattr('status', 'equalto', 'fixme')|list %}
  {%- set manual_items = triage_detail|selectattr('status', 'equalto', 'manual')|list %}
  <div class="readiness-col readiness-auto">
    <div class="readiness-header"><span class="readiness-count">{{ triage.automatic }}</span> Automatic</div>
    <ul>{%- for item in auto_items %}<li><button type="button" class="readiness-link" onclick="show('{{ item.tab }}');return false">{{ item.count }} {{ item.label }}</button></li>{%- endfor %}</ul>
  </div>
  {%- if fixme_items %}
  <div class="readiness-col readiness-fixme">
    <div class="readiness-header"><span class="readiness-count">{{ triage.fixme }}</span> Needs review</div>
    <ul>{%- for item in fixme_items %}<li><button type="button" class="readiness-link" onclick="show('{{ item.tab }}');return false">{{ item.count }} {{ item.label }}</button></li>{%- endfor %}</ul>
  </div>
  {%- endif %}
  {%- if manual_items %}
  <div class="readiness-col readiness-manual">
    <div class="readiness-header"><span class="readiness-count">{{ triage.manual }}</span> Manual</div>
    <ul>{%- for item in manual_items %}<li><button type="button" class="readiness-link" onclick="show('{{ item.tab }}');return false">{{ item.count }} {{ item.label }}</button></li>{%- endfor %}</ul>
  </div>
  {%- endif %}
</div>
<div class="summary-next">
  <p><strong>Next steps:</strong> Review the <strong>Audit report</strong> tab, fix any FIXMEs in the Containerfile, run <code>podman build -t my-image .</code>, then deploy with <code>bootc switch my-image:latest</code>.</p>
</div>
{% endcall %}

{# ── File browser ─────────────────────────────────────────────────────────── #}
{% call section("output_files", "File browser") %}
<p>Browse <code>config/</code> and <code>quadlet/</code> generated in the output directory. Click a file to view its contents.</p>
<div class="file-browser-layout">
  <div class="file-tree-panel"><div class="file-tree-root">{{ tree_html|safe }}</div></div>
  <div class="file-viewer-panel">
    <div class="file-path" id="file-viewer-path">Click a file</div>
    <div id="file-viewer-content"></div>
  </div>
</div>
{{ file_content_snippets_html|safe }}
{% endcall %}

{# ── Packages ────────────────────────────────────────────────────────────── #}
{% call section("packages", "Packages") %}
  {%- if snapshot.rpm and snapshot.rpm.no_baseline %}
  <p><em>No baseline — showing all packages. Pull the base image or provide --baseline-packages.</em></p>
  {%- endif %}
  {%- if snapshot.rpm and snapshot.rpm.packages_added %}

  {%- if snapshot.rpm.leaf_packages is not none and snapshot.rpm.leaf_dep_tree is not none %}
  {%- set auto_set = snapshot.rpm.auto_packages or [] %}
  {%- set dep_tree = snapshot.rpm.leaf_dep_tree or {} %}

  <div class="banner" id="pkg-selection-banner" style="margin-bottom:1rem">
    <strong>{{ leaf_packages_sorted|length }} leaf packages</strong> pull in <strong>{{ auto_set|length }} dependencies</strong>
    — only leaf packages appear in the Containerfile's <code>dnf install</code> line.
  </div>

  {%- if snapshot.rpm.repo_files %}
  <h3>Repositories ({{ snapshot.rpm.repo_files|length }})</h3>
  <table class="data-table" id="pkg-repo-table">
    <thead><tr><th></th><th>Path</th><th></th><th></th></tr></thead>
    <tbody>
    {%- for rf in snapshot.rpm.repo_files %}
    <tr{% if not rf.include %} class="excluded"{% endif %} data-snap-section="rpm" data-snap-list="repo_files" data-snap-index="{{ loop.index0 }}">
      <td><input type="checkbox" class="include-cb repo-cb" {{ 'checked' if rf.include else '' }}{{ ' disabled title="Default distribution repository — cannot be excluded"' if rf.is_default_repo else '' }}/></td>
      <td><code>{{ rf.path }}</code></td>
      <td>
        {%- if repo_display[loop.index0].badge %}
        <span class="repo-badge {{ repo_display[loop.index0].badge }}">{{ repo_display[loop.index0].badge|upper }}</span>
        {%- endif %}
      </td>
      <td>
        {%- if rf.content %}
        <details><summary>show</summary>
          <pre class="repo-content-pre">{{ rf.content }}</pre>
        </details>
        {%- endif %}
      </td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  {%- endif %}

  <h3>Dependency Tree</h3>
  {%- if repo_groups %}
  {%- for repo_name, entries in repo_groups.items() %}
  <h4 style="margin-top:1.5rem">{{ repo_name }} ({{ entries|length }} package{{ 's' if entries|length != 1 else '' }})</h4>
  <table class="data-table pkg-dep-tree-group">
    <thead><tr><th></th><th>Leaf Package</th><th>Dependencies</th><th></th></tr></thead>
    <tbody>
    {%- for entry in entries %}
    <tr{% if not entry.include %} class="excluded"{% endif %} data-leaf="{{ entry.name }}" data-snap-section="rpm" data-snap-list="packages_added" data-snap-index="{{ entry.snap_index }}">
      <td><input type="checkbox" class="include-cb leaf-cb" {{ 'checked' if entry.include else '' }}/></td>
      <td><strong>{{ entry.name }}</strong></td>
      <td>{{ entry.deps|length }}</td>
      <td>
        {%- if entry.deps %}
        <details><summary>show</summary>
          <ul style="margin:0.25rem 0;padding-left:1.5rem">
          {%- for d in entry.deps %}
            <li style="font-size:0.85em">{{ d }}</li>
          {%- endfor %}
          </ul>
        </details>
        {%- else %}
        <em style="color:var(--muted)">independent</em>
        {%- endif %}
      </td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  {%- endfor %}
  {%- else %}
  {# Fallback: flat table when repo_groups is not populated #}
  <table class="data-table" id="pkg-dep-tree">
    <thead><tr><th></th><th>Leaf Package</th><th>Repo</th><th>Dependencies</th><th></th></tr></thead>
    <tbody>
    {%- for lf in leaf_packages_sorted if dep_tree.get(lf) is not none %}
    {%- set deps = dep_tree.get(lf, []) %}
    {%- set leaf_idx = namespace(val=-1) %}
    {%- for p in snapshot.rpm.packages_added %}
      {%- if p.name == lf %}{% set leaf_idx.val = loop.index0 %}{% endif %}
    {%- endfor %}
    <tr{% if leaf_idx.val >= 0 and not snapshot.rpm.packages_added[leaf_idx.val].include %} class="excluded"{% endif %} data-leaf="{{ lf }}" data-snap-section="rpm" data-snap-list="packages_added" data-snap-index="{{ leaf_idx.val }}">
      <td><input type="checkbox" class="include-cb leaf-cb" {{ 'checked' if leaf_idx.val < 0 or snapshot.rpm.packages_added[leaf_idx.val].include else '' }}/></td>
      <td><strong>{{ lf }}</strong></td>
      <td style="font-size:0.85em;color:var(--muted)">{{ snapshot.rpm.packages_added[leaf_idx.val].source_repo if leaf_idx.val >= 0 else '' }}</td>
      <td>{{ deps|length }}</td>
      <td>
        {%- if deps %}
        <details><summary>show</summary>
          <ul style="margin:0.25rem 0;padding-left:1.5rem">
          {%- for d in deps %}
            <li style="font-size:0.85em">{{ d }}</li>
          {%- endfor %}
          </ul>
        </details>
        {%- else %}
        <em style="color:var(--muted)">independent</em>
        {%- endif %}
      </td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  {%- endif %}

  {%- set leaf_names = snapshot.rpm.leaf_packages %}
  {%- set auto_names = snapshot.rpm.auto_packages or [] %}
  {%- set unclassified_pkgs = [] %}
  {%- for p in snapshot.rpm.packages_added %}
    {%- if p.name not in leaf_names and p.name not in auto_names %}
      {%- set _ = unclassified_pkgs.append(p) %}
    {%- endif %}
  {%- endfor %}
  {%- if unclassified_pkgs %}
  <h3 style="margin-top:1.5rem">Unclassified Packages ({{ unclassified_pkgs|length }})</h3>
  <p style="font-size:0.85em;color:var(--muted)">These packages could not be classified as leaf or auto-dependency. They are included in the Containerfile by default.</p>
  <table class="data-table">
    <thead><tr><th></th><th>Name</th><th>Version</th><th>Arch</th></tr></thead>
    <tbody>
    {%- for p in unclassified_pkgs %}
    {%- set uidx = namespace(val=-1) %}
    {%- for q in snapshot.rpm.packages_added %}
      {%- if q.name == p.name %}{% set uidx.val = loop.index0 %}{% endif %}
    {%- endfor %}
    <tr{% if not p.include %} class="excluded"{% endif %} data-snap-section="rpm" data-snap-list="packages_added" data-snap-index="{{ uidx.val }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if p.include else '' }}/></td>
      <td>{{ p.name }}</td>
      <td>{{ p.version }}-{{ p.release }}</td>
      <td>{{ p.arch }}</td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  {%- endif %}

  {%- else %}
  <table><thead><tr><th></th><th>Name</th><th>Version</th><th>Release</th><th>Arch</th></tr></thead><tbody>
    {%- for p in snapshot.rpm.packages_added[:100] %}
    <tr{% if not p.include %} class="excluded"{% endif %} data-snap-section="rpm" data-snap-list="packages_added" data-snap-index="{{ loop.index0 }}"><td><input type="checkbox" class="include-cb" {{ 'checked' if p.include else '' }}/></td><td>{{ p.name }}</td><td>{{ p.version }}</td><td>{{ p.release }}</td><td>{{ p.arch }}</td></tr>
    {%- endfor %}
  </tbody></table>
  {%- if snapshot.rpm.packages_added|length > 100 %}
  <p>... and {{ snapshot.rpm.packages_added|length - 100 }} more.</p>
  {%- endif %}
  {%- endif %}

  {%- else %}
  <p>No added packages.</p>
  {%- endif %}
{% endcall %}

{# ── Services ────────────────────────────────────────────────────────────── #}
{% call section("services", "Services") %}
  {%- if snapshot.services and snapshot.services.state_changes | selectattr('action', 'ne', 'unchanged') | list %}
  <table><thead><tr><th></th><th>Unit</th><th>Current</th><th>Default</th><th>Action</th></tr></thead><tbody>
    {%- for s in snapshot.services.state_changes %}
    {%- if s.action != 'unchanged' %}
    <tr{% if not s.include %} class="excluded"{% endif %} data-snap-section="services" data-snap-list="state_changes" data-snap-index="{{ loop.index0 }}"><td><input type="checkbox" class="include-cb" {{ 'checked' if s.include else '' }}/></td><td>{{ s.unit }}</td><td>{{ s.current_state }}</td><td>{{ s.default_state }}</td><td>{{ s.action }}</td></tr>
    {%- endif %}
    {%- endfor %}
  </tbody></table>
  {%- else %}
  <p>No service changes.</p>
  {%- endif %}

  {%- if snapshot.services and snapshot.services.drop_ins %}
  <h3>Systemd drop-in overrides ({{ snapshot.services.drop_ins|length }})</h3>
  <table><thead><tr><th></th><th>Parent unit</th><th>Drop-in path</th><th>Content</th></tr></thead><tbody>
    {%- for d in snapshot.services.drop_ins %}
    <tr{% if not d.include %} class="excluded"{% endif %} data-snap-section="services" data-snap-list="drop_ins" data-snap-index="{{ loop.index0 }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if d.include else '' }}/></td>
      <td>{{ d.unit }}</td>
      <td><code>{{ d.path }}</code></td>
      <td>
        {%- if d.content.strip() %}
        <details><summary>show</summary>
          <pre style="background:var(--code-bg);border:1px solid var(--border);border-radius:4px;padding:0.5rem;font-size:0.8rem;max-height:200px;overflow:auto;margin:0.25rem 0">{{ d.content }}</pre>
        </details>
        {%- endif %}
      </td>
    </tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}
{% endcall %}

{# ── Config ──────────────────────────────────────────────────────────────── #}
{% call section("config", "Configuration files") %}
  {%- if snapshot.config and snapshot.config.files %}
  <table><thead><tr><th></th><th>Path</th><th>Kind</th><th>rpm -Va flags</th><th>Diff</th></tr></thead><tbody>
    {%- for item in config_files_rendered %}
    <tr{% if not item.include %} class="excluded"{% endif %} data-snap-section="config" data-snap-list="files" data-snap-index="{{ item.snap_index }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if item.include else '' }}/></td>
      <td><code>{{ item.path }}</code></td>
      <td>{{ item.kind }}</td>
      <td>{% if item.flags %}<code>{{ item.flags }}</code>{% endif %}</td>
      <td>{{ item.diff_html|safe }}</td>
    </tr>
    {%- endfor %}
  </tbody></table>
  {%- else %}
  <p>No config files.</p>
  {%- endif %}
{% endcall %}

{# ── Non-RPM software ────────────────────────────────────────────────────── #}
{% call section("non_rpm", "Non-RPM software") %}
  {%- set nr = snapshot.non_rpm_software %}
  {%- if nr and nr.items %}
  {%- set nd = non_rpm_data %}

  {%- if nd.elf %}
  <h3>Compiled binaries</h3>
  <table><tr><th></th><th>Path</th><th>Language</th><th>Linking</th><th>Shared Libraries</th></tr>
    {%- for i in nd.elf %}
    {%- set lang = i.lang %}
    {%- set lang_colors = {'go': '#00ADD8', 'rust': '#DEA584', 'c/c++': '#555'} %}
    {%- set color = lang_colors.get(lang, '#999') %}
    {%- set linking = 'static' if i.static else 'dynamic' %}
    {%- set link_color = '#4caf50' if i.static else '#ff9800' %}
    {%- set nr_idx = namespace(val=-1) %}
    {%- for item in nr.items %}{% if item.path == i.path %}{% set nr_idx.val = loop.index0 %}{% endif %}{%- endfor %}
    <tr{% if not i.include %} class="excluded"{% endif %} data-snap-section="non_rpm_software" data-snap-list="items" data-snap-index="{{ nr_idx.val }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if i.include else '' }}/></td>
      <td><code>{{ i.path }}</code></td>
      <td><span style="background:{{ color }};color:#fff;padding:2px 8px;border-radius:4px">{{ lang }}</span></td>
      <td><span style="background:{{ link_color }};color:#fff;padding:2px 8px;border-radius:4px">{{ linking }}</span></td>
      <td style="font-size:0.85em">{{ i.shared_libs[:5]|join(', ') or '' }}</td>
    </tr>
    {%- endfor %}
  </table>
  {%- endif %}

  {%- if nd.venv %}
  <h3>Python virtual environments</h3>
  {%- for v in nd.venv %}
  {%- set ssp = v.system_site_packages %}
  <h4><code>{{ v.path }}</code>
    {%- if ssp %} <span style="background:#f44336;color:#fff;padding:2px 8px;border-radius:4px">system-site-packages</span>
    {%- else %} <span style="background:#4caf50;color:#fff;padding:2px 8px;border-radius:4px">isolated</span>
    {%- endif %}
  </h4>
  {%- set pkgs = v.packages %}
  {%- if pkgs %}
  <table><tr><th>Package</th><th>Version</th></tr>
    {%- for p in pkgs[:20] %}
    <tr><td>{{ p.name }}</td><td>{{ p.version }}</td></tr>
    {%- endfor %}
    {%- if pkgs|length > 20 %}
    <tr><td colspan="2"><em>+{{ pkgs|length - 20 }} more</em></td></tr>
    {%- endif %}
  </table>
  {%- else %}
  <p>No packages found.</p>
  {%- endif %}
  {%- endfor %}
  {%- endif %}

  {%- if nd.git %}
  <h3>Git-managed directories</h3>
  <table><tr><th>Path</th><th>Remote</th><th>Branch</th><th>Commit</th></tr>
    {%- for i in nd.git %}
    <tr>
      <td><code>{{ i.path }}</code></td>
      <td><code>{{ i.git_remote }}</code></td>
      <td>{{ i.git_branch }}</td>
      <td><code>{{ i.git_commit[:12] }}</code></td>
    </tr>
    {%- endfor %}
  </table>
  {%- endif %}

  {%- if nd.pip %}
  <h3>System pip packages</h3>
  <table><tr><th></th><th>Package</th><th>Version</th><th>Path</th></tr>
    {%- for i in nd.pip[:20] %}
    {%- set nr_idx = namespace(val=-1) %}
    {%- for item in nr.items %}{% if item.path == i.path and item.name == i.name %}{% set nr_idx.val = loop.index0 %}{% endif %}{%- endfor %}
    <tr{% if not i.include %} class="excluded"{% endif %} data-snap-section="non_rpm_software" data-snap-list="items" data-snap-index="{{ nr_idx.val }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if i.include else '' }}/></td>
      <td>{{ i.name }}</td>
      <td>{{ i.version }}</td>
      <td><code>{{ i.path }}</code></td>
    </tr>
    {%- endfor %}
  </table>
  {%- endif %}

  {%- if nd.other %}
  <h3>Other non-RPM items</h3>
  <table><tr><th>Path</th><th>Confidence</th><th>Method</th></tr>
    {%- for i in nd.other[:20] %}
    <tr>
      <td><code>{{ i.path or i.name }}</code></td>
      <td>{{ i.confidence }}</td>
      <td>{{ i.method }}</td>
    </tr>
    {%- endfor %}
  </table>
  {%- endif %}

  {%- if nr and nr.env_files %}
  <h3>Dotenv / secret files ({{ nr.env_files|length }})</h3>
  <p style="color:var(--amber)">⚠ These files may contain API keys or passwords. Secrets have been redacted; inject them at deploy time via a secret store or systemd credentials.</p>
  <table class="data-table"><thead><tr><th>Path</th><th>Status</th></tr></thead><tbody>
    {%- for ef in nr.env_files %}
    <tr>
      <td><code>{{ ef.path }}</code></td>
      <td>captured &amp; redacted</td>
    </tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}

  {%- else %}
  <p>No non-RPM software.</p>
  {%- endif %}
{% endcall %}

{# ── Containers ──────────────────────────────────────────────────────────── #}
{% call section("containers", "Containers") %}
  {%- set ct = snapshot.containers %}
  {%- if ct and (ct.quadlet_units or ct.compose_files or ct.running_containers) %}

  {%- if ct.quadlet_units %}
  <h3>Quadlet units</h3>
  <table><tr><th></th><th>Unit</th><th>Image</th><th>Path</th></tr>
    {%- for u in ct.quadlet_units %}
    <tr{% if not u.include %} class="excluded"{% endif %} data-snap-section="containers" data-snap-list="quadlet_units" data-snap-index="{{ loop.index0 }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if u.include else '' }}/></td>
      <td>{{ u.name }}</td>
      <td>{% if u.image %}<code>{{ u.image }}</code>{% else %}<em>none</em>{% endif %}</td>
      <td><code>{{ u.path }}</code></td>
    </tr>
    {%- endfor %}
  </table>
  {%- endif %}

  {%- if ct.compose_files %}
  <h3>Compose files</h3>
  {%- for c in ct.compose_files %}
  <div{% if not c.include %} style="opacity:0.45;text-decoration:line-through"{% endif %} data-snap-section="containers" data-snap-list="compose_files" data-snap-index="{{ loop.index0 }}">
  <label><input type="checkbox" class="include-cb" {{ 'checked' if c.include else '' }}/></label>
  <h4 style="display:inline"><code>{{ c.path }}</code></h4>
  {%- if c.images %}
  <table><tr><th>Service</th><th>Image</th></tr>
    {%- for img in c.images %}
    <tr><td>{{ img.service }}</td><td><code>{{ img.image }}</code></td></tr>
    {%- endfor %}
  </table>
  {%- else %}
  <p>No image references found.</p>
  {%- endif %}
  </div>
  {%- endfor %}
  {%- endif %}

  {%- if ct.running_containers %}
  <h3>Running containers (podman)</h3>
  <table><tr><th>Name</th><th>Image</th><th>Status</th><th>Mounts</th><th>Networks</th></tr>
    {%- for item in containers_data.running %}
    <tr>
      <td><strong>{{ item.name }}</strong></td>
      <td><code>{{ item.image }}</code></td>
      <td>{{ item.status }}</td>
      <td style="font-size:0.85em">{{ item.mount_summary|safe }}</td>
      <td style="font-size:0.85em">{{ item.net_summary or '' }}</td>
    </tr>
    {%- endfor %}
  </table>
  {%- endif %}

  {%- else %}
  <p>No container workloads.</p>
  {%- endif %}
{% endcall %}

{# ── Users / Groups ───────────────────────────────────────────────────────── #}
{% call section("users_groups", "Users and groups") %}
  {%- if snapshot.users_groups and snapshot.users_groups.users %}
  {%- set ug = snapshot.users_groups %}
  {%- set strategies = ["sysusers", "blueprint", "useradd", "kickstart"] %}

  <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem">
    <span style="color:var(--muted);font-size:0.9em">Apply strategy to all users:</span>
    <select id="strategy-apply-all" style="background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:2px 4px;font-size:0.85em">
      {%- for s in strategies %}
      <option value="{{ s }}">{{ s }}</option>
      {%- endfor %}
    </select>
    <button type="button" id="btn-strategy-apply-all" style="background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-size:0.85em;cursor:pointer">Apply</button>
  </div>

  <table class="data-table">
    <thead><tr><th></th><th>User</th><th>UID/GID</th><th>Shell</th><th>Home</th><th>Type</th><th>Strategy</th><th>Notes</th></tr></thead>
    <tbody>
    {%- for u in ug.users %}
    {%- set cls = u.classification or '?' %}
    {%- set cls_color = '#4caf50' if cls == 'service' else '#2196f3' if cls == 'human' else '#ff9800' %}
    <tr{% if not u.get('include', true) %} class="excluded"{% endif %} data-snap-section="users_groups" data-snap-list="users" data-snap-index="{{ loop.index0 }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if u.get('include', true) else '' }}/></td>
      <td><strong>{{ u.name }}</strong></td>
      <td>{{ u.uid }}:{{ u.gid or '?' }}</td>
      <td><code>{{ u.shell }}</code></td>
      <td><code>{{ u.home }}</code></td>
      <td><span style="background:{{ cls_color }};color:#fff;padding:2px 8px;border-radius:4px;font-size:0.8em">{{ cls }}</span></td>
      <td>
        <select class="strategy-select" style="background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:2px 4px;font-size:0.85em">
          {%- for s in strategies %}
          <option value="{{ s }}" {{ 'selected' if s == u.strategy else '' }}>{{ s }}</option>
          {%- endfor %}
        </select>
      </td>
      <td style="font-size:0.85em">
        {%- set notes = [] %}
        {%- if u.name in (ug.ssh_authorized_keys_refs or [])|map(attribute='user')|list %}
          {%- set _ = notes.append('SSH keys') %}
          <span style="background:var(--warn);color:#fff;padding:1px 6px;border-radius:3px;font-size:0.8em" title="authorized_keys found on source but not included in image">SSH KEYS</span>
        {%- endif %}
        {%- if cls == 'ambiguous' %}
          <span style="background:var(--warn);color:#fff;padding:1px 6px;border-radius:3px;font-size:0.8em" title="Classification uncertain — verify intent">ambiguous</span>
        {%- endif %}
      </td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>

  {%- if ug.groups %}
  <h3>Groups</h3>
  <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem">
    <span style="color:var(--muted);font-size:0.9em">Apply strategy to all groups:</span>
    <select id="strategy-apply-all-groups" style="background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:2px 4px;font-size:0.85em">
      {%- for s in strategies %}
      <option value="{{ s }}">{{ s }}</option>
      {%- endfor %}
    </select>
    <button type="button" id="btn-strategy-apply-all-groups" style="background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-size:0.85em;cursor:pointer">Apply</button>
  </div>
  <table class="data-table">
    <thead><tr><th></th><th>Group</th><th>GID</th><th>Strategy</th><th>Members</th></tr></thead>
    <tbody>
    {%- for g in ug.groups %}
    <tr{% if not g.get('include', true) %} class="excluded"{% endif %} data-snap-section="users_groups" data-snap-list="groups" data-snap-index="{{ loop.index0 }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if g.get('include', true) else '' }}/></td>
      <td>{{ g.name }}</td>
      <td>{{ g.gid }}</td>
      <td>
        <select class="strategy-select" style="background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:2px 4px;font-size:0.85em">
          {%- for s in strategies %}
          <option value="{{ s }}" {{ 'selected' if s == g.strategy else '' }}>{{ s }}</option>
          {%- endfor %}
        </select>
      </td>
      <td>{{ (g.members or [])|join(', ') or '—' }}</td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  {%- endif %}

  {%- else %}
  <p>No non-system users/groups.</p>
  {%- endif %}
{% endcall %}

{# ── Scheduled jobs ───────────────────────────────────────────────────────── #}
{% call section("scheduled_tasks", "Scheduled jobs") %}
  {%- set st = snapshot.scheduled_tasks %}
  {%- if st and (st.cron_jobs or st.systemd_timers or st.generated_timer_units or st.at_jobs) %}

  {%- set local_timers = [] %}{%- set vendor_timers = [] %}
  {%- for t in st.systemd_timers %}
    {%- if t.source == 'local' %}{% set _ = local_timers.append(t) %}
    {%- elif t.source == 'vendor' %}{% set _ = vendor_timers.append(t) %}
    {%- endif %}
  {%- endfor %}

  {%- if local_timers or vendor_timers %}
  <h3>Existing systemd timers</h3>
  {%- if vendor_timers %}
  <p style="color:var(--muted);font-size:0.9em">{{ vendor_timers|length }} vendor timer{{ 's' if vendor_timers|length != 1 else '' }} (base image defaults) not shown.</p>
  {%- endif %}
  {%- if local_timers %}
  <table><tr><th>Timer</th><th>Schedule</th><th>ExecStart</th></tr>
    {%- for t in local_timers %}
    <tr style="background:rgba(63,185,80,0.1)">
      <td>{{ t.name }}</td><td>{{ t.on_calendar }}</td>
      <td><code>{{ t.exec_start }}</code></td>
    </tr>
    {%- endfor %}
  </table>
  {%- endif %}
  {%- endif %}

  {%- if st.generated_timer_units %}
  <h3>Cron-converted timers</h3>
  <table><tr><th></th><th>Name</th><th>Cron Expression</th><th>Source File</th></tr>
    {%- for u in st.generated_timer_units %}
    <tr{% if not u.include %} class="excluded"{% endif %} style="background:rgba(210,153,34,0.1)" data-snap-section="scheduled_tasks" data-snap-list="generated_timer_units" data-snap-index="{{ loop.index0 }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if u.include else '' }}/></td>
      <td>{{ u.name }}</td>
      <td><code>{{ u.cron_expr }}</code></td>
      <td><code>{{ u.source_path }}</code></td>
    </tr>
    {%- endfor %}
  </table>
  {%- endif %}

  {%- set rpm_cron_count = st.cron_jobs | selectattr('rpm_owned') | list | length %}
  {%- if st.cron_jobs %}
  <h3>Cron jobs</h3>
  {%- if rpm_cron_count %}
  <p style="color:var(--muted);font-size:0.9em">{{ rpm_cron_count }} package-owned cron job{{ 's' if rpm_cron_count != 1 else '' }} (base image defaults) not shown.</p>
  {%- endif %}
  {%- if st.cron_jobs | selectattr('rpm_owned', 'equalto', false) | list %}
  <table>
    <tr><th></th><th>Path</th><th>Source</th><th>Action</th></tr>
    {%- for j in st.cron_jobs %}
    {%- if not j.rpm_owned %}
    <tr{% if not j.include %} class="excluded"{% endif %} data-snap-section="scheduled_tasks" data-snap-list="cron_jobs" data-snap-index="{{ loop.index0 }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if j.include else '' }}/></td>
      <td><code>{{ j.path }}</code></td>
      <td>{{ j.source }}</td>
      <td>Convert to systemd timer</td>
    </tr>
    {%- endif %}
    {%- endfor %}
  </table>
  {%- endif %}
  {%- endif %}

  {%- if st.at_jobs %}
  <h3>At jobs</h3>
  <table><tr><th>File</th><th>User</th><th>Command</th></tr>
    {%- for a in st.at_jobs %}
    {%- set cmd = a.command[:117] ~ '...' if a.command|length > 120 else a.command %}
    <tr><td><code>{{ a.file }}</code></td><td>{{ a.user }}</td><td><code>{{ cmd }}</code></td></tr>
    {%- endfor %}
  </table>
  {%- endif %}

  {%- else %}
  <p>No scheduled tasks.</p>
  {%- endif %}
{% endcall %}

{# ── Kernel / Boot ────────────────────────────────────────────────────────── #}
{% call section("kernel_boot", "Kernel and boot") %}
  {%- set kb = snapshot.kernel_boot %}
  {%- if kb and (kb.cmdline or kb.sysctl_overrides or kb.non_default_modules or kb.modules_load_d or kb.modprobe_d or kb.dracut_conf or kb.tuned_active or kb.tuned_custom_profiles) %}

  {%- if kb.cmdline %}
  <p><strong>cmdline:</strong> <code>{{ kb.cmdline[:300] }}</code></p>
  {%- endif %}

  {%- if kb.non_default_modules %}
  <p style="color:var(--muted);font-size:0.9em">{{ kb.non_default_modules|length }} kernel module(s) were loaded at inspection time (hardware-specific, not included in the image). See modules-load.d entries below for explicitly configured modules.</p>
  {%- endif %}

  {%- if kb.sysctl_overrides %}
  <h3>Non-default sysctl values ({{ kb.sysctl_overrides|length }})</h3>
  <table class="data-table"><thead><tr><th></th><th>Key</th><th>Runtime</th><th>Default</th><th>Source</th></tr></thead><tbody>
    {%- for s in kb.sysctl_overrides %}
    <tr{% if not s.include %} class="excluded"{% endif %} data-snap-section="kernel_boot" data-snap-list="sysctl_overrides" data-snap-index="{{ loop.index0 }}">
      <td><input type="checkbox" class="include-cb" {{ 'checked' if s.include else '' }}/></td>
      <td><code>{{ s.key }}</code></td>
      <td style="color:#d29922;font-weight:bold">{{ s.runtime }}</td>
      <td>{{ s.default or '—' }}</td>
      <td><code>{{ s.source }}</code></td>
    </tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}

  {%- if kb.modules_load_d %}<p>modules-load.d: {{ kb.modules_load_d|length }} file(s)</p>{%- endif %}
  {%- if kb.modprobe_d %}<p>modprobe.d: {{ kb.modprobe_d|length }} file(s)</p>{%- endif %}
  {%- if kb.dracut_conf %}<p>dracut.conf.d: {{ kb.dracut_conf|length }} file(s)</p>{%- endif %}

  {%- if kb.tuned_active or kb.tuned_custom_profiles %}
  <h3>Tuned profile</h3>
  {%- if kb.tuned_active %}<p>Active profile: <strong>{{ kb.tuned_active }}</strong></p>{%- endif %}
  {%- if kb.tuned_custom_profiles %}
  <p>Custom profiles ({{ kb.tuned_custom_profiles|length }}):</p>
  <ul>
    {%- for tp in kb.tuned_custom_profiles %}
    <li><code>{{ tp.path }}</code></li>
    {%- endfor %}
  </ul>
  {%- endif %}
  {%- endif %}

  {%- else %}
  <p>No kernel/boot customizations detected.</p>
  {%- endif %}
{% endcall %}

{# ── SELinux ──────────────────────────────────────────────────────────────── #}
{% call section("selinux", "SELinux / Security") %}
  {%- set se = snapshot.selinux %}
  {%- if se and (se.mode or se.custom_modules or se.boolean_overrides or se.audit_rules or se.fips_mode or se.port_labels or se.fcontext_rules or se.pam_configs) %}

  {%- if se.mode %}<p><strong>Mode:</strong> {{ se.mode }}</p>{%- endif %}
  {%- if se.fips_mode %}<p><strong>FIPS mode:</strong> enabled</p>{%- endif %}

  {%- if se.custom_modules %}
  <h3>Custom policy modules ({{ se.custom_modules|length }})</h3>
  <ul>{%- for m in se.custom_modules %}<li><code>{{ m }}</code></li>{%- endfor %}</ul>
  {%- endif %}

  {%- set non_default = se.boolean_overrides|selectattr('non_default')|list %}
  {%- set unchanged_count = (se.boolean_overrides|length) - (non_default|length) %}
  {%- if non_default %}
  <h3>Non-default booleans ({{ non_default|length }})</h3>
  <table class="data-table"><thead><tr><th>Boolean</th><th>Current</th><th>Default</th><th>Description</th></tr></thead><tbody>
    {%- for b in non_default %}
    {%- set cur = b.get('current', '?') %}
    <tr>
      <td><code>{{ b.get('name', '?') }}</code></td>
      <td style="{{ 'color:#3fb950' if cur == 'on' else 'color:#f85149' }};font-weight:bold">{{ cur }}</td>
      <td>{{ b.get('default', '?') }}</td>
      <td>{{ b.get('description', '') }}</td>
    </tr>
    {%- endfor %}
  </tbody></table>
  {%- if unchanged_count > 0 %}<p>{{ unchanged_count }} boolean(s) at default values (not shown).</p>{%- endif %}
  {%- endif %}

  {%- if se.port_labels %}
  <h3>Custom port labels ({{ se.port_labels|length }})</h3>
  <table class="data-table"><thead><tr><th>Protocol</th><th>Port</th><th>SELinux type</th></tr></thead><tbody>
    {%- for pl in se.port_labels %}
    <tr>
      <td><code>{{ pl.protocol }}</code></td>
      <td><code>{{ pl.port }}</code></td>
      <td><code>{{ pl.type }}</code></td>
    </tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}

  {%- if se.audit_rules %}<p>Audit rule files: {{ se.audit_rules|length }}</p>{%- endif %}
  {%- if se.pam_configs %}<p>PAM configs: {{ se.pam_configs|length }}</p>{%- endif %}

  {%- else %}
  <p>No SELinux/security customizations detected.</p>
  {%- endif %}
{% endcall %}

{# ── Secrets ──────────────────────────────────────────────────────────────── #}
{% call section("secrets", "Secrets") %}
  {%- if secrets_data %}
  <p><strong>{{ secrets_data|length }} value(s) redacted</strong> across <strong>{{ secrets_file_count }} file(s)</strong>.</p>
  <table class="data-table">
    <thead><tr><th>File Path</th><th>Pattern</th><th>Line</th><th>Remediation</th></tr></thead>
    <tbody>
    {%- for r in secrets_data %}
    <tr>
      <td><code>{{ r.path or '?' }}</code></td>
      <td>{{ r.pattern or '?' }}</td>
      <td>{{ r.line or '?' }}</td>
      <td style="font-size:0.85em">{{ r.remediation or '' }}</td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  {%- else %}
  <p style="color:var(--ok)">No secrets detected.</p>
  {%- endif %}
{% endcall %}

{# ── Network ─────────────────────────────────────────────────────────────── #}
{% call section("network", "Network") %}
  {%- set net = snapshot.network %}
  {%- if net and (net.connections or net.firewall_zones or net.firewall_direct_rules or net.ip_routes or net.ip_rules or net.resolv_provenance) %}

  {%- if net.connections %}
  <h3>Connections</h3>
  <table class="data-table"><thead><tr><th>Name</th><th>Method</th><th>Type</th><th>Deployment</th></tr></thead><tbody>
    {%- for c in net.connections %}
    <tr>
      <td><code>{{ c.name }}</code></td>
      <td>{{ c.method }}</td>
      <td>{{ c.type }}</td>
      <td>
        {%- if c.method == 'static' -%}
        <span style="color:#3fb950;font-weight:bold">Bake into image</span>
        {%- elif c.method == 'dhcp' -%}
        <span style="color:#d29922;font-weight:bold">Kickstart at deploy</span>
        {%- else -%}
        <span style="color:var(--muted)">Review</span>
        {%- endif -%}
      </td>
    </tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}

  {%- if net.firewall_zones %}
  <h3>Firewall zones <span style="color:#3fb950;font-size:0.8em">(bake into image)</span></h3>
  {%- for z in net.firewall_zones %}
  <h4>{{ z.name }}</h4>
  {%- if z.services %}<p>Services: <code>{{ z.services|join(', ') }}</code></p>{%- endif %}
  {%- if z.ports %}<p>Ports: <code>{{ z.ports|join(', ') }}</code></p>{%- endif %}
  {%- if z.rich_rules %}
  <p>Rich rules ({{ z.rich_rules|length }}):</p><ul>
    {%- for r in z.rich_rules %}<li><code>{{ r[:300] }}</code></li>{%- endfor %}
  </ul>
  {%- endif %}
  {%- endfor %}
  {%- endif %}

  {%- if net.firewall_direct_rules %}
  <h3>Firewall direct rules <span style="color:#3fb950;font-size:0.8em">(bake into image)</span></h3>
  <ul>
    {%- for r in net.firewall_direct_rules %}
    <li>{{ r.ipv }} {{ r.chain }}: <code>{{ r.args }}</code></li>
    {%- endfor %}
  </ul>
  {%- endif %}

  {%- if net.resolv_provenance %}
  <h3>DNS</h3>
  <p>resolv.conf provenance:
    {%- if net.resolv_provenance == 'networkmanager' %}
    <span style="color:#d29922;font-weight:bold">NetworkManager-managed</span> — DHCP-assigned DNS — kickstart at deploy time
    {%- elif net.resolv_provenance == 'systemd-resolved' %}
    <span style="color:#d29922;font-weight:bold">systemd-resolved</span> — system resolver — kickstart at deploy time
    {%- else %}
    <span style="color:#3fb950;font-weight:bold">hand-edited</span> — bake /etc/resolv.conf into image or manage at deploy
    {%- endif %}
  </p>
  {%- endif %}

  {%- if net.ip_routes %}
  {%- set static_rt = [] %}
  {%- for r in net.ip_routes %}{% if 'proto static' in r %}{% set _ = static_rt.append(r) %}{% endif %}{%- endfor %}
  {%- if static_rt %}
  <h3>Static routes ({{ static_rt|length }})</h3><ul>
    {%- for r in static_rt %}<li><code>{{ r }}</code></li>{%- endfor %}
  </ul>
  {%- endif %}
  {%- endif %}

  {%- if net.ip_rules %}
  <h3>Policy routing rules ({{ net.ip_rules|length }})</h3><ul>
    {%- for r in net.ip_rules %}<li><code>{{ r }}</code></li>{%- endfor %}
  </ul>
  {%- endif %}

  {%- else %}
  <p>No network config captured.</p>
  {%- endif %}
{% endcall %}

{# ── Storage ─────────────────────────────────────────────────────────────── #}
{% call section("storage", "Storage") %}
  {%- if snapshot.storage and snapshot.storage.fstab_entries %}
  <table><thead><tr><th>Device</th><th>Mount</th><th>Type</th></tr></thead><tbody>
    {%- for e in snapshot.storage.fstab_entries[:30] %}
    <tr><td>{{ e.device }}</td><td>{{ e.mount_point }}</td><td>{{ e.fstype }}</td></tr>
    {%- endfor %}
  </tbody></table>
  {%- else %}
  <p>No fstab entries.</p>
  {%- endif %}
{% endcall %}

{# ── Warnings ─────────────────────────────────────────────────────────────── #}
{% call section("warnings", "Warnings") %}
<div class="search"><input type="text" id="warn-search" placeholder="Search warnings..."/></div>
<ul id="warnings-list">
  {%- for w in warnings %}
  {%- set msg = w.message or w.detail or '—' %}
  {%- set detail = w.detail or '' %}
  <li><strong>{{ msg }}</strong><br/><small>{{ detail }}</small></li>
  {%- endfor %}
</ul>
{% endcall %}

{# ── Audit report ─────────────────────────────────────────────────────────── #}
{% call section("audit", "Audit report") %}
<p>Full audit findings (from <code>audit-report.md</code>).</p>
<div class="audit-section">{{ audit_html|safe }}</div>
{% endcall %}

{# ── Containerfile ────────────────────────────────────────────────────────── #}
<div id="section-containerfile" class="section">
  <div class="section-heading-row">
    <h2>Containerfile</h2>
    <button type="button" class="btn-copy-cf" id="btn-copy-cf">Copy</button>
  </div>
  <p>Generated image definition. Build with <code>podman build -t my-image .</code></p>
  <pre class="containerfile-pre" id="containerfile-pre">{{ containerfile_html|safe }}</pre>
</div>
</div>{# /.container #}

{# ── Sticky toolbar for exclusions ─────────────────────────────────────── #}
<div id="exclude-toolbar" style="display:none">
  <span class="toolbar-status" id="toolbar-status-text"></span>
  <button id="btn-download-snapshot" type="button" title="Download snapshot with current selections as JSON">Download Modified Snapshot</button>
  <button id="btn-rerender" type="button" class="disabled" title="Start yoinkc-refine to enable live re-render">Re-render</button>
  <button id="btn-tarball" type="button" class="disabled btn-primary" title="Start yoinkc-refine to enable tarball download">Download Tarball</button>
</div>
<div id="toast" class="toast"></div>

{# ══════════════════════════════════════════════════════════════════════════
   JavaScript
   ══════════════════════════════════════════════════════════════════════════ #}
<script>
// Apply saved theme immediately so re-rendered pages don't flash
(function(){ var t = localStorage.getItem('yoinkc-theme'); if (t) document.documentElement.setAttribute('data-theme', t); })();
var snapshot = {{ snapshot_json|safe }};
(function(){
  var sections = document.querySelectorAll('.section');
  var tabs = document.querySelectorAll('.tabs button[data-tab]');
  function show(id) {
    if (!id) return;
    sections.forEach(function(s){ s.classList.remove('visible'); });
    var el = document.getElementById('section-' + id);
    if (el) el.classList.add('visible');
    tabs.forEach(function(t){ t.classList.toggle('active', t.getAttribute('data-tab') === id); });
  }
  window.show = show;
  tabs.forEach(function(t){
    t.addEventListener('click', function(){ show(t.getAttribute('data-tab')); });
  });
  show('summary');
  var warningBanner = document.getElementById('warning-banner');
  var bannerCount = document.getElementById('banner-warning-count');
  var panelCount = document.getElementById('warning-banner-count');

  var overflowCount = parseInt(warningBanner ? warningBanner.getAttribute('data-overflow-count') : '0', 10) || 0;

  function updateWarningCounts() {
    if (!warningBanner) return;
    var visibleRows = warningBanner.querySelectorAll('.warning-row[data-warning-idx]:not(.dismissed)');
    var panelVisible = visibleRows.length;
    var total = panelVisible + overflowCount;
    if (bannerCount) bannerCount.textContent = total;
    if (panelCount) panelCount.textContent = total;
    var cardCount = document.getElementById('warnings-card-count');
    if (cardCount) cardCount.textContent = total;
    var statusEl = document.getElementById('warnings-card-status');
    if (statusEl) statusEl.textContent = panelVisible > 0 ? 'Review required' : (overflowCount > 0 ? 'Panel cleared' : 'All dismissed');
    if (panelVisible === 0) {
      warningBanner.classList.add('collapsed');
    }
  }

  if (warningBanner) {
    warningBanner.querySelectorAll('.warning-row-dismiss').forEach(function(btn){
      btn.addEventListener('click', function(){
        this.closest('.warning-row').classList.add('dismissed');
        updateWarningCounts();
      });
    });
    var dismissAll = document.getElementById('warning-dismiss-all');
    if (dismissAll) {
      dismissAll.addEventListener('click', function(){
        warningBanner.querySelectorAll('.warning-row').forEach(function(row){
          row.classList.add('dismissed');
        });
        updateWarningCounts();
      });
    }
  }
  var search = document.getElementById('warn-search');
  if (search) {
    search.addEventListener('input', function(){
      var q = (this.value || '').toLowerCase();
      var listItems = document.querySelectorAll('#warnings-list li');
      listItems.forEach(function(li){
        li.style.display = (q === '' || (li.textContent || '').toLowerCase().indexOf(q) >= 0) ? '' : 'none';
      });
    });
  }
  document.querySelectorAll('.file-entry').forEach(function(btn){
    btn.addEventListener('click', function(){
      var id = this.getAttribute('data-content-id');
      var path = this.getAttribute('data-path');
      var pathEl = document.getElementById('file-viewer-path');
      var contentEl = document.getElementById('file-viewer-content');
      var src = id ? document.getElementById(id) : null;
      if (pathEl) pathEl.textContent = path || 'Click a file';
      if (contentEl) contentEl.innerHTML = src ? src.innerHTML : '';
    });
  });

  // --- Interactive item exclusion ---
  var toolbar = document.getElementById('exclude-toolbar');
  var statusTextEl = document.getElementById('toolbar-status-text');
  var toast = document.getElementById('toast');
  var rerenderBtn = document.getElementById('btn-rerender');
  var tarballBtn = document.getElementById('btn-tarball');
  var downloadSnapshotBtn = document.getElementById('btn-download-snapshot');
  var helperAvailable = false;
  var dirty = false;

  var includeBaseline = {};
  var strategyBaseline = {};
  function buildBaseline() {
    includeBaseline = {};
    strategyBaseline = {};
    document.querySelectorAll('.include-cb').forEach(function(cb) {
      var tr = cb.closest('tr[data-snap-section]') || cb.closest('[data-snap-section]');
      if (!tr) return;
      var section = tr.getAttribute('data-snap-section');
      var list = tr.getAttribute('data-snap-list');
      var idx = tr.getAttribute('data-snap-index');
      if (section && list && idx !== null) {
        includeBaseline[section + '/' + list + '/' + idx] = cb.checked;
      }
    });
    document.querySelectorAll('.strategy-select').forEach(function(sel) {
      var tr = sel.closest('tr[data-snap-section]');
      if (!tr) return;
      var key = tr.getAttribute('data-snap-section') + '/' + tr.getAttribute('data-snap-list') + '/' + tr.getAttribute('data-snap-index');
      strategyBaseline[key] = sel.value;
    });
  }
  function isSnapshotClean() {
    var clean = true;
    document.querySelectorAll('.include-cb').forEach(function(cb) {
      var tr = cb.closest('tr[data-snap-section]') || cb.closest('[data-snap-section]');
      if (!tr) return;
      var section = tr.getAttribute('data-snap-section');
      var list = tr.getAttribute('data-snap-list');
      var idx = tr.getAttribute('data-snap-index');
      if (section && list && idx !== null) {
        if (cb.checked !== includeBaseline[section + '/' + list + '/' + idx]) {
          clean = false;
        }
      }
    });
    document.querySelectorAll('.strategy-select').forEach(function(sel) {
      var tr = sel.closest('tr[data-snap-section]');
      if (!tr) return;
      var key = tr.getAttribute('data-snap-section') + '/' + tr.getAttribute('data-snap-list') + '/' + tr.getAttribute('data-snap-index');
      if (sel.value !== strategyBaseline[key]) clean = false;
    });
    return clean;
  }
  buildBaseline();

  function setDirty(isDirty) {
    dirty = isDirty;
    if (tarballBtn) tarballBtn.classList.toggle('btn-primary', !isDirty);
    if (rerenderBtn) rerenderBtn.classList.toggle('btn-primary', isDirty);
  }

  function showToast(msg, ms) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('visible');
    setTimeout(function(){ toast.classList.remove('visible'); }, ms || 4000);
  }

  function updateToolbar() {
    var n = document.querySelectorAll('.include-cb:not(:checked)').length;
    var strategyChanges = 0;
    document.querySelectorAll('.strategy-select').forEach(function(sel) {
      var tr = sel.closest('tr[data-snap-section]');
      if (!tr) return;
      var key = tr.getAttribute('data-snap-section') + '/' + tr.getAttribute('data-snap-list') + '/' + tr.getAttribute('data-snap-index');
      if (sel.value !== strategyBaseline[key]) strategyChanges++;
    });
    var changed = !isSnapshotClean();
    var isHelper = toolbar && toolbar.classList.contains('helper-active');

    if (changed) {
      var parts = [];
      if (n > 0) parts.push(n + ' item(s) excluded');
      if (strategyChanges > 0) parts.push(strategyChanges + ' strategy change(s)');
      if (parts.length === 0) parts.push('Snapshot modified');
      if (statusTextEl) { statusTextEl.textContent = parts.join(', '); statusTextEl.style.color = ''; }
      if (rerenderBtn) rerenderBtn.classList.remove('disabled');
      if (downloadSnapshotBtn) downloadSnapshotBtn.classList.remove('disabled');
    } else if (isHelper) {
      if (statusTextEl) { statusTextEl.textContent = 'No pending changes'; statusTextEl.style.color = 'var(--muted)'; }
      if (rerenderBtn) rerenderBtn.classList.add('disabled');
      if (downloadSnapshotBtn) downloadSnapshotBtn.classList.add('disabled');
    } else {
      if (statusTextEl) { statusTextEl.textContent = ''; statusTextEl.style.color = ''; }
    }

    if (toolbar && !isHelper) {
      toolbar.classList.toggle('visible', n > 0 || changed);
    }
  }

  function resolveSnapshotRef(section, list) {
    if (!snapshot) return null;
    var sec = snapshot[section];
    if (!sec) return null;
    return sec[list] || null;
  }

  document.querySelectorAll('.include-cb').forEach(function(cb){
    cb.addEventListener('change', function(){
      var tr = this.closest('tr[data-snap-section]') || this.closest('[data-snap-section]');
      if (!tr) return;
      var section = tr.getAttribute('data-snap-section');
      var list = tr.getAttribute('data-snap-list');
      var idx = parseInt(tr.getAttribute('data-snap-index'), 10);
      if (section && list && !isNaN(idx) && idx >= 0) {
        var arr = resolveSnapshotRef(section, list);
        if (arr && arr[idx] !== undefined) {
          arr[idx].include = this.checked;
        }
      }
      tr.classList.toggle('excluded', !this.checked);
      updateToolbar();
      setDirty(!isSnapshotClean());
    });
  });

  // --- Strategy select handler ---
  document.querySelectorAll('.strategy-select').forEach(function(sel){
    sel.addEventListener('change', function(){
      var tr = this.closest('tr[data-snap-section]');
      if (!tr) return;
      var section = tr.getAttribute('data-snap-section');
      var list = tr.getAttribute('data-snap-list');
      var idx = parseInt(tr.getAttribute('data-snap-index'), 10);
      if (section && list && !isNaN(idx) && idx >= 0) {
        var arr = resolveSnapshotRef(section, list);
        if (arr && arr[idx] !== undefined) {
          arr[idx].strategy = this.value;
        }
      }
      setDirty(!isSnapshotClean());
      updateToolbar();
    });
  });

  // --- Apply strategy to all users/groups ---
  function applyStrategyToAll(btnId, selectId, listName) {
    var btn = document.getElementById(btnId);
    var sel = document.getElementById(selectId);
    if (!btn || !sel) return;
    btn.addEventListener('click', function() {
      var val = sel.value;
      var arr = resolveSnapshotRef('users_groups', listName);
      if (!arr) return;
      document.querySelectorAll('tr[data-snap-section="users_groups"][data-snap-list="' + listName + '"] .strategy-select').forEach(function(s) {
        s.value = val;
        var idx = parseInt(s.closest('tr').getAttribute('data-snap-index'), 10);
        if (!isNaN(idx) && arr[idx] !== undefined) arr[idx].strategy = val;
      });
      setDirty(!isSnapshotClean());
      updateToolbar();
    });
  }
  applyStrategyToAll('btn-strategy-apply-all', 'strategy-apply-all', 'users');
  applyStrategyToAll('btn-strategy-apply-all-groups', 'strategy-apply-all-groups', 'groups');

  // --- Package leaf/auto-dep cascade ---
  var pkgDepTree = (snapshot.rpm && snapshot.rpm.leaf_dep_tree) || {};
  var pkgAutoNames = new Set((snapshot.rpm && snapshot.rpm.auto_packages) || []);

  function getPkgIdx(name) {
    var pkgs = (snapshot.rpm && snapshot.rpm.packages_added) || [];
    for (var i = 0; i < pkgs.length; i++) {
      if (pkgs[i] && pkgs[i].name === name) return i;
    }
    return -1;
  }

  function recomputeAutoDeps() {
    var covered = new Set();
    document.querySelectorAll('.pkg-dep-tree-group tr[data-leaf], #pkg-dep-tree tr[data-leaf]').forEach(function(row) {
      var cb = row.querySelector('.leaf-cb');
      if (cb && cb.checked) {
        (pkgDepTree[row.getAttribute('data-leaf')] || []).forEach(function(d) { covered.add(d); });
      }
    });
    pkgAutoNames.forEach(function(dep) {
      var i = getPkgIdx(dep);
      if (i >= 0 && snapshot.rpm && snapshot.rpm.packages_added[i]) {
        snapshot.rpm.packages_added[i].include = covered.has(dep);
      }
    });
  }

  function updatePkgBanner() {
    var banner = document.getElementById('pkg-selection-banner');
    if (!banner) return;
    var leafRows = document.querySelectorAll('.pkg-dep-tree-group tr[data-leaf], #pkg-dep-tree tr[data-leaf]');
    if (!leafRows.length) return;
    var total = leafRows.length;
    var selected = 0;
    var covered = new Set();
    leafRows.forEach(function(row) {
      var cb = row.querySelector('.leaf-cb');
      if (cb && cb.checked) {
        selected++;
        (pkgDepTree[row.getAttribute('data-leaf')] || []).forEach(function(d) { covered.add(d); });
      }
    });
    banner.innerHTML = '<strong>' + selected + ' of ' + total + ' leaf package' + (total !== 1 ? 's' : '') + ' selected</strong>'
      + ', pulling in <strong>' + covered.size + ' dependenc' + (covered.size !== 1 ? 'ies' : 'y') + '</strong>'
      + ' \u2014 only leaf packages appear in the Containerfile\u2019s <code>dnf\u00a0install</code> line.';
  }

  document.querySelectorAll('.pkg-dep-tree-group .leaf-cb, #pkg-dep-tree .leaf-cb').forEach(function(cb) {
    cb.addEventListener('change', function() {
      recomputeAutoDeps();
      updatePkgBanner();
    });
  });

  updatePkgBanner();

  // --- Repo cascade: unchecking a repo cascades to its leaf packages ---
  function parseRepoSectionIds(content) {
    var ids = [];
    if (!content) return ids;
    var lines = content.split('\n');
    for (var i = 0; i < lines.length; i++) {
      var m = lines[i].match(/^\s*\[([^\]]+)\]\s*$/);
      if (m) ids.push(m[1]);
    }
    return ids;
  }

  document.querySelectorAll('#pkg-repo-table .repo-cb').forEach(function(cb) {
    cb.addEventListener('change', function() {
      var tr = this.closest('tr[data-snap-index]');
      if (!tr) return;
      var idx = parseInt(tr.getAttribute('data-snap-index'), 10);
      var repos = (snapshot.rpm && snapshot.rpm.repo_files) || [];
      if (idx < 0 || idx >= repos.length) return;
      var repoIds = new Set(parseRepoSectionIds(repos[idx].content));
      if (!repoIds.size) return;
      var checked = this.checked;

      document.querySelectorAll('.pkg-dep-tree-group tr[data-leaf], #pkg-dep-tree tr[data-leaf]').forEach(function(row) {
        var leafName = row.getAttribute('data-leaf');
        var pkgIdx = parseInt(row.getAttribute('data-snap-index'), 10);
        if (pkgIdx < 0) return;
        var pkg = snapshot.rpm.packages_added[pkgIdx];
        if (!pkg || !repoIds.has(pkg.source_repo)) return;

        var leafCb = row.querySelector('.leaf-cb');
        if (!leafCb) return;

        if (!checked) {
          leafCb.checked = false;
          leafCb.disabled = true;
          pkg.include = false;
          row.classList.add('excluded');
        } else {
          leafCb.checked = true;
          leafCb.disabled = false;
          pkg.include = true;
          row.classList.remove('excluded');
        }
      });
      recomputeAutoDeps();
      updatePkgBanner();
      updateToolbar();
      setDirty(!isSnapshotClean());
    });
  });

  // --- Download modified snapshot ---
  downloadSnapshotBtn.addEventListener('click', function(){
    if (!dirty) return;
    var json = JSON.stringify(snapshot, null, 2);
    var blob = new Blob([json], {type: 'application/json'});
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'modified-snapshot.json';
    a.click();
    URL.revokeObjectURL(a.href);
  });

  // --- Re-render ---
  rerenderBtn.addEventListener('click', function(){
    if (!helperAvailable) return;
    if (!dirty) return;
    var origText = rerenderBtn.innerHTML;
    rerenderBtn.innerHTML = '<span class="spinner"></span>Re-rendering...';
    rerenderBtn.classList.add('disabled');
    fetch(window.location.origin + '/api/re-render', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(snapshot),
    }).then(function(r){
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.text();
    }).then(function(html){
      setDirty(false);
      document.open();
      document.write(html);
      document.close();
    }).catch(function(err){
      showToast('Re-render failed: ' + err.message, 5000);
      rerenderBtn.innerHTML = origText;
      rerenderBtn.classList.remove('disabled');
    });
  });

  // --- Download tarball ---
  tarballBtn.addEventListener('click', function(){
    if (!helperAvailable) return;
    window.location.href = window.location.origin + '/api/tarball';
  });

  // --- Helper script detection with retry ---
  function enableHelperButtons(reRenderAvailable) {
    helperAvailable = true;
    document.querySelectorAll('.include-cb').forEach(function(el){ el.style.display = 'inline-block'; });
    if (toolbar) {
      toolbar.style.display = '';
      toolbar.classList.remove('visible');
      toolbar.classList.add('helper-active');
    }
    if (reRenderAvailable !== false) {
      rerenderBtn.classList.remove('disabled');
      rerenderBtn.title = 'Re-render with excluded items removed';
    } else {
      rerenderBtn.title = 'Re-render requires podman or docker — not found on this system';
    }
    tarballBtn.classList.remove('disabled');
    tarballBtn.title = 'Download current output as tar.gz';
    updateToolbar();
  }

  function checkHelperAvailable(attempt) {
    fetch(window.location.origin + '/api/health')
      .then(function(r) { return r.ok ? r.json() : Promise.reject(new Error('not ok')); })
      .then(function(d) {
        if (d && d.status === 'ok') {
          enableHelperButtons(d.re_render !== false);
        } else {
          retryOrGiveUp(attempt);
        }
      })
      .catch(function() { retryOrGiveUp(attempt); });
  }

  function retryOrGiveUp(attempt) {
    if (attempt < 3) {
      setTimeout(function() { checkHelperAvailable(attempt + 1); }, 2000);
    } else {
      console.log('yoinkc-refine not detected');
    }
  }

  checkHelperAvailable(0);
  updateToolbar();

  // --- Theme toggle ---
  (function() {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      btn.textContent = theme === 'light' ? '\u263D' : '\u2600';
      btn.title = theme === 'light' ? 'Switch to dark theme' : 'Switch to light theme';
      localStorage.setItem('yoinkc-theme', theme);
    }
    applyTheme(localStorage.getItem('yoinkc-theme') || 'dark');
    btn.addEventListener('click', function() {
      applyTheme((document.documentElement.getAttribute('data-theme') || 'dark') === 'dark' ? 'light' : 'dark');
    });
  })();

  // --- Copy Containerfile to clipboard ---
  (function() {
    var btn = document.getElementById('btn-copy-cf');
    if (!btn) return;
    var pre = document.getElementById('containerfile-pre');
    function flash() {
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(function() { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
    }
    function fallback(text) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0';
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      var ok = false;
      try { ok = document.execCommand('copy'); } catch(e) {}
      document.body.removeChild(ta);
      if (ok) { flash(); } else { showToast('Clipboard not available in this context', 3000); }
    }
    btn.addEventListener('click', function() {
      var text = pre ? pre.textContent : '';
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(flash).catch(function() { fallback(text); });
      } else {
        fallback(text);
      }
    });
  })();
})();
</script>
</body>
</html>
