{#
  report.html.j2 — yoinkc self-contained inspection report.
  Rendered by renderers/html_report.py via _build_context().
  Context keys:
    snapshot, counts, fleet_meta, triage, os_desc, meta,
    warnings, warnings_panel, warnings_overflow,
    containerfile_html (Markup), containerfile_lines,
    tree_html (Markup), file_content_snippets_html (Markup),
    audit_html (Markup — kept for backward compat, no longer rendered),
    config_files_rendered (list of dicts),
    non_rpm_data (dict of categorized items),
    containers_data (dict),
    triage_detail (list of dicts),
    patternfly_css (Markup),
#}

{# ── Section wrapper macro ─────────────────────────────────────────────── #}
{% macro section(id, title, visible=false) -%}
<div id="section-{{ id }}" class="section{% if visible %} visible{% endif %}">
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h2>{{ title }}</h2></div></div>
    <div class="pf-v6-c-card__body">
    {{- caller() }}
    </div>
  </div>
</div>
{%- endmacro %}

{# ── Fleet prevalence cell macro ─────────────────────────────────────── #}
{% macro fleet_cell(item) %}
{% if fleet_meta %}
<td class="fleet-prevalence">
  {% if item.fleet %}
  <div class="fleet-bar"
       data-count="{{ item.fleet.count }}"
       data-total="{{ item.fleet.total }}"
       data-hosts="{{ item.fleet.hosts | join(', ') }}">
    <div class="fleet-bar-track">
      <div class="fleet-bar-fill {{ item.fleet | fleet_color }}"
           style="width: {{ (item.fleet.count * 100 // item.fleet.total) if item.fleet.total > 0 else 100 }}%"></div>
    </div>
    <span class="fleet-bar-label">{{ item.fleet.count }}/{{ item.fleet.total }}</span>
  </div>
  {% endif %}
</td>
{% endif %}
{% endmacro %}

{# ── Simple data table macro ────────────────────────────────────────────── #}
{% macro data_table(headers) %}
<table class="pf-v6-c-table"><thead><tr>
  {%- for h in headers %}<th scope="col">{{ h }}</th>{% endfor -%}
</tr></thead><tbody>
{{ caller() }}
</tbody></table>
{% endmacro %}

<!DOCTYPE html>
<html lang="en" class="pf-v6-theme-dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>yoinkc Report</title>
<style>{{ patternfly_css }}</style>
<style>
/* ═══════════════════════════════════════════════════════════════════════
   yoinkc report – custom overrides on top of PatternFly 6
   ═══════════════════════════════════════════════════════════════════════ */

/* OS icon theme-aware colours */
.os-icon { vertical-align: middle; margin-right: 6px; }
.os-icon-rhel   { color: #ffffff; }
.os-icon-fedora { color: #79B8FF; }
.os-icon-centos { color: #c678dd; }
.os-icon-rocky  { color: #73BA25; }
.os-icon-alma   { color: #ff4649; }
html:not(.pf-v6-theme-dark) .os-icon-rhel   { color: #EE0000; }
html:not(.pf-v6-theme-dark) .os-icon-fedora { color: #294172; }
html:not(.pf-v6-theme-dark) .os-icon-centos { color: #932279; }
html:not(.pf-v6-theme-dark) .os-icon-rocky  { color: #10B981; }
html:not(.pf-v6-theme-dark) .os-icon-alma   { color: #ff4649; }

/* Page padding – toolbar lives at the bottom */
body { padding-bottom: 70px; }

/* Inline alert banners – wrap content in .pf-v6-c-alert__title to land in the
   grid's "title" area; nowrap + overflow-x keeps stats on a single line. */
.os-status-banner { margin-bottom: 1rem; }
.os-status-banner .pf-v6-c-alert__title,
#pkg-selection-banner .pf-v6-c-alert__title { white-space: nowrap; overflow-x: auto; }

/* Section show/hide for nav switching */
.section { display: none; margin-top: var(--pf-v6-global--spacer--md, 1rem); }
.section.visible { display: block; animation: fadeIn .15s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* Sidebar nav */
.pf-v6-c-page__sidebar .pf-v6-c-nav__section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }


/* Warning dismiss */
.warning-row.dismissed { display: none; }
#warnings-list { max-height: 400px; overflow-y: auto; }

/* Readiness panel */
.readiness-panel { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
.readiness-col { border-radius: 8px; padding: 1rem; }
.readiness-col.readiness-auto   { border-left: 4px solid var(--pf-t--global--color--status--success--default); }
.readiness-col.readiness-fixme  { border-left: 4px solid var(--pf-t--global--color--status--warning--default); }
.readiness-col.readiness-manual { border-left: 4px solid var(--pf-t--global--color--status--danger--default); }
.readiness-header { font-weight: 600; margin-bottom: 0.5rem; }
.readiness-count  { font-size: 1.3rem; margin-right: 0.25rem; }
.readiness-col.readiness-auto   .readiness-count { color: var(--pf-t--global--text--color--status--success--default); }
.readiness-col.readiness-fixme  .readiness-count { color: var(--pf-t--global--text--color--status--warning--default); }
.readiness-col.readiness-manual .readiness-count { color: var(--pf-t--global--text--color--status--danger--default); }
.readiness-col ul { list-style: none; padding: 0; margin: 0; }
.readiness-col li { padding: 0.2rem 0; }
.readiness-link { background: none; border: none; color: var(--pf-t--global--text--color--link--default); cursor: pointer; padding: 0; font-size: 0.9rem; text-align: left; }
.readiness-link:hover { text-decoration: underline; }

/* Summary */
.summary-hero { font-size: 1.1rem; margin-bottom: 1.5rem; }
.summary-next { margin-top: 1.5rem; padding-top: 1rem; }

/* Diff view */
.diff-view { max-height: 300px; overflow: auto; font-size: 0.85em; line-height: 1.5; padding: 0.5rem; border-radius: 4px; }
.diff-add  { color: var(--pf-t--global--text--color--status--success--default); background: var(--pf-t--global--color--status--success--100); display: block; border-left: 3px solid var(--pf-t--global--color--status--success--default); padding-left: 0.5rem; }
.diff-del  { color: var(--pf-t--global--text--color--status--danger--default); background: var(--pf-t--global--color--status--danger--100); display: block; border-left: 3px solid var(--pf-t--global--color--status--danger--default); padding-left: 0.5rem; }
.diff-hdr  { color: var(--pf-t--global--text--color--subtle); display: block; font-weight: bold; }
.diff-hunk { color: var(--pf-t--global--text--color--status--info--default); display: block; }

/* Containerfile code block */
.containerfile-pre { border-radius: 6px; padding: 1rem; overflow: auto; max-height: 70vh; font-size: 0.85rem; line-height: 1.4; white-space: pre; margin: 0; }
.section-heading-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
.section-heading-row h2 { margin: 0; }

/* Repo content preview */
.repo-content-pre { border-radius: 4px; padding: 0.75rem; font-size: 0.8rem; max-height: 300px; overflow: auto; margin: 0.25rem 0 0; white-space: pre; }

/* File browser */
.fb-tree { flex: 0 1 280px; min-width: 200px; max-width: 280px; max-height: 70vh; overflow-y: auto; overflow-x: hidden; }
.fb-tree .pf-v6-c-tree-view__node-text { overflow-wrap: anywhere; word-break: break-all; }
.fb-viewer { flex: 1 1 400px; min-height: 200px; }
.fb-viewer .pf-v6-c-code-block__pre { max-height: 65vh; overflow: auto; }
.file-content-hidden { display: none; }

/* Excluded rows */
tr.excluded td { text-decoration: line-through; opacity: 0.45; }
tr.excluded td:first-child { text-decoration: none; opacity: 1; }
div.excluded { text-decoration: line-through; opacity: 0.45; }

/* Include checkbox – hidden until yoinkc-refine helper is active */
.pf-v6-c-check.pf-m-standalone.include-cb-wrap { display: none; }
/* Vertically center checkbox cells without overriding all table cells globally */
.pf-v6-c-table .pf-v6-c-table__check { vertical-align: middle; }

/* Gap between stacked inner cards inside a card body */
.pf-v6-c-card__body > .pf-v6-c-card + .pf-v6-c-card { margin-top: var(--pf-v6-global--spacer--md, 1rem); }


/* Details/summary disclosure styling */
details > summary { cursor: pointer; color: var(--pf-t--global--text--color--link--default); font-size: 0.85em; padding: 0.25rem 0; list-style: none; }
details > summary::-webkit-details-marker { display: none; }
details > summary::before { content: "▸ "; font-size: 0.75em; }
details[open] > summary::before { content: "▾ "; }
details > summary:hover { text-decoration: underline; }
details[open] > summary { margin-bottom: 0.25rem; }

/* Inline semantic labels now use native PF6 variants */

/* Audit */
.audit-pre { border-radius: 6px; padding: 1rem; overflow: auto; max-height: 50vh; font-size: 0.85rem; margin: 0.5rem 0; }
.audit-table { margin: 0.5rem 0; }
.audit-section { max-height: 70vh; overflow-y: auto; padding: 0 0.25rem; }
details.audit-expand > summary { font-size: 1em; font-weight: 600; color: inherit; padding: 0.6rem 0 0.2rem; }
details.audit-expand { margin-bottom: 0.25rem; }

/* Sticky toolbar */
#exclude-toolbar { position: fixed; bottom: 0; left: 0; right: 0; padding: 0.6rem 1.5rem; display: none; align-items: center; gap: 1rem; z-index: 1000; }
#exclude-toolbar.visible, #exclude-toolbar.helper-active { display: flex; }
#exclude-toolbar .toolbar-status { font-weight: 600; flex: 1; }

/* Utility classes */
.content-preview { border-radius: 4px; padding: var(--pf-t--global--spacer--sm); font-size: 0.8rem; max-height: 200px; overflow: auto; margin: var(--pf-t--global--spacer--xs) 0; }
.table-group-header { font-weight: var(--pf-t--global--font--weight--body--bold); padding-bottom: var(--pf-t--global--spacer--xs); padding-top: var(--pf-t--global--spacer--md); border-top: 1px solid var(--pf-t--global--border--color--default); }
.text-sm { font-size: var(--pf-t--global--font--size--body--sm); }
.text-bold { font-weight: var(--pf-t--global--font--weight--body--bold); }
.mt-sm { margin-top: var(--pf-t--global--spacer--sm); }
.mt-md { margin-top: var(--pf-t--global--spacer--md); }
.mt-lg { margin-top: var(--pf-t--global--spacer--lg); }
.mb-md { margin-bottom: var(--pf-t--global--spacer--md); }
.table-group-header-first { border-top: none; padding-top: var(--pf-t--global--spacer--sm); }
.deps-list { margin: var(--pf-t--global--spacer--xs) 0; padding-left: 1.5rem; }
.card-actions-layout { display: flex; align-items: center; gap: var(--pf-t--global--spacer--sm); flex-wrap: nowrap; }

/* Toast */
.toast { position: fixed; top: 1rem; right: 1rem; z-index: 2000; display: none; }
.toast.visible { display: block; }

/* Spinner (for re-render button) */
.spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid currentColor; border-top-color: transparent; border-radius: 50%; animation: spin 0.6s linear infinite; margin-right: 0.5rem; vertical-align: middle; }
@keyframes spin { to { transform: rotate(360deg); } }

/* Form controls in table cells – reduce margins for compact rows */
.pf-v6-c-table td .pf-v6-c-form-control {
  margin: 0;
  padding: 0.25rem 0;
}

/* Status text/background utility classes — theme-aware via PF6 tokens */
.text-status-success { color: var(--pf-t--global--text--color--status--success--default); }
.text-status-warning { color: var(--pf-t--global--text--color--status--warning--default); }
.text-status-danger  { color: var(--pf-t--global--text--color--status--danger--default); }
.text-status-info    { color: var(--pf-t--global--text--color--status--info--default); }

{% if fleet_meta %}
/* Fleet prevalence badges */
.fleet-prevalence {
  width: 90px;
  min-width: 90px;
}
.fleet-bar {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
}
.fleet-bar-track {
  width: 60px;
  height: 6px;
  background: #e0e0e0;
  border-radius: 3px;
  overflow: hidden;
}
.fleet-bar-fill {
  height: 100%;
  border-radius: 3px;
}
.fleet-bar-fill.pf-m-blue {
  background: var(--pf-v6-global--palette--blue-300, #0066cc);
}
.fleet-bar-fill.pf-m-gold {
  background: var(--pf-v6-global--palette--gold-400, #f0ab00);
}
.fleet-bar-fill.pf-m-red {
  background: var(--pf-v6-global--palette--red-100, #c9190b);
}
.fleet-bar-label {
  font-size: 11px;
  color: var(--pf-v6-global--Color--200, #6a6e73);
  white-space: nowrap;
  cursor: pointer;
  user-select: none;
}
.fleet-banner {
  border-left: 4px solid var(--pf-v6-global--palette--blue-300, #0066cc);
}
/* Fleet popover */
.fleet-popover {
  position: absolute;
  z-index: 1000;
  background: var(--pf-v6-global--BackgroundColor--100, #fff);
  border: 1px solid var(--pf-v6-global--BorderColor--100, #d2d2d2);
  border-radius: 4px;
  padding: 8px 12px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  font-size: 13px;
  max-width: 300px;
}
.fleet-popover ul {
  list-style: none;
  margin: 0;
  padding: 0;
}
.fleet-popover li {
  padding: 2px 0;
}
/* Fleet variant grouping */
.fleet-variant-children {
  display: none;
}
{% endif %}

</style>
</head>
<body>
<div class="pf-v6-c-page">

<header class="pf-v6-c-masthead">
  <div class="pf-v6-c-masthead__main">
    <span class="pf-v6-c-masthead__brand">yoinkc Inspection Report</span>
  </div>
  <div class="pf-v6-c-masthead__content">
    <button id="theme-toggle" class="pf-v6-c-button pf-m-plain" title="Switch to light theme" aria-label="Toggle theme">&#9728;</button>
  </div>
</header>

{# ── Sidebar navigation ─────────────────────────────────────────────────── #}
<div class="pf-v6-c-page__sidebar">
  <div class="pf-v6-c-page__sidebar-body">
    <nav class="pf-v6-c-nav" id="report-nav" aria-label="Report sections">
      <section class="pf-v6-c-nav__section">
        <h2 class="pf-v6-c-nav__section-title">Overview</h2>
        <ul class="pf-v6-c-nav__list">
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link pf-m-current" data-tab="summary" href="#">Summary</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="audit" href="#">Audit report</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="warnings" href="#">Warnings <span class="pf-v6-c-badge pf-m-unread" id="nav-warning-badge">{{ warnings|length }}</span></a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="output_files" href="#">File browser</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="containerfile" href="#">Containerfile</a></li>
        </ul>
      </section>
      <section class="pf-v6-c-nav__section">
        <h2 class="pf-v6-c-nav__section-title">Inspectors</h2>
        <ul class="pf-v6-c-nav__list">
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="packages" href="#">Packages</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="config" href="#">Config</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="services" href="#">Services</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="users_groups" href="#">Users/Groups</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="containers" href="#">Containers</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="non_rpm" href="#">Non-RPM</a></li>
        </ul>
      </section>
      <section class="pf-v6-c-nav__section">
        <h2 class="pf-v6-c-nav__section-title">System</h2>
        <ul class="pf-v6-c-nav__list">
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="scheduled_tasks" href="#">Scheduled</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="kernel_boot" href="#">Kernel/Boot</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="selinux" href="#">SELinux</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="network" href="#">Network</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="storage" href="#">Storage</a></li>
          <li class="pf-v6-c-nav__item"><a class="pf-v6-c-nav__link" data-tab="secrets" href="#">Secrets</a></li>
        </ul>
      </section>
    </nav>
  </div>
</div>

<main class="pf-v6-c-page__main">
<section class="pf-v6-c-page__main-section">

{# ── Banner ─────────────────────────────────────────────────────────────── #}
<div class="pf-v6-c-alert pf-m-info pf-m-inline os-status-banner">
  <p class="pf-v6-c-alert__title">
  {%- if os_id == "rhel" -%}
  <svg role="img" class="os-icon os-icon-rhel" height="20" viewBox="0 0 24 24" aria-label="Red Hat"><path fill="currentColor" d="M16.009 13.386c1.577 0 3.86-.326 3.86-2.202a1.765 1.765 0 0 0-.04-.431l-.94-4.08c-.216-.898-.406-1.305-1.982-2.093-1.223-.625-3.888-1.658-4.676-1.658-.733 0-.947.946-1.822.946-.842 0-1.467-.706-2.255-.706-.757 0-1.25.515-1.63 1.576 0 0-1.06 2.99-1.197 3.424a.81.81 0 0 0-.028.245c0 1.162 4.577 4.974 10.71 4.974m4.101-1.435c.218 1.032.218 1.14.218 1.277 0 1.765-1.984 2.745-4.593 2.745-5.895.004-11.06-3.451-11.06-5.734a2.326 2.326 0 0 1 .19-.925C2.746 9.415 0 9.794 0 12.217c0 3.969 9.405 8.861 16.851 8.861 5.71 0 7.149-2.582 7.149-4.62 0-1.605-1.387-3.425-3.887-4.512"/></svg>
  {%- elif os_id == "fedora" -%}
  <svg role="img" class="os-icon os-icon-fedora" height="20" viewBox="0 0 24 24" aria-label="Fedora"><path fill="currentColor" d="M12.001 0C5.376 0 .008 5.369.004 11.992H.002v9.287h.002A2.726 2.726 0 0 0 2.73 24h9.275c6.626-.004 11.993-5.372 11.993-11.997C23.998 5.375 18.628 0 12 0zm2.431 4.94c2.015 0 3.917 1.543 3.917 3.671 0 .197.001.395-.03.619a1.002 1.002 0 0 1-1.137.893 1.002 1.002 0 0 1-.842-1.175 2.61 2.61 0 0 0 .013-.337c0-1.207-.987-1.672-1.92-1.672-.934 0-1.775.784-1.777 1.672.016 1.027 0 2.046 0 3.07l1.732-.012c1.352-.028 1.368 2.009.016 1.998l-1.748.013c-.004.826.006.677.002 1.093 0 0 .015 1.01-.016 1.776-.209 2.25-2.124 4.046-4.424 4.046-2.438 0-4.448-1.993-4.448-4.437.073-2.515 2.078-4.492 4.603-4.469l1.409-.01v1.996l-1.409.013h-.007c-1.388.04-2.577.984-2.6 2.47a2.438 2.438 0 0 0 2.452 2.439c1.356 0 2.441-.987 2.441-2.437l-.001-7.557c0-.14.005-.252.02-.407.23-1.848 1.883-3.256 3.754-3.256z"/></svg>
  {%- elif os_id == "centos" -%}
  <svg role="img" class="os-icon os-icon-centos" height="20" viewBox="0 0 24 24" aria-label="CentOS"><path fill="currentColor" d="M12.076.066L8.883 3.28H3.348v5.434L0 12.01l3.349 3.298v5.39h5.374l3.285 3.236 3.285-3.236h5.43v-5.374L24 12.026l-3.232-3.252V3.321H15.31zm0 .749l2.49 2.506h-1.69v6.441l-.8.805-.81-.815V3.28H9.627zm-8.2 2.991h4.483L6.485 5.692l4.253 4.279v.654H9.94L5.674 6.423l-1.798 1.77zm5.227 0h1.635v5.415l-3.509-3.53zm4.302.043h1.687l1.83 1.842-3.517 3.539zm2.431 0h4.404v4.394l-1.83-1.842-4.241 4.267h-.764v-.69l4.261-4.287zm2.574 3.3l1.83 1.843v1.676h-5.327zm-12.735.013l3.515 3.462H3.876v-1.69zM3.348 9.454v1.697h6.377l.871.858-.782.77H3.35v1.786L.753 12.01zm17.42.068l2.488 2.503-2.533 2.55v-1.796h-6.41l-.75-.754.825-.83h6.38zm-9.502.978l.81.815.186-.188.614-.618v.686h.768l-.825.83.75.754h-.719v.808l-.842-.83-.741.73v-.707h-.7l.781-.77-.188-.186-.682-.672h.788zm-7.39 2.807h5.402l-3.603 3.55-1.798-1.772zm6.154 0h.708v.7l-4.404 4.338 1.852 1.824h-4.31v-4.342l1.798 1.77zm3.348 0h.715l4.317 4.343.186-.187 1.599-1.61v4.316h-4.366l1.853-1.825-.188-.185-4.116-4.054zm1.46 0h5.357v1.798l-1.785 1.796zm-2.83.191l.842.829v6.37h1.691l-2.532 2.495-2.533-2.495h1.79V14.23zm-1.27 1.251v5.42H8.939l-1.852-1.823zm2.64.097l3.552 3.499-1.853 1.825h-1.7z"/></svg>
  {%- elif os_id == "rocky" -%}
  <svg role="img" class="os-icon os-icon-rocky" height="20" viewBox="0 0 24 24" aria-label="Rocky Linux"><path fill="currentColor" d="M23.332 15.957c.433-1.239.668-2.57.668-3.957 0-6.627-5.373-12-12-12S0 5.373 0 12c0 3.28 1.315 6.251 3.447 8.417L15.62 8.245l3.005 3.005zm-2.192 3.819l-5.52-5.52L6.975 22.9c1.528.706 3.23 1.1 5.025 1.1 3.661 0 6.94-1.64 9.14-4.224z"/></svg>
  {%- elif os_id == "almalinux" -%}
  <svg role="img" class="os-icon os-icon-alma" height="20" viewBox="0 0 24 24" aria-label="AlmaLinux"><path fill="currentColor" d="M23.994 15.133c.079 1.061-.668 1.927-1.69 2.005a1.8 1.8 0 0 1-1.928-1.651c-.078-1.062.63-1.849 1.691-1.967 1.023-.078 1.849.59 1.927 1.613zm-12.623 4.955c-.944 0-1.73.786-1.73 1.809 0 1.14.747 1.848 1.887 1.848.904-.04 1.691-.865 1.691-1.809 0-.983-.904-1.848-1.848-1.848zm1.061-9.675c-.039-.865-.078-1.73.08-2.556.156-.944.314-1.887.904-2.674.707-.983 1.809-.944 2.399.118.314.511.432 1.062.471 1.652 0 .354.158.432.472.393.944-.157 1.888-.157 2.792.197.118.039.236.118.394 0 .314-.276.393-1.652.196-2.006-.354-.63-.904-.55-1.455-.55-.629.039-1.18-.158-1.612-.67-.393-.471-.511-1.06-.59-1.65-.04-.276-.079-.512-.315-.709-.55-.55-1.809-.432-2.477.118-2.556 2.045-2.989 5.467-1.534 8.18.04.118.118.236.275.157zm7.984 3.658c.354-.511.865-.747 1.415-.983a.973.973 0 0 0 .59-.472c.354-.669-.078-1.81-.747-2.36-2.595-2.006-5.938-1.612-8.18.433-.118.078-.157.196-.078.314.786-.236 1.612-.472 2.477-.51.905-.08 1.848-.158 2.753.235 1.14.472 1.337 1.534.472 2.36-.393.393-.905.668-1.455.825-.315.08-.354.236-.236.551.354.865.59 1.77.472 2.753-.04.157-.079.275.078.393.354.236 1.691 0 1.967-.275.511-.472.314-1.023.196-1.534-.157-.63-.078-1.219.276-1.73zm-7.197-2.045c-.118-.079-.197-.118-.315 0 .472.708.905 1.455 1.259 2.241.314.866.668 1.73.55 2.714-.118 1.18-1.1 1.69-2.123 1.101-.511-.275-.905-.669-1.22-1.14-.196-.276-.393-.276-.629-.08-.747.63-1.533 1.102-2.516 1.26-.158 0-.315 0-.394.157-.118.393.472 1.612.826 1.809.59.354 1.062 0 1.534-.276.55-.314 1.101-.432 1.73-.236.59.197.983.63 1.337 1.102.158.196.315.353.63.432.747.197 1.77-.59 2.084-1.376 1.18-3.028-.157-6.135-2.753-7.708zm-2.556 2.438c.472-.669.826-1.416.983-2.202-.157-.04-.197.04-.315.078-.904.944-1.848 1.849-3.067 2.478-.472.236-.983.433-1.534.433-.865 0-1.376-.551-1.298-1.416a2.92 2.92 0 0 1 .787-1.849c.236-.275.236-.432-.04-.668-.786-.55-1.494-1.22-1.848-2.124-.078-.275-.275-.275-.51-.157a4.293 4.293 0 0 0-.434.236c-1.022.63-1.14 1.416-.275 2.28.63.63.944 1.338.708 2.203-.118.433-.354.747-.63 1.101a.95.95 0 0 0-.235.787c.079.747.826 1.494 1.73 1.573 2.517.236 4.562-.63 5.978-2.753zm-4.68-5.152c1.376 1.18 3.067 1.455 4.837 1.377.157 0 .315 0 .354-.118.04-.197-.157-.197-.275-.236-.826-.354-1.691-.63-2.438-1.14S6.848 8.25 6.534 7.266c-.236-.747.078-1.415.825-1.651.669-.236 1.337-.236 1.967 0 .393.157.55.078.629-.354.118-.747.354-1.455.826-2.085.55-.786.55-.865-.354-1.376-.04 0-.04-.04-.079-.04-.865-.471-1.534-.196-1.848.709-.472 1.376-1.377 1.887-2.832 1.612-.196-.04-.393-.079-.472-.079-.747.118-1.18.55-1.297 1.14-.158 1.81.786 3.107 2.084 4.17zm-2.32 3.658c-.079-.944-1.023-1.652-2.045-1.534-.905.079-1.691 1.022-1.613 1.966.08.983 1.023 1.77 1.967 1.652 1.14-.079 1.73-1.18 1.69-2.084zm15.18-8.298c.943-.079 1.73-.983 1.651-1.927-.078-.983-1.022-1.77-2.005-1.691-1.023.079-1.73.983-1.652 1.966s.983 1.73 2.006 1.652zm-12.27-.826c1.062-.157 1.77-1.023 1.652-2.045C8.107.897 7.163.149 6.18.267c-1.062.118-1.691.944-1.573 2.085.118.865 1.061 1.612 1.966 1.494z"/></svg>
  {%- else -%}
  <strong>Host:</strong>
  {%- endif -%}
  {{ os_desc }}{% if hostname %} <span style="opacity:0.7">({{ hostname }})</span>{% endif %} &nbsp;|&nbsp;
  <span class="text-status-success">&#10003; {{ triage.automatic }} automatic</span> &nbsp;|&nbsp;
  <span class="text-status-warning">&#9888; {{ triage.fixme }} FIXME</span> &nbsp;|&nbsp;
  <span class="text-status-danger">&#9679; {{ triage.manual }} manual</span> &nbsp;|&nbsp;
  <strong>Warnings:</strong> <span id="banner-warning-count">{{ warnings|length }}</span>
  </p>
</div>

{% if fleet_meta %}
<div class="pf-v6-c-card pf-m-compact fleet-banner" style="margin-bottom: 16px;">
  <div class="pf-v6-c-card__body">
    <div class="text-bold" style="font-size: 1.1em; margin-bottom: 4px;">Fleet Analysis</div>
    <div>{{ fleet_meta.total_hosts }} hosts merged at {{ fleet_meta.min_prevalence }}% prevalence threshold</div>
    <div style="color: var(--pf-v6-global--Color--200);">{{ fleet_meta.source_hosts | join(', ') }}</div>
    <div style="margin-top: 4px;">{{ counts.n_included }} items included, {{ counts.n_excluded }} excluded</div>
  </div>
</div>
{% endif %}


{# ══════════════════════════════════════════════════════════════════════════
   Sections
   ══════════════════════════════════════════════════════════════════════════ #}

{# ── Summary ────────────────────────────────────────────────────────────── #}
{% call section("summary", "Summary", visible=true) %}
<p class="summary-hero">Inspection overview and run metadata. Use the sidebar navigation to drill into any category.</p>
<p class="text-sm">This report is self-contained and portable: all content (Containerfile, audit, config/ and quadlet/ file browser) is embedded. You can copy or share <code>report.html</code> alone.</p>
<dl class="pf-v6-c-description-list summary-meta">
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Host root</dt><dd class="pf-v6-c-description-list__description"><code>{{ meta.host_root|default('') }}</code></dd></div>
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Hostname</dt><dd class="pf-v6-c-description-list__description">{{ meta.hostname|default('—') }}</dd></div>
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Inspection time (UTC)</dt><dd class="pf-v6-c-description-list__description">{{ meta.timestamp|default('—') }}</dd></div>
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">OS</dt><dd class="pf-v6-c-description-list__description">{{ os_desc }}</dd></div>
</dl>
<h3>Migration readiness</h3>
<div class="readiness-panel">
  {%- set auto_items = triage_detail|selectattr('status', 'equalto', 'automatic')|list %}
  {%- set fixme_items = triage_detail|selectattr('status', 'equalto', 'fixme')|list %}
  {%- set manual_items = triage_detail|selectattr('status', 'equalto', 'manual')|list %}
  <div class="pf-v6-c-card readiness-col readiness-auto">
    <div class="readiness-header"><span class="readiness-count">{{ triage.automatic }}</span> Automatic</div>
    <ul>{%- for item in auto_items %}<li><button type="button" class="readiness-link" onclick="show('{{ item.tab }}');return false">{{ item.count }} {{ item.label }}</button></li>{%- endfor %}</ul>
  </div>
  {%- if fixme_items %}
  <div class="pf-v6-c-card readiness-col readiness-fixme">
    <div class="readiness-header"><span class="readiness-count">{{ triage.fixme }}</span> Needs review</div>
    <ul>{%- for item in fixme_items %}<li><button type="button" class="readiness-link" onclick="show('{{ item.tab }}');return false">{{ item.count }} {{ item.label }}</button></li>{%- endfor %}</ul>
  </div>
  {%- endif %}
  {%- if manual_items %}
  <div class="pf-v6-c-card readiness-col readiness-manual">
    <div class="readiness-header"><span class="readiness-count">{{ triage.manual }}</span> Manual</div>
    <ul>{%- for item in manual_items %}<li><button type="button" class="readiness-link" onclick="show('{{ item.tab }}');return false">{{ item.count }} {{ item.label }}</button></li>{%- endfor %}</ul>
  </div>
  {%- endif %}
</div>
<div class="summary-next">
  <p><strong>Next steps:</strong> Review the <strong>Audit report</strong> tab, fix any FIXMEs in the Containerfile, run <code>podman build -t my-image .</code>, then deploy with <code>bootc switch my-image:latest</code>.</p>
</div>
{% endcall %}

{# ── File browser ─────────────────────────────────────────────────────────── #}
{% call section("output_files", "File browser") %}
<p>Browse <code>config/</code> and <code>quadlet/</code> generated in the output directory. Click a file to view its contents.</p>
<div class="pf-v6-l-flex pf-m-nowrap mt-md" style="gap:1rem">
  <div class="fb-tree">{{ tree_html|safe }}</div>
  <div class="fb-viewer">
    <div class="pf-v6-c-code-block">
      <div class="pf-v6-c-code-block__header"><span id="file-viewer-path">Click a file</span></div>
      <div class="pf-v6-c-code-block__content">
        <pre class="pf-v6-c-code-block__pre"><code class="pf-v6-c-code-block__code" id="file-viewer-content"></code></pre>
      </div>
    </div>
  </div>
</div>
{{ file_content_snippets_html|safe }}
{% endcall %}

{# ── Packages ────────────────────────────────────────────────────────────── #}
{% call section("packages", "Packages") %}
  {%- if snapshot.rpm and snapshot.rpm.no_baseline %}
  <p><em>No baseline — showing all packages. Pull the base image or provide --baseline-packages.</em></p>
  {%- endif %}
  {%- if snapshot.rpm and snapshot.rpm.packages_added %}

  {%- if snapshot.rpm.leaf_packages is not none and snapshot.rpm.leaf_dep_tree is not none %}
  {%- set auto_set = snapshot.rpm.auto_packages or [] %}
  {%- set dep_tree = snapshot.rpm.leaf_dep_tree or {} %}

  <div class="pf-v6-c-alert pf-m-info pf-m-inline mb-md" id="pkg-selection-banner">
    <p class="pf-v6-c-alert__title" id="pkg-selection-text"><strong>{{ leaf_packages_sorted|length }} leaf packages</strong> pull in <strong>{{ auto_set|length }} dependencies</strong> — only leaf packages appear in the Containerfile's <code>dnf install</code> line.</p>
  </div>

  {%- if snapshot.rpm.repo_files %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Repositories ({{ snapshot.rpm.repo_files|length }})</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table" id="pkg-repo-table">
      <thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Path</th><th scope="col"><span class="pf-v6-u-screen-reader">Source</span></th><th scope="col"><span class="pf-v6-u-screen-reader">Details</span></th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead>
      <tbody>
      {%- for rf in snapshot.rpm.repo_files %}
      <tr{% if not rf.include %} class="excluded"{% endif %} data-snap-section="rpm" data-snap-list="repo_files" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb repo-cb" {{ 'checked' if rf.include else '' }}{{ ' disabled title="Default distribution repository — cannot be excluded"' if rf.is_default_repo else '' }}/></span></td>
        <td><code>{{ rf.path }}</code></td>
        <td>
          {%- if repo_display[loop.index0].badge %}
          <span class="pf-v6-c-label pf-m-compact {{ repo_display[loop.index0].badge_color }}"><span class="pf-v6-c-label__content">{{ repo_display[loop.index0].badge }}</span></span>
          {%- endif %}
        </td>
        <td>
          {%- if rf.content %}
          <details><summary>show</summary>
            <pre class="repo-content-pre">{{ rf.content }}</pre>
          </details>
          {%- endif %}
        </td>
        {{ fleet_cell(rf) }}
      </tr>
      {%- endfor %}
      </tbody>
    </table>
    </div>
  </div>
  {%- endif %}

  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Dependency Tree</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- if repo_groups %}
    <table class="pf-v6-c-table pkg-dep-tree-group">
      <thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Leaf Package</th><th scope="col">Dependencies</th><th scope="col"><span class="pf-v6-u-screen-reader">Details</span></th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead>
      <tbody>
      {%- for repo_name, entries in repo_groups.items() %}
      <tr><th colspan="{{ 5 if fleet_meta else 4 }}" class="table-group-header{{ ' table-group-header-first' if loop.first else '' }}">{{ repo_name }} ({{ entries|length }} package{{ 's' if entries|length != 1 else '' }})</th></tr>
      {%- for entry in entries %}
      <tr{% if not entry.include %} class="excluded"{% endif %} data-leaf="{{ entry.name }}" data-snap-section="rpm" data-snap-list="packages_added" data-snap-index="{{ entry.snap_index }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb leaf-cb" {{ 'checked' if entry.include else '' }}/></span></td>
        <td><strong>{{ entry.name }}</strong></td>
        <td>{{ entry.deps|length }}</td>
        <td>
          {%- if entry.deps %}
          <details><summary>show</summary>
            <ul class="deps-list">
            {%- for d in entry.deps %}
              <li class="text-sm">{{ d }}</li>
            {%- endfor %}
            </ul>
          </details>
          {%- else %}
          <em>independent</em>
          {%- endif %}
        </td>
        {{ fleet_cell(entry) }}
      </tr>
      {%- endfor %}
      {%- endfor %}
      </tbody>
    </table>
    {%- else %}
    {# Fallback: flat table when repo_groups is not populated #}
    <table class="pf-v6-c-table" id="pkg-dep-tree">
      <thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Leaf Package</th><th scope="col">Repo</th><th scope="col">Dependencies</th><th scope="col"><span class="pf-v6-u-screen-reader">Details</span></th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead>
      <tbody>
      {%- for lf in leaf_packages_sorted if dep_tree.get(lf) is not none %}
      {%- set deps = dep_tree.get(lf, []) %}
      {%- set leaf_idx = namespace(val=-1) %}
      {%- for p in snapshot.rpm.packages_added %}
        {%- if p.name == lf %}{% set leaf_idx.val = loop.index0 %}{% endif %}
      {%- endfor %}
      <tr{% if leaf_idx.val >= 0 and not snapshot.rpm.packages_added[leaf_idx.val].include %} class="excluded"{% endif %} data-leaf="{{ lf }}" data-snap-section="rpm" data-snap-list="packages_added" data-snap-index="{{ leaf_idx.val }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb leaf-cb" {{ 'checked' if leaf_idx.val < 0 or snapshot.rpm.packages_added[leaf_idx.val].include else '' }}/></span></td>
        <td><strong>{{ lf }}</strong></td>
        <td class="text-sm">{{ snapshot.rpm.packages_added[leaf_idx.val].source_repo if leaf_idx.val >= 0 else '' }}</td>
        <td>{{ deps|length }}</td>
        <td>
          {%- if deps %}
          <details><summary>show</summary>
            <ul class="deps-list">
            {%- for d in deps %}
              <li class="text-sm">{{ d }}</li>
            {%- endfor %}
            </ul>
          </details>
          {%- else %}
          <em>independent</em>
          {%- endif %}
        </td>
        {% if fleet_meta and leaf_idx.val >= 0 %}{{ fleet_cell(snapshot.rpm.packages_added[leaf_idx.val]) }}{% elif fleet_meta %}<td class="fleet-prevalence"></td>{% endif %}
      </tr>
      {%- endfor %}
      </tbody>
    </table>
    {%- endif %}
    </div>
  </div>

  {%- set leaf_names = snapshot.rpm.leaf_packages %}
  {%- set auto_names = snapshot.rpm.auto_packages or [] %}
  {%- set unclassified_pkgs = [] %}
  {%- for p in snapshot.rpm.packages_added %}
    {%- if p.name not in leaf_names and p.name not in auto_names %}
      {%- set _ = unclassified_pkgs.append(p) %}
    {%- endif %}
  {%- endfor %}
  {%- if unclassified_pkgs %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Unclassified Packages ({{ unclassified_pkgs|length }})</h3></div></div>
    <div class="pf-v6-c-card__body">
    <p class="text-sm">These packages could not be classified as leaf or auto-dependency. They are included in the Containerfile by default.</p>
    <table class="pf-v6-c-table">
      <thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Name</th><th scope="col">Version</th><th scope="col">Arch</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead>
      <tbody>
      {%- for p in unclassified_pkgs %}
      {%- set uidx = namespace(val=-1) %}
      {%- for q in snapshot.rpm.packages_added %}
        {%- if q.name == p.name %}{% set uidx.val = loop.index0 %}{% endif %}
      {%- endfor %}
      <tr{% if not p.include %} class="excluded"{% endif %} data-snap-section="rpm" data-snap-list="packages_added" data-snap-index="{{ uidx.val }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if p.include else '' }}/></span></td>
        <td>{{ p.name }}</td>
        <td>{{ p.version }}-{{ p.release }}</td>
        <td>{{ p.arch }}</td>
        {{ fleet_cell(p) }}
      </tr>
      {%- endfor %}
      </tbody>
    </table>
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Name</th><th scope="col">Version</th><th scope="col">Release</th><th scope="col">Arch</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
    {%- for p in snapshot.rpm.packages_added[:100] %}
    <tr{% if not p.include %} class="excluded"{% endif %} data-snap-section="rpm" data-snap-list="packages_added" data-snap-index="{{ loop.index0 }}"><td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if p.include else '' }}/></span></td><td>{{ p.name }}</td><td>{{ p.version }}</td><td>{{ p.release }}</td><td>{{ p.arch }}</td>{{ fleet_cell(p) }}</tr>
    {%- endfor %}
  </tbody></table>
  {%- if snapshot.rpm.packages_added|length > 100 %}
  <p>... and {{ snapshot.rpm.packages_added|length - 100 }} more.</p>
  {%- endif %}
  {%- endif %}

  {%- else %}
  <p>No added packages.</p>
  {%- endif %}
{% endcall %}

{# ── Services ────────────────────────────────────────────────────────────── #}
{% call section("services", "Services") %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Service State Changes</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- if snapshot.services and snapshot.services.state_changes | selectattr('action', 'ne', 'unchanged') | list %}
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Unit</th><th scope="col">Current</th><th scope="col">Default</th><th scope="col">Action</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
      {%- for s in snapshot.services.state_changes %}
      {%- if s.action != 'unchanged' %}
      <tr{% if not s.include %} class="excluded"{% endif %} data-snap-section="services" data-snap-list="state_changes" data-snap-index="{{ loop.index0 }}"><td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if s.include else '' }}/></span></td><td>{{ s.unit }}</td><td>{{ s.current_state }}</td><td>{{ s.default_state }}</td><td>{{ s.action }}</td>{{ fleet_cell(s) }}</tr>
      {%- endif %}
      {%- endfor %}
    </tbody></table>
    {%- else %}
    <p>No service changes.</p>
    {%- endif %}
    </div>
  </div>

  {%- if snapshot.services and snapshot.services.drop_ins %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Drop-in Overrides ({{ snapshot.services.drop_ins|length }})</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Parent unit</th><th scope="col">Drop-in path</th><th scope="col">Content</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
      {%- for d in snapshot.services.drop_ins %}
      <tr{% if not d.include %} class="excluded"{% endif %} data-snap-section="services" data-snap-list="drop_ins" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if d.include else '' }}/></span></td>
        <td>{{ d.unit }}</td>
        <td><code>{{ d.path }}</code></td>
        <td>
          {%- if d.content.strip() %}
          <details><summary>show</summary>
            <pre class="content-preview">{{ d.content }}</pre>
          </details>
          {%- endif %}
        </td>
        {{ fleet_cell(d) }}
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}
{% endcall %}

{# ── Config ──────────────────────────────────────────────────────────────── #}
{% call section("config", "Configuration files") %}
  {%- if snapshot.config and snapshot.config.files %}
  <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Path</th><th scope="col">Kind</th><th scope="col">rpm -Va flags</th><th scope="col">Diff</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
    {%- for item in config_files_rendered %}
    <tr{% if not item.include %} class="excluded"{% endif %} data-snap-section="config" data-snap-list="files" data-snap-index="{{ item.snap_index }}">
      <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if item.include else '' }}/></span></td>
      <td><code>{{ item.path }}</code></td>
      <td>{{ item.kind }}</td>
      <td>{% if item.flags %}<code>{{ item.flags }}</code>{% endif %}</td>
      <td>{{ item.diff_html|safe }}</td>
      {{ fleet_cell(item) }}
    </tr>
    {%- endfor %}
  </tbody></table>
  {%- else %}
  <p>No config files.</p>
  {%- endif %}
{% endcall %}

{# ── Non-RPM software ────────────────────────────────────────────────────── #}
{% call section("non_rpm", "Non-RPM software") %}
  {%- set nr = snapshot.non_rpm_software %}
  {%- if nr and nr.items %}
  {%- set nd = non_rpm_data %}

  {%- if nd.elf %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Compiled Binaries</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Path</th><th scope="col">Language</th><th scope="col">Linking</th><th scope="col">Shared Libraries</th></tr></thead><tbody>
      {%- for i in nd.elf %}
      {%- set lang = i.lang %}
      {%- set lang_lbl = {'go': 'pf-m-teal', 'rust': 'pf-m-orange', 'c/c++': 'pf-m-purple'} %}
      {%- set linking = 'static' if i.static else 'dynamic' %}
      {%- set nr_idx = namespace(val=-1) %}
      {%- for item in nr.items %}{% if item.path == i.path %}{% set nr_idx.val = loop.index0 %}{% endif %}{%- endfor %}
      <tr{% if not i.include %} class="excluded"{% endif %} data-snap-section="non_rpm_software" data-snap-list="items" data-snap-index="{{ nr_idx.val }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if i.include else '' }}/></span></td>
        <td><code>{{ i.path }}</code></td>
        <td><span class="pf-v6-c-label pf-m-filled {{ lang_lbl.get(lang, 'pf-m-grey') }}">{{ lang }}</span></td>
        <td><span class="pf-v6-c-label pf-m-filled {{ 'pf-m-green' if i.static else 'pf-m-orange' }}">{{ linking }}</span></td>
        <td class="text-sm">{{ i.shared_libs[:5]|join(', ') or '' }}</td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if nd.venv %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Python Virtual Environments</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- for v in nd.venv %}
    {%- set ssp = v.system_site_packages %}
    <div class="mt-md" style="display:flex;align-items:center;gap:var(--pf-t--global--spacer--sm)">
      <code>{{ v.path }}</code>
      {%- if ssp %} <span class="pf-v6-c-label pf-m-filled pf-m-red">system-site-packages</span>
      {%- else %} <span class="pf-v6-c-label pf-m-filled pf-m-green">isolated</span>
      {%- endif %}
    </div>
    {%- set pkgs = v.packages %}
    {%- if pkgs %}
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Package</th><th scope="col">Version</th></tr></thead><tbody>
      {%- for p in pkgs[:20] %}
      <tr><td>{{ p.name }}</td><td>{{ p.version }}</td></tr>
      {%- endfor %}
      {%- if pkgs|length > 20 %}
      <tr><td colspan="2"><em>+{{ pkgs|length - 20 }} more</em></td></tr>
      {%- endif %}
    </tbody></table>
    {%- else %}
    <p>No packages found.</p>
    {%- endif %}
    {%- endfor %}
    </div>
  </div>
  {%- endif %}

  {%- if nd.git %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Git Repositories</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Path</th><th scope="col">Remote</th><th scope="col">Branch</th><th scope="col">Commit</th></tr></thead><tbody>
      {%- for i in nd.git %}
      <tr>
        <td><code>{{ i.path }}</code></td>
        <td><code>{{ i.git_remote }}</code></td>
        <td>{{ i.git_branch }}</td>
        <td><code>{{ i.git_commit[:12] }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if nd.pip %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>System Pip Packages</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Package</th><th scope="col">Version</th><th scope="col">Path</th></tr></thead><tbody>
      {%- for i in nd.pip[:20] %}
      {%- set nr_idx = namespace(val=-1) %}
      {%- for item in nr.items %}{% if item.path == i.path and item.name == i.name %}{% set nr_idx.val = loop.index0 %}{% endif %}{%- endfor %}
      <tr{% if not i.include %} class="excluded"{% endif %} data-snap-section="non_rpm_software" data-snap-list="items" data-snap-index="{{ nr_idx.val }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if i.include else '' }}/></span></td>
        <td>{{ i.name }}</td>
        <td>{{ i.version }}</td>
        <td><code>{{ i.path }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if nd.other %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Other Items</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Path</th><th scope="col">Confidence</th><th scope="col">Method</th></tr></thead><tbody>
      {%- for i in nd.other[:20] %}
      <tr>
        <td><code>{{ i.path or i.name }}</code></td>
        <td>{{ i.confidence }}</td>
        <td>{{ i.method }}</td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if nr and nr.env_files %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Dotenv / Secret Files</h3></div></div>
    <div class="pf-v6-c-card__body">
    <p>These files may contain API keys or passwords. Secrets have been redacted; inject them at deploy time via a secret store or systemd credentials.</p>
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Path</th><th scope="col">Status</th></tr></thead><tbody>
      {%- for ef in nr.env_files %}
      <tr>
        <td><code>{{ ef.path }}</code></td>
        <td>captured &amp; redacted</td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No non-RPM software.</p>
  {%- endif %}
{% endcall %}

{# ── Containers ──────────────────────────────────────────────────────────── #}
{% call section("containers", "Containers") %}
  {%- set ct = snapshot.containers %}
  {%- if ct and (ct.quadlet_units or ct.compose_files or ct.running_containers) %}

  {%- if ct.quadlet_units %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Quadlet Units</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Unit</th><th scope="col">Image</th><th scope="col">Path</th><th scope="col">Content</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
      {%- for u in ct.quadlet_units %}
      <tr{% if not u.include %} class="excluded"{% endif %} data-snap-section="containers" data-snap-list="quadlet_units" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if u.include else '' }}/></span></td>
        <td>{{ u.name }}</td>
        <td>{% if u.image %}<code>{{ u.image }}</code>{% else %}<em>none</em>{% endif %}</td>
        <td><code>{{ u.path }}</code></td>
        <td>
          {%- if u.content and u.content.strip() %}
          <details><summary>show</summary>
            <pre class="content-preview">{{ u.content }}</pre>
          </details>
          {%- endif %}
        </td>
        {{ fleet_cell(u) }}
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if ct.compose_files %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Compose Files</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- for c in ct.compose_files %}
    <div{% if not c.include %} class="excluded"{% endif %} data-snap-section="containers" data-snap-list="compose_files" data-snap-index="{{ loop.index0 }}">
    <label><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if c.include else '' }}/></span></label>
    <span class="text-bold"><code>{{ c.path }}</code></span>
    {% if fleet_meta and c.fleet %}
    <div class="fleet-prevalence" style="display: inline-block; margin-left: 8px;">
      <div class="fleet-bar"
           data-count="{{ c.fleet.count }}"
           data-total="{{ c.fleet.total }}"
           data-hosts="{{ c.fleet.hosts | join(', ') }}">
        <div class="fleet-bar-track">
          <div class="fleet-bar-fill {{ c.fleet | fleet_color }}"
               style="width: {{ (c.fleet.count * 100 // c.fleet.total) if c.fleet.total > 0 else 100 }}%"></div>
        </div>
        <span class="fleet-bar-label">{{ c.fleet.count }}/{{ c.fleet.total }}</span>
      </div>
    </div>
    {% endif %}
    {%- if c.images %}
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Service</th><th scope="col">Image</th></tr></thead><tbody>
      {%- for img in c.images %}
      <tr><td>{{ img.service }}</td><td><code>{{ img.image }}</code></td></tr>
      {%- endfor %}
    </tbody></table>
    {%- else %}
    <p>No image references found.</p>
    {%- endif %}
    </div>
    {%- endfor %}
    </div>
  </div>
  {%- endif %}

  {%- if ct.running_containers %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Running Containers</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Name</th><th scope="col">Image</th><th scope="col">Status</th><th scope="col">Mounts</th><th scope="col">Networks</th></tr></thead><tbody>
      {%- for item in containers_data.running %}
      <tr>
        <td><strong>{{ item.name }}</strong></td>
        <td><code>{{ item.image }}</code></td>
        <td>{{ item.status }}</td>
        <td class="text-sm">{{ item.mount_summary|safe }}</td>
        <td class="text-sm">{{ item.net_summary or '' }}</td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No container workloads.</p>
  {%- endif %}
{% endcall %}

{# ── Users / Groups ───────────────────────────────────────────────────────── #}
{% call section("users_groups", "Users and groups") %}
  {%- if snapshot.users_groups and snapshot.users_groups.users %}
  {%- set ug = snapshot.users_groups %}
  {%- set strategies = ["sysusers", "blueprint", "useradd", "kickstart"] %}

  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header">
      <div class="pf-v6-c-card__title"><h3>Users</h3></div>
      <div class="pf-v6-c-card__actions card-actions-layout">
        <span>Apply to all:</span>
        <span class="pf-v6-c-form-control"><select id="strategy-apply-all">
          {%- for s in strategies %}
          <option value="{{ s }}">{{ s }}</option>
          {%- endfor %}
        </select></span>
        <button type="button" class="pf-v6-c-button pf-m-secondary" id="btn-strategy-apply-all">Apply</button>
      </div>
    </div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table">
      <thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">User</th><th scope="col">UID/GID</th><th scope="col">Shell</th><th scope="col">Home</th><th scope="col">Type</th><th scope="col">Strategy</th><th scope="col">Notes</th></tr></thead>
      <tbody>
      {%- for u in ug.users %}
      {%- set cls = u.classification or '?' %}
      {%- set cls_lbl = 'pf-m-green' if cls == 'service' else 'pf-m-blue' if cls == 'human' else 'pf-m-orange' %}
      <tr{% if not u.get('include', true) %} class="excluded"{% endif %} data-snap-section="users_groups" data-snap-list="users" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if u.get('include', true) else '' }}/></span></td>
        <td><strong>{{ u.name }}</strong></td>
        <td>{{ u.uid }}:{{ u.gid or '?' }}</td>
        <td><code>{{ u.shell }}</code></td>
        <td><code>{{ u.home }}</code></td>
        <td><span class="pf-v6-c-label pf-m-filled {{ cls_lbl }}">{{ cls }}</span></td>
        <td>
          <span class="pf-v6-c-form-control"><select class="strategy-select">
            {%- for s in strategies %}
            <option value="{{ s }}" {{ 'selected' if s == u.strategy else '' }}>{{ s }}</option>
            {%- endfor %}
          </select></span>
        </td>
        <td class="text-sm">
          {%- set notes = [] %}
          {%- if u.name in (ug.ssh_authorized_keys_refs or [])|map(attribute='user')|list %}
            {%- set _ = notes.append('SSH keys') %}
            <span class="pf-v6-c-label pf-m-filled pf-m-orange" title="authorized_keys found on source but not included in image">SSH KEYS</span>
          {%- endif %}
          {%- if cls == 'ambiguous' %}
            <span class="pf-v6-c-label pf-m-filled pf-m-orange" title="Classification uncertain — verify intent">ambiguous</span>
          {%- endif %}
        </td>
      </tr>
      {%- endfor %}
      </tbody>
    </table>
    </div>
  </div>

  {%- if ug.groups %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header">
      <div class="pf-v6-c-card__title"><h3>Groups</h3></div>
      <div class="pf-v6-c-card__actions card-actions-layout">
        <span>Apply to all:</span>
        <span class="pf-v6-c-form-control"><select id="strategy-apply-all-groups">
          {%- for s in strategies %}
          <option value="{{ s }}">{{ s }}</option>
          {%- endfor %}
        </select></span>
        <button type="button" class="pf-v6-c-button pf-m-secondary" id="btn-strategy-apply-all-groups">Apply</button>
      </div>
    </div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table">
      <thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Group</th><th scope="col">GID</th><th scope="col">Strategy</th><th scope="col">Members</th></tr></thead>
      <tbody>
      {%- for g in ug.groups %}
      <tr{% if not g.get('include', true) %} class="excluded"{% endif %} data-snap-section="users_groups" data-snap-list="groups" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if g.get('include', true) else '' }}/></span></td>
        <td>{{ g.name }}</td>
        <td>{{ g.gid }}</td>
        <td>
          <span class="pf-v6-c-form-control"><select class="strategy-select">
            {%- for s in strategies %}
            <option value="{{ s }}" {{ 'selected' if s == g.strategy else '' }}>{{ s }}</option>
            {%- endfor %}
          </select></span>
        </td>
        <td>{{ (g.members or [])|join(', ') or '—' }}</td>
      </tr>
      {%- endfor %}
      </tbody>
    </table>
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No non-system users/groups.</p>
  {%- endif %}
{% endcall %}

{# ── Scheduled jobs ───────────────────────────────────────────────────────── #}
{% call section("scheduled_tasks", "Scheduled jobs") %}
  {%- set st = snapshot.scheduled_tasks %}
  {%- if st and (st.cron_jobs or st.systemd_timers or st.generated_timer_units or st.at_jobs) %}

  {%- set local_timers = [] %}{%- set vendor_timers = [] %}
  {%- for t in st.systemd_timers %}
    {%- if t.source == 'local' %}{% set _ = local_timers.append(t) %}
    {%- elif t.source == 'vendor' %}{% set _ = vendor_timers.append(t) %}
    {%- endif %}
  {%- endfor %}

  {%- if local_timers or vendor_timers %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Systemd Timers</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- if vendor_timers %}
    <p class="text-sm">{{ vendor_timers|length }} vendor timer{{ 's' if vendor_timers|length != 1 else '' }} (base image defaults) not shown.</p>
    {%- endif %}
    {%- if local_timers %}
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Timer</th><th scope="col">Schedule</th><th scope="col">ExecStart</th></tr></thead><tbody>
      {%- for t in local_timers %}
      <tr>
        <td>{{ t.name }}</td><td>{{ t.on_calendar }}</td>
        <td><code>{{ t.exec_start }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    {%- endif %}
    </div>
  </div>
  {%- endif %}

  {%- if st.generated_timer_units %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Cron-Converted Timers</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Name</th><th scope="col">Cron Expression</th><th scope="col">Source File</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
      {%- for u in st.generated_timer_units %}
      <tr{% if not u.include %} class="excluded"{% endif %} data-snap-section="scheduled_tasks" data-snap-list="generated_timer_units" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if u.include else '' }}/></span></td>
        <td>{{ u.name }}</td>
        <td><code>{{ u.cron_expr }}</code></td>
        <td><code>{{ u.source_path }}</code></td>
        {{ fleet_cell(u) }}
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- set rpm_cron_count = st.cron_jobs | selectattr('rpm_owned') | list | length %}
  {%- if st.cron_jobs %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Cron Jobs</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- if rpm_cron_count %}
    <p class="text-sm">{{ rpm_cron_count }} package-owned cron job{{ 's' if rpm_cron_count != 1 else '' }} (base image defaults) not shown.</p>
    {%- endif %}
    {%- if st.cron_jobs | selectattr('rpm_owned', 'equalto', false) | list %}
    <table class="pf-v6-c-table"><thead>
      <tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Path</th><th scope="col">Source</th><th scope="col">Action</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
      {%- for j in st.cron_jobs %}
      {%- if not j.rpm_owned %}
      <tr{% if not j.include %} class="excluded"{% endif %} data-snap-section="scheduled_tasks" data-snap-list="cron_jobs" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if j.include else '' }}/></span></td>
        <td><code>{{ j.path }}</code></td>
        <td>{{ j.source }}</td>
        <td>Convert to systemd timer</td>
        {{ fleet_cell(j) }}
      </tr>
      {%- endif %}
      {%- endfor %}
    </tbody></table>
    {%- endif %}
    </div>
  </div>
  {%- endif %}

  {%- if st.at_jobs %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>At Jobs</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">File</th><th scope="col">User</th><th scope="col">Command</th></tr></thead><tbody>
      {%- for a in st.at_jobs %}
      {%- set cmd = a.command[:117] ~ '...' if a.command|length > 120 else a.command %}
      <tr><td><code>{{ a.file }}</code></td><td>{{ a.user }}</td><td><code>{{ cmd }}</code></td></tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No scheduled tasks.</p>
  {%- endif %}
{% endcall %}

{# ── Kernel / Boot ────────────────────────────────────────────────────────── #}
{% call section("kernel_boot", "Kernel and boot") %}
  {%- set kb = snapshot.kernel_boot %}
  {%- if kb and (kb.cmdline or kb.sysctl_overrides or kb.non_default_modules or kb.modules_load_d or kb.modprobe_d or kb.dracut_conf or kb.tuned_active or kb.tuned_custom_profiles) %}

  {%- if kb.cmdline or kb.non_default_modules %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Kernel Command Line</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- if kb.cmdline %}
    <div class="pf-v6-c-code-block"><div class="pf-v6-c-code-block__content"><pre class="pf-v6-c-code-block__pre"><code class="pf-v6-c-code-block__code">{{ kb.cmdline[:300] }}</code></pre></div></div>
    {%- endif %}
    {%- if kb.non_default_modules %}
    <p>{{ kb.non_default_modules|length }} kernel module(s) loaded at inspection time (hardware-specific, not included in the image). See modules-load.d entries below for explicitly configured modules.</p>
    {%- endif %}
    </div>
  </div>
  {%- endif %}

  {%- if kb.sysctl_overrides %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Sysctl Overrides</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Key</th><th scope="col">Runtime</th><th scope="col">Default</th><th scope="col">Source</th></tr></thead><tbody>
      {%- for s in kb.sysctl_overrides %}
      <tr{% if not s.include %} class="excluded"{% endif %} data-snap-section="kernel_boot" data-snap-list="sysctl_overrides" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if s.include else '' }}/></span></td>
        <td><code>{{ s.key }}</code></td>
        <td class="text-status-warning text-bold">{{ s.runtime }}</td>
        <td>{{ s.default or '—' }}</td>
        <td><code>{{ s.source }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if kb.modules_load_d or kb.modprobe_d or kb.dracut_conf %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Module and Dracut Configuration</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- set modconf_sections =
          ([("modules-load.d", kb.modules_load_d)] if kb.modules_load_d else []) +
          ([("modprobe.d", kb.modprobe_d)] if kb.modprobe_d else []) +
          ([("dracut.conf.d", kb.dracut_conf)] if kb.dracut_conf else [])
    %}
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Path</th><th scope="col">Content</th></tr></thead><tbody>
      {%- for label, items in modconf_sections %}
      <tr><th colspan="2" class="table-group-header{{ ' table-group-header-first' if loop.first else '' }}">{{ label }}</th></tr>
      {%- for cfg in items %}
      <tr>
        <td><code>{{ cfg.path }}</code></td>
        <td>
          {%- if cfg.content and cfg.content.strip() %}
          <details><summary>show</summary>
            <pre class="content-preview">{{ cfg.content }}</pre>
          </details>
          {%- endif %}
        </td>
      </tr>
      {%- endfor %}
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if kb.tuned_active or kb.tuned_custom_profiles %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Tuned Profile</h3></div></div>
    <div class="pf-v6-c-card__body">
    {%- if kb.tuned_active %}<p>Active profile: <strong>{{ kb.tuned_active }}</strong></p>{%- endif %}
    {%- if kb.tuned_custom_profiles %}
    <p>Custom profiles ({{ kb.tuned_custom_profiles|length }}):</p>
    <ul>
      {%- for tp in kb.tuned_custom_profiles %}
      <li><code>{{ tp.path }}</code></li>
      {%- endfor %}
    </ul>
    {%- endif %}
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No kernel/boot customizations detected.</p>
  {%- endif %}
{% endcall %}

{# ── SELinux ──────────────────────────────────────────────────────────────── #}
{% call section("selinux", "SELinux / Security") %}
  {%- set se = snapshot.selinux %}
  {%- if se and (se.mode or se.custom_modules or se.boolean_overrides or se.audit_rules or se.fips_mode or se.port_labels or se.fcontext_rules or se.pam_configs) %}

  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Overview</h3></div></div>
    <div class="pf-v6-c-card__body">
    <dl class="pf-v6-c-description-list pf-m-horizontal">
      {%- if se.mode %}
      <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term"><span class="pf-v6-c-description-list__text">Mode</span></dt><dd class="pf-v6-c-description-list__description"><div class="pf-v6-c-description-list__text">{{ se.mode }}</div></dd></div>
      {%- endif %}
      {%- if se.fips_mode %}
      <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term"><span class="pf-v6-c-description-list__text">FIPS mode</span></dt><dd class="pf-v6-c-description-list__description"><div class="pf-v6-c-description-list__text">enabled</div></dd></div>
      {%- endif %}
      {%- if se.audit_rules %}
      <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term"><span class="pf-v6-c-description-list__text">Audit rule files</span></dt><dd class="pf-v6-c-description-list__description"><div class="pf-v6-c-description-list__text">{{ se.audit_rules|length }}</div></dd></div>
      {%- endif %}
      {%- if se.pam_configs %}
      <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term"><span class="pf-v6-c-description-list__text">PAM configs</span></dt><dd class="pf-v6-c-description-list__description"><div class="pf-v6-c-description-list__text">{{ se.pam_configs|length }}</div></dd></div>
      {%- endif %}
    </dl>
    </div>
  </div>

  {%- if se.custom_modules %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Custom Policy Modules</h3></div></div>
    <div class="pf-v6-c-card__body">
    <ul>{%- for m in se.custom_modules %}<li><code>{{ m }}</code></li>{%- endfor %}</ul>
    </div>
  </div>
  {%- endif %}

  {%- set non_default = se.boolean_overrides|selectattr('non_default')|list %}
  {%- set unchanged_count = (se.boolean_overrides|length) - (non_default|length) %}
  {%- if non_default %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Non-Default Booleans</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Boolean</th><th scope="col">Current</th><th scope="col">Default</th><th scope="col">Description</th></tr></thead><tbody>
      {%- for b in non_default %}
      {%- set cur = b.get('current', '?') %}
      <tr>
        <td><code>{{ b.get('name', '?') }}</code></td>
        <td class="{{ 'text-status-success' if cur == 'on' else 'text-status-danger' }} text-bold">{{ cur }}</td>
        <td>{{ b.get('default', '?') }}</td>
        <td>{{ b.get('description', '') }}</td>
      </tr>
      {%- endfor %}
    </tbody></table>
    {%- if unchanged_count > 0 %}<p>{{ unchanged_count }} boolean(s) at default values (not shown).</p>{%- endif %}
    </div>
  </div>
  {%- endif %}

  {%- if se.port_labels %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Custom Port Labels</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Protocol</th><th scope="col">Port</th><th scope="col">SELinux type</th></tr></thead><tbody>
      {%- for pl in se.port_labels %}
      <tr>
        <td><code>{{ pl.protocol }}</code></td>
        <td><code>{{ pl.port }}</code></td>
        <td><code>{{ pl.type }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No SELinux/security customizations detected.</p>
  {%- endif %}
{% endcall %}

{# ── Secrets ──────────────────────────────────────────────────────────────── #}
{% call section("secrets", "Secrets") %}
  {%- if secrets_data %}
  <p><strong>{{ secrets_data|length }} value(s) redacted</strong> across <strong>{{ secrets_file_count }} file(s)</strong>.</p>
  <table class="pf-v6-c-table">
    <thead><tr><th scope="col">File Path</th><th scope="col">Pattern</th><th scope="col">Line</th><th scope="col">Remediation</th></tr></thead>
    <tbody>
    {%- for r in secrets_data %}
    <tr>
      <td><code>{{ r.path or '?' }}</code></td>
      <td>{{ r.pattern or '?' }}</td>
      <td>{{ r.line or '?' }}</td>
      <td class="text-sm">{{ r.remediation or '' }}</td>
    </tr>
    {%- endfor %}
    </tbody>
  </table>
  {%- else %}
  <p class="text-status-success">No secrets detected.</p>
  {%- endif %}
{% endcall %}

{# ── Network ─────────────────────────────────────────────────────────────── #}
{% call section("network", "Network") %}
  {%- set net = snapshot.network %}
  {%- if net and (net.connections or net.firewall_zones or net.firewall_direct_rules or net.ip_routes or net.ip_rules or net.resolv_provenance) %}

  {%- if net.connections %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Connections</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th scope="col">Name</th><th scope="col">Method</th><th scope="col">Type</th><th scope="col">Deployment</th></tr></thead><tbody>
      {%- for c in net.connections %}
      <tr>
        <td><code>{{ c.name }}</code></td>
        <td>{{ c.method }}</td>
        <td>{{ c.type }}</td>
        <td>
          {%- if c.method == 'static' -%}
          <span class="text-status-success text-bold">Bake into image</span>
          {%- elif c.method == 'dhcp' -%}
          <span class="text-status-warning text-bold">Kickstart at deploy</span>
          {%- else -%}
          <span>Review</span>
          {%- endif -%}
        </td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if net.firewall_zones %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Firewall Zones</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">Zone</th><th scope="col">Services</th><th scope="col">Ports</th><th scope="col">Rich Rules</th>{% if fleet_meta %}<th scope="col">Fleet</th>{% endif %}</tr></thead><tbody>
      {%- for z in net.firewall_zones %}
      <tr{% if not z.include %} class="excluded"{% endif %} data-snap-section="network" data-snap-list="firewall_zones" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if z.include else '' }}/></span></td>
        <td><strong>{{ z.name }}</strong></td>
        <td>{{ z.services|join(', ') or '—' }}</td>
        <td>{{ z.ports|join(', ') or '—' }}</td>
        <td>
          {%- if z.rich_rules %}
          <details><summary>{{ z.rich_rules|length }} rule{{ 's' if z.rich_rules|length != 1 else '' }}</summary>
            <ul class="deps-list">
              {%- for r in z.rich_rules %}<li><code>{{ r[:300] }}</code></li>{%- endfor %}
            </ul>
          </details>
          {%- else %}—{%- endif %}
        </td>
        {{ fleet_cell(z) }}
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if net.firewall_direct_rules %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Firewall Direct Rules</h3></div></div>
    <div class="pf-v6-c-card__body">
    <table class="pf-v6-c-table"><thead><tr><th class="pf-v6-c-table__check" scope="col"></th><th scope="col">IPv</th><th scope="col">Table</th><th scope="col">Chain</th><th scope="col">Args</th></tr></thead><tbody>
      {%- for r in net.firewall_direct_rules %}
      <tr{% if not r.include %} class="excluded"{% endif %} data-snap-section="network" data-snap-list="firewall_direct_rules" data-snap-index="{{ loop.index0 }}">
        <td class="pf-v6-c-table__check"><span class="pf-v6-c-check pf-m-standalone include-cb-wrap"><input type="checkbox" class="pf-v6-c-check__input include-cb" {{ 'checked' if r.include else '' }}/></span></td>
        <td>{{ r.ipv }}</td>
        <td>{{ r.table }}</td>
        <td>{{ r.chain }}</td>
        <td><code>{{ r.args }}</code></td>
      </tr>
      {%- endfor %}
    </tbody></table>
    </div>
  </div>
  {%- endif %}

  {%- if net.resolv_provenance %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>DNS</h3></div></div>
    <div class="pf-v6-c-card__body">
    <p>resolv.conf provenance:
      {%- if net.resolv_provenance == 'networkmanager' %}
      <span class="text-status-warning text-bold">NetworkManager-managed</span> — DHCP-assigned DNS — kickstart at deploy time
      {%- elif net.resolv_provenance == 'systemd-resolved' %}
      <span class="text-status-warning text-bold">systemd-resolved</span> — system resolver — kickstart at deploy time
      {%- else %}
      <span class="text-status-success text-bold">hand-edited</span> — bake /etc/resolv.conf into image or manage at deploy
      {%- endif %}
    </p>
    </div>
  </div>
  {%- endif %}

  {%- if net.ip_routes %}
  {%- set static_rt = [] %}
  {%- for r in net.ip_routes %}{% if 'proto static' in r %}{% set _ = static_rt.append(r) %}{% endif %}{%- endfor %}
  {%- if static_rt %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Static Routes</h3></div></div>
    <div class="pf-v6-c-card__body">
    <ul>
      {%- for r in static_rt %}<li><code>{{ r }}</code></li>{%- endfor %}
    </ul>
    </div>
  </div>
  {%- endif %}
  {%- endif %}

  {%- if net.ip_rules %}
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header"><div class="pf-v6-c-card__title"><h3>Policy Routing</h3></div></div>
    <div class="pf-v6-c-card__body">
    <ul>
      {%- for r in net.ip_rules %}<li><code>{{ r }}</code></li>{%- endfor %}
    </ul>
    </div>
  </div>
  {%- endif %}

  {%- else %}
  <p>No network config captured.</p>
  {%- endif %}
{% endcall %}

{# ── Storage ─────────────────────────────────────────────────────────────── #}
{% call section("storage", "Storage") %}
  {%- if snapshot.storage and snapshot.storage.fstab_entries %}
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Device</th><th scope="col">Mount</th><th scope="col">Type</th></tr></thead><tbody>
    {%- for e in snapshot.storage.fstab_entries[:30] %}
    <tr><td>{{ e.device }}</td><td>{{ e.mount_point }}</td><td>{{ e.fstype }}</td></tr>
    {%- endfor %}
  </tbody></table>
  {%- else %}
  <p>No fstab entries.</p>
  {%- endif %}
{% endcall %}

{# ── Warnings ─────────────────────────────────────────────────────────────── #}
{% call section("warnings", "Warnings") %}
<div class="pf-v6-c-text-input-group mb-md">
  <div class="pf-v6-c-text-input-group__main">
    <input type="text" class="pf-v6-c-text-input-group__text-input" id="warn-search" placeholder="Search warnings..."/>
  </div>
</div>
<div style="display:flex;justify-content:flex-end;margin-bottom:0.5rem">
  <button type="button" class="pf-v6-c-button pf-m-secondary pf-m-small" id="warning-dismiss-all">Dismiss All</button>
</div>
<div class="pf-v6-c-alert-group" id="warnings-list">
  {%- for w in warnings %}
  {%- set msg = w.message or w.detail or '—' %}
  {%- set detail = w.detail or '' %}
  <div class="pf-v6-c-alert pf-m-warning pf-m-inline warning-row" data-warning-idx="{{ loop.index0 }}">
    <div class="pf-v6-c-alert__title">{{ msg }}</div>
    {%- if detail and detail != msg %}
    <div class="pf-v6-c-alert__description">{{ detail }}</div>
    {%- endif %}
    <div class="pf-v6-c-alert__action">
      <button type="button" class="pf-v6-c-button pf-m-plain warning-row-dismiss" aria-label="Dismiss">&times;</button>
    </div>
  </div>
  {%- endfor %}
</div>
{% endcall %}

{# ── Audit report ─────────────────────────────────────────────────────────── #}
{% call section("audit", "Audit report") %}
<p>Consolidated view of all inspection findings. Expand sections for details; individual tabs have the full information.</p>
<div class="audit-section">

{# ── 1. Executive Summary ── #}
<h3>Executive Summary</h3>
<dl class="pf-v6-c-description-list">
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Packages added</dt><dd class="pf-v6-c-description-list__description">{{ counts.packages_added }}</dd></div>
  {%- if counts.base_image_only %}
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Base-image-only</dt><dd class="pf-v6-c-description-list__description">{{ counts.base_image_only }}</dd></div>
  {%- endif %}
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Config files</dt><dd class="pf-v6-c-description-list__description">{{ counts.config_files }}</dd></div>
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Containers / quadlets</dt><dd class="pf-v6-c-description-list__description">{{ counts.containers }}</dd></div>
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Secrets redacted</dt><dd class="pf-v6-c-description-list__description">{{ counts.redactions }}</dd></div>
  <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Triage</dt><dd class="pf-v6-c-description-list__description"><span class="text-status-success">{{ triage.automatic }} automatic</span> · <span class="text-status-warning">{{ triage.fixme }} FIXME</span> · <span class="text-status-danger">{{ triage.manual }} manual</span></dd></div>
</dl>

{# ── 2. Packages ── #}
{%- set _audit_leaf = leaf_packages_sorted %}
{%- set _audit_pkgs = snapshot.rpm.packages_added if snapshot.rpm else [] %}
{%- set _audit_bio = snapshot.rpm.base_image_only if snapshot.rpm else [] %}
{%- if _audit_leaf or _audit_pkgs or _audit_bio %}
<details class="audit-expand">
  <summary>Packages</summary>
  {%- if _audit_leaf %}
  <h4>Explicitly installed ({{ _audit_leaf|length }})</h4>
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Name</th><th scope="col">Version</th><th scope="col">Repo</th></tr></thead><tbody>
    {%- for lf in _audit_leaf %}
    {%- for p in snapshot.rpm.packages_added if p.name == lf %}
    <tr><td>{{ p.name }}</td><td>{{ p.version }}-{{ p.release }}</td><td>{{ p.source_repo or '' }}</td></tr>
    {%- endfor %}
    {%- endfor %}
  </tbody></table>
  {%- elif _audit_pkgs %}
  <h4>Packages added ({{ _audit_pkgs|length }})</h4>
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Name</th><th scope="col">Version</th><th scope="col">Arch</th></tr></thead><tbody>
    {%- for p in _audit_pkgs[:50] %}
    <tr><td>{{ p.name }}</td><td>{{ p.version }}-{{ p.release }}</td><td>{{ p.arch }}</td></tr>
    {%- endfor %}
    {%- if _audit_pkgs|length > 50 %}
    <tr><td colspan="3"><em>+{{ _audit_pkgs|length - 50 }} more — see Packages tab</em></td></tr>
    {%- endif %}
  </tbody></table>
  {%- endif %}
  {%- if _audit_bio %}
  <h4>In target image only ({{ _audit_bio|length }})</h4>
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Package</th></tr></thead><tbody>
    {%- for p in _audit_bio[:30] %}
    <tr><td>{{ p.name }}</td></tr>
    {%- endfor %}
    {%- if _audit_bio|length > 30 %}
    <tr><td><em>+{{ _audit_bio|length - 30 }} more — see Packages tab</em></td></tr>
    {%- endif %}
  </tbody></table>
  {%- endif %}
</details>
{%- endif %}

{# ── 3. Services ── #}
{%- set _audit_svc = snapshot.services.state_changes|selectattr('action', 'ne', 'unchanged')|list if snapshot.services and snapshot.services.state_changes else [] %}
{%- if _audit_svc %}
<details class="audit-expand">
  <summary>Services ({{ _audit_svc|length }})</summary>
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Unit</th><th scope="col">Current</th><th scope="col">Default</th><th scope="col">Action</th></tr></thead><tbody>
    {%- for s in _audit_svc %}
    <tr><td>{{ s.unit }}</td><td>{{ s.current_state }}</td><td>{{ s.default_state }}</td><td>{{ s.action }}</td></tr>
    {%- endfor %}
  </tbody></table>
  {%- if snapshot.services.drop_ins %}
  <p class="mt-sm">{{ snapshot.services.drop_ins|length }} systemd drop-in override(s).</p>
  {%- endif %}
</details>
{%- endif %}

{# ── 4. Configuration Files ── #}
{%- if config_files_rendered %}
<details class="audit-expand">
  <summary>Configuration Files ({{ config_files_rendered|length }})</summary>
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Path</th><th scope="col">Kind</th></tr></thead><tbody>
    {%- for item in config_files_rendered %}
    <tr><td><code>{{ item.path }}</code></td><td>{{ item.kind }}</td></tr>
    {%- endfor %}
  </tbody></table>
</details>
{%- endif %}

{# ── 5. Network ── #}
{%- set _net = snapshot.network %}
{%- if _net and (_net.connections or _net.firewall_zones or _net.resolv_provenance) %}
<details class="audit-expand">
  <summary>Network</summary>
  {%- if _net.connections %}
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Connection</th><th scope="col">Method</th><th scope="col">Type</th></tr></thead><tbody>
    {%- for c in _net.connections %}
    <tr><td><code>{{ c.name }}</code></td><td>{{ c.method }}</td><td>{{ c.type }}</td></tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}
  {%- if _net.firewall_zones %}
  <p class="mt-sm"><strong>Firewall zones:</strong>
    {%- for z in _net.firewall_zones %}
    {{ z.name }}{% if z.services %} ({{ z.services|join(', ') }}){% endif %}{% if z.ports %} [{{ z.ports|join(', ') }}]{% endif %}{% if not loop.last %};{% endif %}
    {%- endfor %}
  </p>
  {%- endif %}
  {%- if _net.resolv_provenance %}
  <p><strong>DNS:</strong> {{ _net.resolv_provenance }}</p>
  {%- endif %}
</details>
{%- endif %}

{# ── 6. Storage ── #}
{%- if snapshot.storage and snapshot.storage.fstab_entries %}
<details class="audit-expand">
  <summary>Storage ({{ snapshot.storage.fstab_entries|length }} fstab entries)</summary>
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Device</th><th scope="col">Mount</th><th scope="col">Type</th></tr></thead><tbody>
    {%- for e in snapshot.storage.fstab_entries %}
    <tr><td>{{ e.device }}</td><td>{{ e.mount_point }}</td><td>{{ e.fstype }}</td></tr>
    {%- endfor %}
  </tbody></table>
</details>
{%- endif %}

{# ── 7. Scheduled Tasks ── #}
{%- set _st = snapshot.scheduled_tasks %}
{%- if _st and (_st.systemd_timers or _st.generated_timer_units or _st.cron_jobs or _st.at_jobs) %}
<details class="audit-expand">
  <summary>Scheduled Tasks</summary>
  {%- set _local_timers = [] %}
  {%- for t in _st.systemd_timers %}{% if t.source == 'local' %}{% set _ = _local_timers.append(t) %}{% endif %}{%- endfor %}
  {%- if _local_timers %}
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Timer</th><th scope="col">Schedule</th></tr></thead><tbody>
    {%- for t in _local_timers %}
    <tr><td>{{ t.name }}</td><td>{{ t.on_calendar }}</td></tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}
  {%- if _st.generated_timer_units %}<p>{{ _st.generated_timer_units|length }} cron-converted timer(s).</p>{%- endif %}
  {%- if _st.at_jobs %}<p>{{ _st.at_jobs|length }} at job(s).</p>{%- endif %}
</details>
{%- endif %}

{# ── 8. Container Workloads ── #}
{%- set _ct = snapshot.containers %}
{%- if _ct and (_ct.quadlet_units or _ct.compose_files) %}
<details class="audit-expand">
  <summary>Container Workloads</summary>
  {%- if _ct.quadlet_units %}
  <table class="pf-v6-c-table"><thead><tr><th scope="col">Unit</th><th scope="col">Image</th><th scope="col">Path</th></tr></thead><tbody>
    {%- for u in _ct.quadlet_units %}
    <tr><td>{{ u.name }}</td><td>{% if u.image %}<code>{{ u.image }}</code>{% endif %}</td><td><code>{{ u.path }}</code></td></tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}
  {%- if _ct.compose_files %}
  <p class="mt-sm">Compose files:
    {%- for c in _ct.compose_files %} <code>{{ c.path }}</code>{% if not loop.last %},{% endif %}{%- endfor %}
  </p>
  {%- endif %}
</details>
{%- endif %}

{# ── 9. Non-RPM Software ── #}
{%- set _nd = non_rpm_data %}
{%- if _nd.elf or _nd.venv or _nd.git or _nd.pip %}
<details class="audit-expand">
  <summary>Non-RPM Software</summary>
  <dl class="pf-v6-c-description-list">
    {%- if _nd.elf %}
    <div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Compiled binaries</dt><dd class="pf-v6-c-description-list__description">{{ _nd.elf|length }} ({%- for group in _nd.elf|groupby('lang') %}{{ group.list|length }}&nbsp;{{ group.grouper }}{% if not loop.last %}, {% endif %}{%- endfor %})</dd></div>
    {%- endif %}
    {%- if _nd.venv %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Python venvs</dt><dd class="pf-v6-c-description-list__description">{{ _nd.venv|length }}</dd></div>{%- endif %}
    {%- if _nd.git %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Git repos</dt><dd class="pf-v6-c-description-list__description">{{ _nd.git|length }}</dd></div>{%- endif %}
    {%- if _nd.pip %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">System pip packages</dt><dd class="pf-v6-c-description-list__description">{{ _nd.pip|length }}</dd></div>{%- endif %}
  </dl>
</details>
{%- endif %}

{# ── 10. Kernel / Boot ── #}
{%- set _kb = snapshot.kernel_boot %}
{%- if _kb and (_kb.sysctl_overrides or _kb.modules_load_d or _kb.modprobe_d or _kb.dracut_conf or _kb.tuned_active) %}
<details class="audit-expand">
  <summary>Kernel / Boot</summary>
  <dl class="pf-v6-c-description-list">
    {%- if _kb.sysctl_overrides %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Sysctl overrides</dt><dd class="pf-v6-c-description-list__description">{{ _kb.sysctl_overrides|length }}</dd></div>{%- endif %}
    {%- if _kb.modules_load_d %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">modules-load.d</dt><dd class="pf-v6-c-description-list__description">{{ _kb.modules_load_d|length }} file(s)</dd></div>{%- endif %}
    {%- if _kb.modprobe_d %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">modprobe.d</dt><dd class="pf-v6-c-description-list__description">{{ _kb.modprobe_d|length }} file(s)</dd></div>{%- endif %}
    {%- if _kb.dracut_conf %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">dracut.conf.d</dt><dd class="pf-v6-c-description-list__description">{{ _kb.dracut_conf|length }} file(s)</dd></div>{%- endif %}
    {%- if _kb.tuned_active %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Tuned profile</dt><dd class="pf-v6-c-description-list__description">{{ _kb.tuned_active }}</dd></div>{%- endif %}
  </dl>
</details>
{%- endif %}

{# ── 11. SELinux ── #}
{%- set _se = snapshot.selinux %}
{%- if _se and (_se.mode or _se.custom_modules or _se.boolean_overrides or _se.audit_rules) %}
<details class="audit-expand">
  <summary>SELinux</summary>
  <dl class="pf-v6-c-description-list">
    {%- if _se.mode %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Mode</dt><dd class="pf-v6-c-description-list__description">{{ _se.mode }}</dd></div>{%- endif %}
    {%- if _se.custom_modules %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Custom modules</dt><dd class="pf-v6-c-description-list__description">{{ _se.custom_modules|length }}</dd></div>{%- endif %}
    {%- set _se_nd = _se.boolean_overrides|selectattr('non_default')|list %}
    {%- if _se_nd %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Non-default booleans</dt><dd class="pf-v6-c-description-list__description">{{ _se_nd|length }}</dd></div>{%- endif %}
    {%- if _se.audit_rules %}<div class="pf-v6-c-description-list__group"><dt class="pf-v6-c-description-list__term">Audit rules</dt><dd class="pf-v6-c-description-list__description">{{ _se.audit_rules|length }}</dd></div>{%- endif %}
  </dl>
</details>
{%- endif %}

{# ── 12. Users / Groups ── #}
{%- set _ug = snapshot.users_groups %}
{%- if _ug and (_ug.users or _ug.groups) %}
<details class="audit-expand">
  <summary>Users / Groups</summary>
  {%- if _ug.users %}
  <table class="pf-v6-c-table"><thead><tr><th scope="col">User</th><th scope="col">UID</th><th scope="col">Type</th><th scope="col">Strategy</th></tr></thead><tbody>
    {%- for u in _ug.users %}
    <tr><td>{{ u.name }}</td><td>{{ u.uid }}</td><td>{{ u.classification or '?' }}</td><td>{{ u.strategy or '' }}</td></tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}
  {%- if _ug.groups %}
  <table class="pf-v6-c-table mt-sm"><thead><tr><th scope="col">Group</th><th scope="col">GID</th><th scope="col">Members</th></tr></thead><tbody>
    {%- for g in _ug.groups %}
    <tr><td>{{ g.name }}</td><td>{{ g.gid }}</td><td>{{ (g.members or [])|join(', ') or '—' }}</td></tr>
    {%- endfor %}
  </tbody></table>
  {%- endif %}
</details>
{%- endif %}

{# ── 13. Items Requiring Manual Intervention ── #}
{%- if warnings %}
<h3>Items Requiring Manual Intervention</h3>
<ul style="margin:0.25rem 0 0;padding-left:1.5rem;font-size:0.9rem">
  {%- for w in warnings[:20] %}
  {%- set msg = w.message or w.detail or '—' %}
  <li>{{ msg }}</li>
  {%- endfor %}
  {%- if warnings|length > 20 %}
  <li><em>+{{ warnings|length - 20 }} more — see Warnings tab.</em></li>
  {%- endif %}
</ul>
{%- endif %}

</div>{# /.audit-section #}
{% endcall %}

{# ── Containerfile ────────────────────────────────────────────────────────── #}
<div id="section-containerfile" class="section">
  <div class="pf-v6-c-card">
    <div class="pf-v6-c-card__header">
      <div class="pf-v6-c-card__title">
        <div class="section-heading-row">
          <h2>Containerfile</h2>
          <button type="button" class="pf-v6-c-button pf-m-secondary pf-m-small btn-copy-cf" id="btn-copy-cf">Copy</button>
        </div>
